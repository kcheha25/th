import gc
import json
import os
import random
from pathlib import Path

import h5py
import numpy as np
import torch
from torch.utils.data import Dataset, DataLoader, DistributedSampler
import torch.distributed as dist

CHUNK_READ = 2_048
PREFETCH_Q = 8

_H5_REGISTRY: dict = {}

def _get_h5_handle(h5_path: str) -> h5py.File:
    key = (os.getpid(), h5_path)
    f = _H5_REGISTRY.get(key)
    if f is None or not f.id.valid:
        f = h5py.File(h5_path, 'r', swmr=True)
        _H5_REGISTRY[key] = f
    return f

class FastHDF5Dataset(Dataset):
    def __init__(self, h5_path: str, split_name: str,
                 dtype_x=np.float32):
        self.h5_path    = str(h5_path)
        self.split_name = split_name
        self.dtype_x    = dtype_x

        with h5py.File(self.h5_path, 'r') as f:
            self.length  = int(f[f"{split_name}/y"].shape[0])
            self.x_shape = tuple(f[f"{split_name}/X"].shape[1:])

    def __len__(self):
        return self.length

    def __getitem__(self, idx):
        f = _get_h5_handle(self.h5_path)
        X = torch.from_numpy(
            f[f"{self.split_name}/X"][idx].astype(self.dtype_x)
        )
        y = int(f[f"{self.split_name}/y"][idx])
        return X.unsqueeze(0), torch.tensor(y, dtype=torch.long)

def make_loaders_fast(h5_path: str,
                      batch_size: int      = 512,
                      num_workers: int     = 8,
                      rank: int            = 0,
                      world_size: int      = 1,
                      seed: int            = 42,
                      chunk_read: int      = CHUNK_READ,
                      pin_memory: bool     = True,
                      prefetch_factor: int = 4):
    train_ds = FastHDF5Dataset(h5_path, 'train')
    val_ds   = FastHDF5Dataset(h5_path, 'val')
    test_ds  = FastHDF5Dataset(h5_path, 'test')

    def _worker_init(wid):
        s = (torch.initial_seed() + wid) % (2 ** 32)
        np.random.seed(s)
        random.seed(s)

    pf = prefetch_factor if num_workers > 0 else None
    common = dict(
        num_workers        = num_workers,
        pin_memory         = pin_memory,
        worker_init_fn     = _worker_init,
        persistent_workers = (num_workers > 0),
        prefetch_factor    = pf,
    )

    if world_size > 1:
        train_sampler = DistributedSampler(
            train_ds, num_replicas=world_size, rank=rank, shuffle=True, seed=seed)
        val_sampler   = DistributedSampler(
            val_ds,   num_replicas=world_size, rank=rank, shuffle=False)
        test_sampler  = DistributedSampler(
            test_ds,  num_replicas=world_size, rank=rank, shuffle=False)
        shuffle_train = False
    else:
        train_sampler = val_sampler = test_sampler = None
        shuffle_train = True

    train_loader = DataLoader(train_ds, batch_size=batch_size,
                              sampler=train_sampler, shuffle=shuffle_train, **common)
    val_loader   = DataLoader(val_ds,   batch_size=batch_size * 2,
                              sampler=val_sampler,   shuffle=False, **common)
    test_loader  = DataLoader(test_ds,  batch_size=batch_size * 2,
                              sampler=test_sampler,  shuffle=False, **common)

    with h5py.File(h5_path, 'r') as f:
        meta = {
            "class_names": json.loads(f.attrs.get("class_names", "[]")),
            "label2idx":   json.loads(f.attrs.get("label2idx",   "{}")),
            "num_classes": len(json.loads(f.attrs.get("class_names", "[]"))),
            "num_bands":   int(f['train/X'].shape[1]),
            "patch_size":  int(f.attrs.get("patch_size", 13)),
        }

    return train_loader, val_loader, test_loader, meta, train_sampler