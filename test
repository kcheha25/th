def get_dataset_length(loader):
    if hasattr(loader, 'dataset'):
        return len(loader.dataset)
    elif hasattr(loader, 'loader'):
        return len(loader.loader.dataset)
    elif hasattr(loader, '_dataset'):
        return len(loader._dataset)
    else:
        return 0

def train(train_loader, meta, epochs, learning_rate=0.001, device=None):
    if device is None:
        device = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
    print(f"\nTraining on device: {device}")
    num_bands = meta['num_bands']
    net = SSFTTnet.SSFTTnet(n_bands=num_bands, n_classes=meta['num_classes'], patch_size=meta['patch_size']).to(device)
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(net.parameters(), lr=learning_rate)
    scheduler = optim.lr_scheduler.StepLR(optimizer, step_size=50, gamma=0.5)
    best_loss = float('inf')
    print("\nStarting training...")
    print("="*60)
    for epoch in range(epochs):
        net.train()
        epoch_loss = 0
        batch_count = 0
        for i, (data, target) in enumerate(train_loader):
            data, target = data.to(device), target.to(device)
            outputs = net(data)
            loss = criterion(outputs, target)
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            epoch_loss += loss.item()
            batch_count += 1
            if (i + 1) % 50 == 0:
                print(f'  Epoch [{epoch+1}/{epochs}] Batch [{i+1}] Loss: {loss.item():.4f}')
        avg_loss = epoch_loss / batch_count if batch_count > 0 else 0
        if avg_loss < best_loss:
            best_loss = avg_loss
            torch.save(net.state_dict(), 'cls_params/SSFTTnet_best.pth')
            print(f'  New best model saved! (loss: {best_loss:.4f})')
        scheduler.step()
        print(f'[Epoch {epoch+1}/{epochs}] Avg Loss: {avg_loss:.4f} | Best Loss: {best_loss:.4f} | LR: {scheduler.get_last_lr()[0]:.6f}')
        print_cache_stats(meta, epoch+1)
    print("\n" + "="*60)
    print("Training finished!")
    torch.save(net.state_dict(), 'cls_params/SSFTTnet_final.pth')
    return net, device

def test(device, net, test_loader):
    print("\nTesting model...")
    net.eval()
    y_pred_test = []
    y_test = []
    with torch.no_grad():
        for inputs, labels in test_loader:
            inputs = inputs.to(device)
            outputs = net(inputs)
            outputs = np.argmax(outputs.cpu().numpy(), axis=1)
            y_pred_test.extend(outputs)
            y_test.extend(labels.numpy())
    return np.array(y_pred_test), np.array(y_test)

def AA_andEachClassAccuracy(confusion_matrix):
    list_diag = np.diag(confusion_matrix)
    list_raw_sum = np.sum(confusion_matrix, axis=1)
    each_acc = np.nan_to_num(truediv(list_diag, list_raw_sum))
    average_acc = np.mean(each_acc)
    return each_acc, average_acc

def acc_reports(y_test, y_pred_test, class_names):
    classification = classification_report(y_test, y_pred_test, digits=4, target_names=class_names)
    oa = accuracy_score(y_test, y_pred_test)
    confusion = confusion_matrix(y_test, y_pred_test)
    each_acc, aa = AA_andEachClassAccuracy(confusion)
    kappa = cohen_kappa_score(y_test, y_pred_test)
    return classification, oa*100, confusion, each_acc*100, aa*100, kappa*100

