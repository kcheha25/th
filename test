import argparse
import time
import torch
import torch.nn as nn
from torch.cuda.amp import autocast, GradScaler

from fast_dataset import make_loaders_fast
from ssfnet import SSFTTnet

N_BATCHES = 50

def parse_args():
    p = argparse.ArgumentParser()
    p.add_argument("--h5_path",    required=True)
    p.add_argument("--batch_size", type=int, default=512)
    p.add_argument("--num_workers",type=int, default=8)
    p.add_argument("--amp_dtype",  default="float16", choices=["float16","bfloat16","none"])
    return p.parse_args()

def timer(label, fn, n_warmup=2, n_repeat=10):
    device = next(iter([].__class__.__mro__))
    for _ in range(n_warmup):
        fn()
    if torch.cuda.is_available():
        torch.cuda.synchronize()
    t0 = time.perf_counter()
    for _ in range(n_repeat):
        fn()
    if torch.cuda.is_available():
        torch.cuda.synchronize()
    elapsed = (time.perf_counter() - t0) / n_repeat * 1000
    print(f"  {label:<30s}: {elapsed:7.2f} ms/batch")
    return elapsed

def main():
    args   = parse_args()
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

    print(f"\n{'═'*55}")
    print(f"  Profiling bottleneck — device: {device}")
    print(f"  batch_size={args.batch_size}  workers={args.num_workers}")
    print(f"{'═'*55}\n")

    train_loader, _, _, meta, _ = make_loaders_fast(
        h5_path     = args.h5_path,
        batch_size  = args.batch_size,
        num_workers = args.num_workers,
    )
    loader_iter = iter(train_loader)

    print("── 1. Débit DataLoader pur (CPU uniquement) ─────────────────")
    times = []
    for i in range(N_BATCHES + 2):
        t0 = time.perf_counter()
        try:
            X, y = next(loader_iter)
        except StopIteration:
            loader_iter = iter(train_loader)
            X, y = next(loader_iter)
        dt = (time.perf_counter() - t0) * 1000
        if i >= 2:
            times.append(dt)

    import statistics
    print(f"  mean  : {statistics.mean(times):.2f} ms")
    print(f"  median: {statistics.median(times):.2f} ms")
    print(f"  min   : {min(times):.2f} ms")
    print(f"  max   : {max(times):.2f} ms")
    throughput = args.batch_size / (statistics.mean(times) / 1000)
    print(f"  → Débit loader : {throughput:,.0f} patches/s\n")

    if not torch.cuda.is_available():
        print("Pas de GPU détecté — profiling GPU ignoré.")
        return

    print("── 2. Transfert CPU→GPU (H2D) ───────────────────────────────")
    X_cpu, y_cpu = X, y
    times_h2d = []
    for _ in range(N_BATCHES):
        torch.cuda.synchronize()
        t0 = time.perf_counter()
        X_gpu = X_cpu.to(device, non_blocking=False)
        y_gpu = y_cpu.to(device, non_blocking=False)
        torch.cuda.synchronize()
        times_h2d.append((time.perf_counter() - t0) * 1000)
    print(f"  mean H2D : {statistics.mean(times_h2d):.2f} ms")
    size_mb = X_cpu.nbytes / 1e6
    bw = size_mb / (statistics.mean(times_h2d) / 1000) / 1e3
    print(f"  batch size: {size_mb:.1f} MB → BW effective: {bw:.1f} GB/s\n")

    num_classes = meta["num_classes"]
    model = SSFTTnet(
        in_channels=1, num_classes=num_classes,
        num_tokens=4, dim=64, depth=1, heads=8, mlp_dim=8,
    ).to(device)
    model.train()

    criterion = nn.CrossEntropyLoss()
    optimizer = torch.optim.AdamW(model.parameters(), lr=1e-3)
    scaler    = GradScaler()

    amp_dtype = None
    if args.amp_dtype == "float16":
        amp_dtype = torch.float16
    elif args.amp_dtype == "bfloat16":
        amp_dtype = torch.bfloat16

    X_gpu = X_cpu.to(device)
    y_gpu = y_cpu.to(device)

    print("── 3. Forward pass ──────────────────────────────────────────")
    times_fwd = []
    for _ in range(N_BATCHES):
        torch.cuda.synchronize()
        t0 = time.perf_counter()
        if amp_dtype:
            with autocast(device_type="cuda", dtype=amp_dtype):
                logits = model(X_gpu)
        else:
            logits = model(X_gpu)
        torch.cuda.synchronize()
        times_fwd.append((time.perf_counter() - t0) * 1000)
    print(f"  mean forward : {statistics.mean(times_fwd):.2f} ms")
    print(f"  → {args.batch_size / (statistics.mean(times_fwd)/1000):,.0f} patches/s\n")

    print("── 4. Backward pass ─────────────────────────────────────────")
    times_bwd = []
    for _ in range(N_BATCHES):
        if amp_dtype:
            with autocast(device_type="cuda", dtype=amp_dtype):
                logits = model(X_gpu)
                loss   = criterion(logits, y_gpu)
            torch.cuda.synchronize()
            t0 = time.perf_counter()
            scaler.scale(loss).backward()
        else:
            logits = model(X_gpu)
            loss   = criterion(logits, y_gpu)
            torch.cuda.synchronize()
            t0 = time.perf_counter()
            loss.backward()
        torch.cuda.synchronize()
        times_bwd.append((time.perf_counter() - t0) * 1000)
        optimizer.zero_grad(set_to_none=True)
    print(f"  mean backward: {statistics.mean(times_bwd):.2f} ms\n")

    print("── 5. Optimizer step ────────────────────────────────────────")
    times_opt = []
    for _ in range(N_BATCHES):
        if amp_dtype:
            with autocast(device_type="cuda", dtype=amp_dtype):
                logits = model(X_gpu)
                loss   = criterion(logits, y_gpu)
            scaler.scale(loss).backward()
            torch.cuda.synchronize()
            t0 = time.perf_counter()
            scaler.step(optimizer)
            scaler.update()
        else:
            logits = model(X_gpu)
            loss   = criterion(logits, y_gpu)
            loss.backward()
            torch.cuda.synchronize()
            t0 = time.perf_counter()
            optimizer.step()
        torch.cuda.synchronize()
        times_opt.append((time.perf_counter() - t0) * 1000)
        optimizer.zero_grad(set_to_none=True)
    print(f"  mean opt step: {statistics.mean(times_opt):.2f} ms\n")

    t_load  = statistics.mean(times)
    t_h2d   = statistics.mean(times_h2d)
    t_fwd   = statistics.mean(times_fwd)
    t_bwd   = statistics.mean(times_bwd)
    t_opt   = statistics.mean(times_opt)
    t_total = t_load + t_h2d + t_fwd + t_bwd + t_opt

    print(f"{'═'*55}")
    print(f"  RÉSUMÉ (ms/batch, batch={args.batch_size})")
    print(f"{'─'*55}")
    for label, t in [("DataLoader",t_load),("H2D transfer",t_h2d),
                     ("Forward",t_fwd),("Backward",t_bwd),("Optim step",t_opt)]:
        bar = "█" * int(t / t_total * 30)
        print(f"  {label:<15s} {t:7.2f} ms  {t/t_total*100:5.1f}%  {bar}")
    print(f"{'─'*55}")
    print(f"  TOTAL estimé : {t_total:.2f} ms/batch")
    print(f"  Throughput   : {args.batch_size/(t_total/1000):,.0f} patches/s")
    print(f"  Époque (66M) : {66_000_000/(args.batch_size/(t_total/1000))/60:.1f} min")
    print(f"{'═'*55}\n")
    print("→ La colonne % indique LE goulot réel à optimiser.")

if __name__ == "__main__":
    main()


