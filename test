import gc
import json
import random
import threading
import queue
from pathlib import Path

import h5py
import numpy as np
import torch
from torch.utils.data import Dataset, DataLoader, DistributedSampler, RandomSampler
import torch.distributed as dist

CHUNK_READ   = 2_048
PREFETCH_Q   = 8

class FastHDF5Dataset(Dataset):
    def __init__(self, h5_path: str, split_name: str,
                 chunk_read: int = CHUNK_READ,
                 dtype_x: np.dtype = np.float32):
        self.h5_path    = h5_path
        self.split_name = split_name
        self.chunk_read = chunk_read
        self.dtype_x    = dtype_x

        with h5py.File(h5_path, 'r', swmr=True) as f:
            self.length  = f[f"{split_name}/y"].shape[0]
            self.x_shape = f[f"{split_name}/X"].shape[1:]

        self._h5_local = threading.local()

    def _get_h5(self):
        if not hasattr(self._h5_local, 'f') or not self._h5_local.f.id.valid:
            self._h5_local.f = h5py.File(self.h5_path, 'r', swmr=True)
        return self._h5_local.f

    def __len__(self):
        return self.length

    def __getitem__(self, idx):
        f  = self._get_h5()
        X  = torch.from_numpy(f[f"{self.split_name}/X"][idx].astype(self.dtype_x))
        y  = int(f[f"{self.split_name}/y"][idx])
        X  = X.unsqueeze(0)
        return X, torch.tensor(y, dtype=torch.long)

    def __del__(self):
        if hasattr(self._h5_local, 'f'):
            try:
                self._h5_local.f.close()
            except Exception:
                pass

class SlabHDF5Dataset(Dataset):
    def __init__(self, h5_path: str, split_name: str, slab_size: int = 200_000,
                 shuffle: bool = True, seed: int = 0):
        self.h5_path    = h5_path
        self.split_name = split_name
        self.slab_size  = slab_size
        self.shuffle    = shuffle
        self.seed       = seed

        with h5py.File(h5_path, 'r', swmr=True) as f:
            self.length  = f[f"{split_name}/y"].shape[0]
            self.x_shape = f[f"{split_name}/X"].shape[1:]

        self._build_index()

    def _build_index(self):
        rng = np.random.default_rng(self.seed)
        slab_ids = np.arange(0, self.length, self.slab_size)
        if self.shuffle:
            rng.shuffle(slab_ids)
        self._index = np.concatenate([
            np.arange(s, min(s + self.slab_size, self.length))
            for s in slab_ids
        ]).astype(np.int64)

    def reshuffle(self, epoch: int):
        rng = np.random.default_rng(self.seed + epoch * 1_000_003)
        slab_ids = np.arange(0, self.length, self.slab_size)
        rng.shuffle(slab_ids)
        self._index = np.concatenate([
            np.arange(s, min(s + self.slab_size, self.length))
            for s in slab_ids
        ]).astype(np.int64)

    def __len__(self):
        return self.length

    def __getitem__(self, pos):
        idx = int(self._index[pos])
        with h5py.File(self.h5_path, 'r', swmr=True) as f:
            X = torch.from_numpy(f[f"{self.split_name}/X"][idx].astype(np.float32))
            y = int(f[f"{self.split_name}/y"][idx])
        return X.unsqueeze(0), torch.tensor(y, dtype=torch.long)

def make_loaders_fast(h5_path: str,
                      batch_size: int      = 512,
                      num_workers: int     = 8,
                      rank: int            = 0,
                      world_size: int      = 1,
                      seed: int            = 42,
                      chunk_read: int      = CHUNK_READ,
                      pin_memory: bool     = True,
                      prefetch_factor: int = 4):
    train_ds = FastHDF5Dataset(h5_path, 'train', chunk_read=chunk_read)
    val_ds   = FastHDF5Dataset(h5_path, 'val',   chunk_read=chunk_read)
    test_ds  = FastHDF5Dataset(h5_path, 'test',  chunk_read=chunk_read)

    def _worker_init(wid):
        s = (torch.initial_seed() + wid) % (2**32)
        np.random.seed(s)
        random.seed(s)

    common = dict(
        num_workers    = num_workers,
        pin_memory     = pin_memory,
        worker_init_fn = _worker_init,
        persistent_workers = (num_workers > 0),
        prefetch_factor    = prefetch_factor if num_workers > 0 else None,
    )

    if world_size > 1:
        train_sampler = DistributedSampler(train_ds, num_replicas=world_size,
                                           rank=rank, shuffle=True, seed=seed)
        val_sampler   = DistributedSampler(val_ds,   num_replicas=world_size,
                                           rank=rank, shuffle=False)
        test_sampler  = DistributedSampler(test_ds,  num_replicas=world_size,
                                           rank=rank, shuffle=False)
        shuffle_train = False
    else:
        train_sampler = None
        val_sampler   = None
        test_sampler  = None
        shuffle_train = True

    train_loader = DataLoader(train_ds, batch_size=batch_size,
                              sampler=train_sampler, shuffle=shuffle_train, **common)
    val_loader   = DataLoader(val_ds,   batch_size=batch_size * 2,
                              sampler=val_sampler,   shuffle=False, **common)
    test_loader  = DataLoader(test_ds,  batch_size=batch_size * 2,
                              sampler=test_sampler,  shuffle=False, **common)

    with h5py.File(h5_path, 'r') as f:
        meta = {
            "class_names": json.loads(f.attrs.get("class_names", "[]")),
            "label2idx":   json.loads(f.attrs.get("label2idx",   "{}")),
            "num_classes": len(json.loads(f.attrs.get("class_names", "[]"))),
            "num_bands":   int(f['train/X'].shape[1]),
            "patch_size":  int(f.attrs.get("patch_size", 13)),
        }

    return train_loader, val_loader, test_loader, meta, train_sampler