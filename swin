_to_2tuple = nn.modules.utils._ntuple(2)


class Mlp(nn.Module):
    def __init__(self, in_features, hidden_features=None, out_features=None, act_layer=nn.GELU, drop=0.0):
        super().__init__()
        out_features = out_features or in_features
        hidden_features = hidden_features or in_features
        self.fc1 = nn.Linear(in_features, hidden_features)
        self.act = act_layer()
        self.fc2 = nn.Linear(hidden_features, out_features)
        self.drop = nn.Dropout(drop)

    def forward(self, x):
        x = self.fc1(x)
        x = self.act(x)
        x = self.drop(x)
        x = self.fc2(x)
        x = self.drop(x)
        return x


def spectral_window_partition(x, window_size):
    B, N, D = x.shape
    pad_n = (window_size - N % window_size) % window_size
    if pad_n > 0:
        x = F.pad(x, (0, 0, 0, pad_n))
    N_padded = x.shape[1]
    x = x.view(B, N_padded // window_size, window_size, D)
    windows = x.contiguous().view(-1, window_size, D)
    return windows, N, pad_n


def spectral_window_reverse(windows, window_size, N_original, pad_n):
    N_padded = N_original + pad_n
    B = windows.shape[0] // (N_padded // window_size)
    x = windows.view(B, N_padded // window_size, window_size, -1)
    x = x.contiguous().view(B, N_padded, -1)
    if pad_n > 0:
        x = x[:, :N_original, :]
    return x


class SpectralWindowAttention(nn.Module):
    def __init__(self, dim, window_size, num_heads, qkv_bias=True, qk_scale=None, attn_drop=0.0, proj_drop=0.0):
        super().__init__()
        self.dim = dim
        self.window_size = window_size
        self.num_heads = num_heads
        head_dim = dim // num_heads
        self.scale = qk_scale or head_dim**-0.5
        self.relative_position_bias_table = nn.Parameter(torch.zeros((2 * window_size - 1), num_heads))
        coords = torch.arange(self.window_size)
        relative_coords = coords[None, :] - coords[:, None]
        relative_coords += self.window_size - 1
        self.register_buffer("relative_position_index", relative_coords)
        self.qkv = nn.Linear(dim, dim * 3, bias=qkv_bias)
        self.attn_drop = nn.Dropout(attn_drop)
        self.proj = nn.Linear(dim, dim)
        self.proj_drop = nn.Dropout(proj_drop)
        trunc_normal_(self.relative_position_bias_table, std=0.02)
        self.softmax = nn.Softmax(dim=-1)

    def forward(self, x, mask=None):
        B_, N, C = x.shape
        qkv = self.qkv(x).reshape(B_, N, 3, self.num_heads, C // self.num_heads).permute(2, 0, 3, 1, 4)
        q, k, v = qkv[0], qkv[1], qkv[2]
        q = q * self.scale
        attn = q @ k.transpose(-2, -1)
        relative_position_bias = self.relative_position_bias_table[self.relative_position_index.view(-1)].view(
            self.window_size, self.window_size, -1)
        relative_position_bias = relative_position_bias.permute(2, 0, 1).contiguous()
        attn = attn + relative_position_bias.unsqueeze(0)
        if mask is not None:
            nW = mask.shape[0]
            attn = attn.view(B_ // nW, nW, self.num_heads, N, N) + mask.unsqueeze(1).unsqueeze(0)
            attn = attn.view(-1, self.num_heads, N, N)
            attn = self.softmax(attn)
        else:
            attn = self.softmax(attn)
        attn = self.attn_drop(attn)
        x = (attn @ v).transpose(1, 2).reshape(B_, N, C)
        x = self.proj(x)
        x = self.proj_drop(x)
        return x


class SpectralSwinTransformerBlock(nn.Module):
    def __init__(self, dim, num_heads, window_size=8, shift_size=0, mlp_ratio=4.0, qkv_bias=True,
                 qk_scale=None, drop=0.0, attn_drop=0.0, drop_path=0.0, act_layer=nn.GELU,
                 norm_layer=nn.LayerNorm):
        super().__init__()
        self.dim = dim
        self.num_heads = num_heads
        self.window_size = window_size
        self.shift_size = shift_size
        self.mlp_ratio = mlp_ratio
        assert 0 <= self.shift_size < self.window_size
        self.norm1 = norm_layer(dim)
        self.attn = SpectralWindowAttention(
            dim, window_size=self.window_size, num_heads=num_heads,
            qkv_bias=qkv_bias, qk_scale=qk_scale, attn_drop=attn_drop, proj_drop=drop)
        self.drop_path = DropPath(drop_path) if drop_path > 0.0 else nn.Identity()
        self.norm2 = norm_layer(dim)
        mlp_hidden_dim = int(dim * mlp_ratio)
        self.mlp = Mlp(in_features=dim, hidden_features=mlp_hidden_dim, act_layer=act_layer, drop=drop)

    def forward(self, x, attn_mask=None):
        B, N, D = x.shape
        shortcut = x
        x = self.norm1(x)
        if self.shift_size > 0:
            shifted_x = torch.roll(x, shifts=-self.shift_size, dims=1)
        else:
            shifted_x = x
        x_windows, N_original, pad_n = spectral_window_partition(shifted_x, self.window_size)
        attn_windows = self.attn(x_windows, mask=attn_mask)
        shifted_x = spectral_window_reverse(attn_windows, self.window_size, N_original, pad_n)
        if self.shift_size > 0:
            x = torch.roll(shifted_x, shifts=self.shift_size, dims=1)
        else:
            x = shifted_x
        x = shortcut + self.drop_path(x)
        x = x + self.drop_path(self.mlp(self.norm2(x)))
        return x


class SpectralPatchMerging(nn.Module):
    def __init__(self, dim, norm_layer=nn.LayerNorm):
        super().__init__()
        self.dim = dim
        self.reduction = nn.Linear(2 * dim, 2 * dim, bias=False)
        self.norm = norm_layer(2 * dim)

    def forward(self, x):
        B, N, D = x.shape
        if N % 2 == 1:
            x = F.pad(x, (0, 0, 0, 1))
            N = N + 1
        x0 = x[:, 0::2, :]
        x1 = x[:, 1::2, :]
        x = torch.cat([x0, x1], -1)
        x = self.norm(x)
        x = self.reduction(x)
        return x


class BasicSpectralLayer(nn.Module):
    def __init__(self, dim, depth, num_heads, window_size=8, mlp_ratio=4.0, qkv_bias=True,
                 qk_scale=None, drop=0.0, attn_drop=0.0, drop_path=0.0, norm_layer=nn.LayerNorm,
                 downsample=None, use_checkpoint=False):
        super().__init__()
        self.window_size = window_size
        self.shift_size = window_size // 2
        self.depth = depth
        self.use_checkpoint = use_checkpoint
        self.blocks = nn.ModuleList([
            SpectralSwinTransformerBlock(
                dim=dim, num_heads=num_heads, window_size=window_size,
                shift_size=0 if (i % 2 == 0) else window_size // 2,
                mlp_ratio=mlp_ratio, qkv_bias=qkv_bias, qk_scale=qk_scale,
                drop=drop, attn_drop=attn_drop,
                drop_path=drop_path[i] if isinstance(drop_path, list) else drop_path,
                norm_layer=norm_layer)
            for i in range(depth)])
        self.downsample = downsample(dim=dim, norm_layer=norm_layer) if downsample is not None else None

    def forward(self, x):
        B, N, D = x.shape
        N_padded = int(np.ceil(N / self.window_size)) * self.window_size
        img_mask = torch.zeros((1, N_padded, 1), device=x.device)
        n_slices = (
            slice(0, -self.window_size),
            slice(-self.window_size, -self.shift_size),
            slice(-self.shift_size, None),
        )
        cnt = 0
        for s in n_slices:
            img_mask[:, s, :] = cnt
            cnt += 1
        mask_windows, _, _ = spectral_window_partition(img_mask, self.window_size)
        mask_windows = mask_windows.squeeze(-1)
        attn_mask = mask_windows.unsqueeze(1) - mask_windows.unsqueeze(2)
        attn_mask = attn_mask.masked_fill(attn_mask != 0, float(-100.0)).masked_fill(attn_mask == 0, float(0.0))
        for blk in self.blocks:
            if self.use_checkpoint:
                x = checkpoint.checkpoint(blk, x, attn_mask)
            else:
                x = blk(x, attn_mask)
        if self.downsample is not None:
            x_down = self.downsample(x)
            return x, x_down
        else:
            return x, x


class SpectralPatchEmbed(nn.Module):
    def __init__(self, in_chans=256, spectral_patch_size=1, embed_dim=256, norm_layer=None):
        super().__init__()
        self.in_chans = in_chans
        self.spectral_patch_size = spectral_patch_size
        self.embed_dim = embed_dim
        self.num_spectral_tokens = in_chans // spectral_patch_size
        self.proj = nn.Linear(spectral_patch_size, embed_dim)
        self.norm = norm_layer(embed_dim) if norm_layer is not None else None

    def forward(self, x):
        B, C, H, W = x.shape
        x = x.permute(0, 2, 3, 1).contiguous()
        x = x.view(B * H * W, C)
        x = x.view(B * H * W, self.num_spectral_tokens, self.spectral_patch_size)
        x = self.proj(x)
        if self.norm is not None:
            x = self.norm(x)
        return x, H, W


class SpatialDownsample(nn.Module):
    def __init__(self, channels):
        super().__init__()
        self.dw_conv = nn.Conv2d(
            channels, channels,
            kernel_size=3, stride=2, padding=1,
            groups=channels, bias=False,
        )
        self.bn = nn.BatchNorm2d(channels)
        self.act = nn.GELU()

    def forward(self, x, H, W, B):
        N_tokens = x.shape[1]
        C = x.shape[2]
        H2 = (H + 1) // 2
        W2 = (W + 1) // 2
        x_mean = x.mean(dim=1)
        x_spatial = x_mean.view(B, H, W, C).permute(0, 3, 1, 2).contiguous()
        x_spatial = self.dw_conv(x_spatial)
        x_spatial = self.bn(x_spatial)
        x_spatial = self.act(x_spatial)
        assert x_spatial.shape[2] == H2 and x_spatial.shape[3] == W2
        x = x.view(B, H, W, N_tokens, C)
        x = x.permute(0, 3, 4, 1, 2).contiguous().view(B, N_tokens * C, H, W)
        x = F.interpolate(x, size=(H2, W2), mode='bilinear', align_corners=False)
        x = x.view(B, N_tokens, C, H2, W2)
        x = x.permute(0, 3, 4, 1, 2).contiguous()
        x = x.view(B * H2 * W2, N_tokens, C)
        return x, H2, W2


class SpectralSwinTransformer(Backbone):
    def __init__(self, in_chans=270, spectral_patch_size=1, embed_dim=256, depths=(2, 2, 6, 2),
                 num_heads=(4, 8, 16, 32), spectral_window_size=8, mlp_ratio=4.0, qkv_bias=True,
                 qk_scale=None, drop_rate=0.0, attn_drop_rate=0.0, drop_path_rate=0.2,
                 norm_layer=nn.LayerNorm, patch_norm=True, frozen_stages=-1,
                 use_checkpoint=False, out_features=None):
        super().__init__()
        self.num_layers = len(depths)
        self.embed_dim = embed_dim
        self.patch_norm = patch_norm
        self.frozen_stages = frozen_stages
        self.in_chans = in_chans
        self.spectral_patch_size = spectral_patch_size
        self.spectral_window_size = spectral_window_size
        self.out_features = out_features

        self.stem = nn.Conv2d(in_chans, embed_dim, kernel_size=3, stride=2, padding=1, bias=False)
        self.stem_norm = nn.BatchNorm2d(embed_dim)
        self.stem_act = nn.GELU()

        self.patch_embed = SpectralPatchEmbed(
            in_chans=embed_dim,
            spectral_patch_size=spectral_patch_size,
            embed_dim=embed_dim,
            norm_layer=norm_layer if self.patch_norm else None,
        )

        self.pos_drop = nn.Dropout(p=drop_rate)

        dpr = [x.item() for x in torch.linspace(0, drop_path_rate, sum(depths))]

        self._out_feature_strides = {}
        self._out_feature_channels = {}

        num_features = [int(embed_dim * 2**i) for i in range(self.num_layers)]
        self.num_features = num_features

        self.spatial_downsamples = nn.ModuleList()
        self.layers = nn.ModuleList()

        for i_layer in range(self.num_layers):
            layer_dim = num_features[i_layer]
            self.spatial_downsamples.append(SpatialDownsample(channels=layer_dim))

            layer = BasicSpectralLayer(
                dim=layer_dim,
                depth=depths[i_layer],
                num_heads=num_heads[i_layer],
                window_size=spectral_window_size,
                mlp_ratio=mlp_ratio,
                qkv_bias=qkv_bias,
                qk_scale=qk_scale,
                drop=drop_rate,
                attn_drop=attn_drop_rate,
                drop_path=dpr[sum(depths[:i_layer]):sum(depths[:i_layer + 1])],
                norm_layer=norm_layer,
                downsample=SpectralPatchMerging if (i_layer < self.num_layers - 1) else None,
                use_checkpoint=use_checkpoint,
            )
            self.layers.append(layer)

            stage = f"stage{i_layer + 2}"
            if stage in self.out_features:
                self._out_feature_channels[stage] = layer_dim
                self._out_feature_strides[stage] = 2 ** (i_layer + 2)

        for i_layer in range(self.num_layers):
            stage = f"stage{i_layer + 2}"
            if stage in self.out_features:
                layer = norm_layer(num_features[i_layer])
                layer_name = f"norm{i_layer}"
                self.add_module(layer_name, layer)

        self._freeze_stages()
        self.apply(self._init_weights)

    def _freeze_stages(self):
        if self.frozen_stages >= 0:
            self.stem.eval()
            for param in self.stem.parameters():
                param.requires_grad = False
            self.patch_embed.eval()
            for param in self.patch_embed.parameters():
                param.requires_grad = False
        if self.frozen_stages >= 2:
            self.pos_drop.eval()
            for i in range(0, self.frozen_stages - 1):
                m = self.layers[i]
                m.eval()
                for param in m.parameters():
                    param.requires_grad = False

    def _init_weights(self, m):
        if isinstance(m, nn.Linear):
            trunc_normal_(m.weight, std=0.02)
            if m.bias is not None:
                nn.init.constant_(m.bias, 0)
        elif isinstance(m, nn.LayerNorm):
            nn.init.constant_(m.bias, 0)
            nn.init.constant_(m.weight, 1.0)
        elif isinstance(m, nn.BatchNorm2d):
            nn.init.constant_(m.weight, 1.0)
            nn.init.constant_(m.bias, 0)

    def forward(self, x):
        B = x.shape[0]
        x = self.stem(x)
        x = self.stem_norm(x)
        x = self.stem_act(x)
        x, H, W = self.patch_embed(x)
        x = self.pos_drop(x)
        cur_H, cur_W = H, W
        outs = {}
        for i in range(self.num_layers):
            x, cur_H, cur_W = self.spatial_downsamples[i](x, cur_H, cur_W, B)
            x_out, x_down = self.layers[i](x)
            stage = f"stage{i + 2}"
            if stage in self.out_features:
                norm_layer = getattr(self, f"norm{i}")
                out = x_out.mean(dim=1)
                out = norm_layer(out)
                out = out.view(B, cur_H, cur_W, self.num_features[i]).permute(0, 3, 1, 2).contiguous()
                outs[stage] = out
            x = x_down
        return outs

    def train(self, mode=True):
        super(SpectralSwinTransformer, self).train(mode)
        self._freeze_stages()

    def output_shape(self):
        return {
            name: ShapeSpec(
                channels=self._out_feature_channels[name],
                stride=self._out_feature_strides[name],
            )
            for name in self.out_features
        }


class LastLevelP6(nn.Module):
    def __init__(self, in_channels, out_channels, in_features="p5"):
        super().__init__()
        self.num_levels = 1
        self.in_feature = in_features
        self.p6 = nn.Conv2d(in_channels, out_channels, 3, 2, 1)
        weight_init.c2_xavier_fill(self.p6)

    def forward(self, x):
        return [self.p6(x)]


@BACKBONE_REGISTRY.register()
def build_spectral_swint_backbone(cfg, input_shape):
    out_features = cfg.MODEL.SPECTRAL_SWINT.OUT_FEATURES
    return SpectralSwinTransformer(
        in_chans=cfg.MODEL.SPECTRAL_SWINT.IN_CHANS,
        spectral_patch_size=cfg.MODEL.SPECTRAL_SWINT.PATCH_SIZE,
        embed_dim=cfg.MODEL.SPECTRAL_SWINT.EMBED_DIM,
        depths=cfg.MODEL.SPECTRAL_SWINT.DEPTHS,
        num_heads=cfg.MODEL.SPECTRAL_SWINT.NUM_HEADS,
        spectral_window_size=cfg.MODEL.SPECTRAL_SWINT.WINDOW_SIZE,
        mlp_ratio=cfg.MODEL.SPECTRAL_SWINT.MLP_RATIO,
        qkv_bias=True,
        qk_scale=None,
        drop_rate=0.0,
        attn_drop_rate=0.0,
        drop_path_rate=cfg.MODEL.SPECTRAL_SWINT.DROP_PATH_RATE,
        norm_layer=nn.LayerNorm,
        patch_norm=True,
        frozen_stages=cfg.MODEL.BACKBONE.FREEZE_AT,
        out_features=out_features,
    )


@BACKBONE_REGISTRY.register()
def build_spectral_swint_fpn_backbone(cfg, input_shape: ShapeSpec):
    bottom_up = build_spectral_swint_backbone(cfg, input_shape)
    in_features = cfg.MODEL.FPN.IN_FEATURES
    out_channels = cfg.MODEL.FPN.OUT_CHANNELS
    backbone = FPN(
        bottom_up=bottom_up,
        in_features=in_features,
        out_channels=out_channels,
        norm=cfg.MODEL.FPN.NORM,
        top_block=LastLevelMaxPool(),
        fuse_type=cfg.MODEL.FPN.FUSE_TYPE,
    )
    return backbone


@BACKBONE_REGISTRY.register()
def build_retinanet_spectral_swint_fpn_backbone(cfg, input_shape: ShapeSpec):
    bottom_up = build_spectral_swint_backbone(cfg, input_shape)
    in_features = cfg.MODEL.FPN.IN_FEATURES
    out_channels = cfg.MODEL.FPN.OUT_CHANNELS
    top_levels = cfg.MODEL.FPN.TOP_LEVELS
    in_channels_top = out_channels
    if top_levels == 2:
        top_block = LastLevelP6P7(in_channels_top, out_channels, "p5")
    elif top_levels == 1:
        top_block = LastLevelP6(in_channels_top, out_channels, "p5")
    else:
        top_block = None
    backbone = FPN(
        bottom_up=bottom_up,
        in_features=in_features,
        out_channels=out_channels,
        norm=cfg.MODEL.FPN.NORM,
        top_block=top_block,
        fuse_type=cfg.MODEL.FPN.FUSE_TYPE,
    )
    return backbone