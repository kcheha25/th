    def _log(self, msg):
        self.log.configure(state="normal")
        self.log.insert("end", f"► {msg}\n")
        self.log.see("end")
        self.log.configure(state="disabled")

    def _scroll(self, event, ax, canvas):
        if event.inaxes != ax:
            return
        factor = 0.85 if event.button == "up" else 1.15
        xlim   = ax.get_xlim(); ylim = ax.get_ylim()
        cx, cy = event.xdata, event.ydata
        ax.set_xlim([cx + (x-cx)*factor for x in xlim])
        ax.set_ylim([cy + (y-cy)*factor for y in ylim])
        canvas.draw_idle()

    def _load_plots(self):
        folder = filedialog.askdirectory(title="Dossier des plots HDR smoothed")
        if not folder:
            return
        self.plots = []
        for hdr in sorted(Path(folder).rglob("*.hdr")):
            try:
                cube, meta = load_hdr(hdr)
                self.plots.append({"name": hdr.stem, "cube": cube,
                                   "meta": meta, "path": hdr})
            except Exception as e:
                print(f"Erreur {hdr.name}: {e}")
        self.current_idx = 0
        self.review_info.configure(text=f"{len(self.plots)} plot(s) chargé(s)")
        self._log(f"{len(self.plots)} plots chargés")
        if self.plots:
            self._show_review(0)

    def _show_review(self, idx):
        if idx >= len(self.plots):
            self.review_status.configure(text="Tous les plots reviewés.")
            return
        p        = self.plots[idx]
        mean_map = compute_mean_map(p["cube"])
        self.ax_r.clear()
        self.ax_r.set_facecolor("#0a0a12")
        self.ax_r.imshow(mean_map, cmap="inferno", aspect="auto")
        self.ax_r.set_title(f"{p['name']}  ({idx+1}/{len(self.plots)})",
                             color="#e2e8f0", fontsize=10)
        self.ax_r.axis("off")
        self.canvas_r.draw()
        self.review_status.configure(text=f"Plot {idx+1}/{len(self.plots)}")

    def _keep_plot(self):
        if self.current_idx >= len(self.plots):
            return
        p = self.plots[self.current_idx]
        self.kept_plots.append(p)
        self.kept_var.configure(text=f"Conservés : {len(self.kept_plots)}")
        self._log(f"✅ Conservé : {p['name']}")
        self.current_idx += 1
        self._show_review(self.current_idx)

    def _discard_plot(self):
        if self.current_idx >= len(self.plots):
            return
        p = self.plots[self.current_idx]
        self._log(f"❌ Supprimé : {p['name']}")
        self.current_idx += 1
        self._show_review(self.current_idx)

    def _finish_review(self):
        if not self.kept_plots:
            messagebox.showwarning("Review", "Aucun plot conservé.")
            return
        self.review_done = True
        self.kept_list.delete(0, "end")
        for p in self.kept_plots:
            self.kept_list.insert("end", p["name"])
        self._log(f"Review terminée : {len(self.kept_plots)} plot(s) conservé(s)")
        messagebox.showinfo("Review", f"{len(self.kept_plots)} plot(s) conservé(s).\nPassez à l'onglet Placer extrudes.")

    def _load_extrudes(self):
        folder = filedialog.askdirectory(title="Dossier racine des extrudes")
        if not folder:
            return
        self.extrudes = []
        classes = set()
        for hdr in sorted(Path(folder).rglob("*.hdr")):
            try:
                cube, meta   = load_hdr(hdr)
                class_name   = hdr.parent.name
                valid_mask   = get_valid_mask_fast(cube)
                cube_c, mask_c, _, _ = crop_to_valid(cube, valid_mask)
                polygons     = find_contour_polygons(mask_c)
                if not polygons:
                    continue
                self.extrudes.append({
                    "name"      : hdr.stem,
                    "cube"      : cube_c,
                    "class_name": class_name,
                    "polygons"  : polygons,
                    "H"         : cube_c.shape[1],
                    "W"         : cube_c.shape[2],
                    "path"      : hdr
                })
                classes.add(class_name)
            except Exception as e:
                print(f"Erreur {hdr.name}: {e}")
        self.ext_info.configure(text=f"{len(self.extrudes)} extrude(s)")
        self.class_combo["values"] = [""] + sorted(classes)
        self._log(f"{len(self.extrudes)} extrudes | classes : {sorted(classes)}")

    def _on_kept_select(self, event):
        sel = self.kept_list.curselection()
        if not sel:
            return
        idx = sel[0]
        self.current_kept_idx = idx
        self._show_place_plot(idx)

    def _show_place_plot(self, idx):
        self.annotations   = []
        self.placed_patches= []
        self._clear_polygon()
        p        = self.kept_plots[idx]
        mean_map = compute_mean_map(p["cube"])
        self.ax_p.clear()
        self.ax_p.set_facecolor("#0a0a12")
        self.ax_p.imshow(mean_map, cmap="inferno", aspect="auto")
        self.ax_p.set_title(p["name"], color="#e2e8f0", fontsize=10)
        self.ax_p.axis("off")
        self.canvas_p.draw()

    def _start_polygon(self):
        self.drawing     = True
        self.polygon_pts = []
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
            self.polygon_patch = None
        self.draw_var.set("✏️  Cliquer pour poser les points")
        self.canvas_p.draw_idle()

    def _close_polygon(self):
        if len(self.polygon_pts) < 3:
            messagebox.showwarning("Polygon", "Il faut au moins 3 points.")
            return
        self.drawing = False
        self.draw_var.set("✅ Polygon fermé")
        self._redraw_polygon(closed=True)
        self._log(f"Polygon fermé : {len(self.polygon_pts)} points")

    def _clear_polygon(self):
        self.drawing     = False
        self.polygon_pts = []
        self.draw_var.set("Navigation")
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
            self.polygon_patch = None
        self.canvas_p.draw_idle()

    def _on_press(self, event):
        if not self.drawing or event.inaxes != self.ax_p:
            return
        if event.xdata is None or event.ydata is None:
            return
        self.polygon_pts.append((event.xdata, event.ydata))
        self._redraw_polygon(closed=False)

    def _redraw_polygon(self, closed=False):
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
        if len(self.polygon_pts) < 2:
            self.canvas_p.draw_idle()
            return
        pts   = np.array(self.polygon_pts)
        patch = MplPolygon(pts, closed=closed, linewidth=1.5,
                           edgecolor="#7c83fd",
                           facecolor="#7c83fd" if closed else "none",
                           alpha=0.2 if closed else 1.0, linestyle="--")
        self.ax_p.add_patch(patch)
        self.polygon_patch = patch
        self.canvas_p.draw_idle()

    def _place_extrudes(self):
        if not self.kept_plots:
            messagebox.showwarning("Plots", "Terminez d abord la review.")
            return
        if not self.extrudes:
            messagebox.showwarning("Extrudes", "Chargez d abord les extrudes.")
            return
        if len(self.polygon_pts) < 3:
            messagebox.showwarning("Polygon", "Dessinez et fermez un polygon d abord.")
            return

        try:
            n_place = int(self.n_ext_var.get())
        except ValueError:
            messagebox.showerror("Erreur", "Nombre d extrudes invalide.")
            return

        sel_class = self.class_var.get().strip()
        pool      = self.extrudes if not sel_class else \
                    [e for e in self.extrudes if e["class_name"] == sel_class]
        if not pool:
            messagebox.showwarning("Extrudes", f"Aucun extrude pour la classe '{sel_class}'.")
            return

        idx      = getattr(self, "current_kept_idx", 0)
        p        = self.kept_plots[idx]
        B, H, W  = p["cube"].shape
        rng      = np.random.default_rng()

        zone_pts = [(int(round(x)), int(round(y))) for x, y in self.polygon_pts]
        zone_mask= polygon_mask_2d(H, W, [(y, x) for x, y in zone_pts])

        COLORS = ["#f38ba8","#a6e3a1","#fab387","#89b4fa","#f9e2af","#cba6f7"]

        for k in range(n_place):
            ext        = pool[rng.integers(len(pool))]
            class_name = ext["class_name"]
            color      = COLORS[k % len(COLORS)]

            chosen_poly = ext["polygons"][rng.integers(len(ext["polygons"]))]
            new_pts     = place_polygon_in_zone(zone_mask, chosen_poly, H, W, rng)
            if new_pts is None:
                self._log(f"  Pas de place pour extrude {k+1}")
                continue

            self.annotations.append({
                "label" : class_name,
                "points": new_pts
            })

            arr   = np.array(new_pts)
            patch = MplPolygon(arr, closed=True, linewidth=1.5,
                               edgecolor=color, facecolor=color, alpha=0.3)
            self.ax_p.add_patch(patch)
            self.ax_p.text(arr[:, 0].mean(), arr[:, 1].mean(), class_name,
                           color=color, fontsize=6, ha="center", va="center",
                           bbox=dict(fc="#0f0f17", alpha=0.6, pad=1))
            self.placed_patches.append(patch)
            self._log(f"  Placé {class_name} @ centre ({int(arr[:,0].mean())},{int(arr[:,1].mean())})")

        self.canvas_p.draw()
        self._log(f"{len(self.annotations)} extrude(s) placé(s)")

    def _clear_placements(self):
        for patch in self.placed_patches:
            try:
                patch.remove()
            except:
                pass
        self.placed_patches = []
        self.annotations    = []
        idx = getattr(self, "current_kept_idx", 0)
        self._show_place_plot(idx)
        self._log("Placements effacés")

    def _save(self):
        if not self.annotations:
            messagebox.showwarning("Sauvegarde", "Aucune annotation à sauvegarder.")
            return
        idx      = getattr(self, "current_kept_idx", 0)
        p        = self.kept_plots[idx]
        B, H, W  = p["cube"].shape
        out_dir  = Path(self.out_var.get())
        out_dir.mkdir(parents=True, exist_ok=True)

        ann_full = list(self.annotations)
        ann_full.append({
            "label" : "zone_placement",
            "points": [[x, y] for x, y in self.polygon_pts]
        })

        json_data = make_labelme_json(f"{p['name']}.png", H, W, ann_full)
        json_out  = out_dir / f"{p['name']}_annotations.json"
        with open(json_out, "w") as f:
            json.dump(json_data, f, indent=2)

        fig_out = out_dir / f"{p['name']}_placed.png"
        self.fig_p.savefig(fig_out, dpi=120, facecolor="#0f0f17")

        self._log(f"JSON : {json_out.name}")
        self._log(f"PNG  : {fig_out.name}")
        messagebox.showinfo("Sauvegarde", f"Sauvegardé dans :\n{out_dir}")


