        s.configure("TLabel",          background=bg, foreground=fg)
        s.configure("TButton",         background="#1e1e2e", foreground=fg, padding=6)
        s.configure("TLabelframe",     background=bg, foreground=acc)
        s.configure("TLabelframe.Label", background=bg, foreground=acc, font=("Courier New", 10, "bold"))
        s.configure("Treeview",        background="#1e1e2e", foreground=fg, fieldbackground="#1e1e2e", rowheight=20)
        s.map("Treeview",              background=[("selected", acc)])
        s.configure("TEntry",          fieldbackground="#1e1e2e", foreground=fg)

