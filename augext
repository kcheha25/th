import numpy as np
import cv2
from pathlib import Path
from specarray import SpecArray
from ultralytics import YOLO
import spectral.io.envi as envi

DATA_ROOT = Path("data")
MODEL_PATH = "best.pt"
OUT_DIR = Path("output_plots")
WL1 = 900
WL2 = 1100
YOLO_H = 640

OUT_DIR.mkdir(exist_ok=True)

def find_nearest_idx(target, arr):
    return np.argmin(np.abs(arr - target))

def compute_ratio(cube, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    b1 = cube[:, i1, :]
    b2 = cube[:, i2, :]
    r = b1 / (b2 + 1e-8)
    r = (r - r.min()) / (r.max() - r.min())
    return r

def prepare_yolo_image(ratio, target_h):
    img = (ratio * 255).astype(np.uint8)
    img = cv2.cvtColor(img, cv2.COLOR_GRAY2BGR)
    H, W = ratio.shape
    img = cv2.resize(img, (W, target_h))
    return img

model = YOLO(MODEL_PATH)
plot_id = 0

for cube_dir in DATA_ROOT.iterdir():
    if not cube_dir.is_dir():
        continue

    spec = SpecArray.from_folder(cube_dir)
    cube = np.array(spec.spectral_albedo)
    wavelengths = np.array(spec.wavelengths)
    H, B, W = cube.shape

    ratio = compute_ratio(cube, wavelengths)
    yolo_img = prepare_yolo_image(ratio, YOLO_H)
    results = model.predict(source=yolo_img, imgsz=(YOLO_H, W), conf=0.3, device=0, verbose=False)
    boxes = results[0].boxes
    if boxes is None:
        continue

    scale_y = H / YOLO_H

    for i, box in enumerate(boxes):
        x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
        x1 = int(x1)
        x2 = int(x2)
        y1 = int(y1 * scale_y)
        y2 = int(y2 * scale_y)
        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(W, x2)
        y2 = min(H, y2)

        plot_cube = cube[y1:y2, :, x1:x2]

        out_plot_dir = OUT_DIR / f"{cube_dir.name}_plot_{plot_id}"
        out_plot_dir.mkdir(exist_ok=True)

        hdr_path = out_plot_dir / f"plot_{plot_id}.hdr"
        raw_path = out_plot_dir / f"plot_{plot_id}.raw"

        envi.save_image(
            str(hdr_path),
            plot_cube.transpose(1,0,2),  # ENVI attends (bands, rows, cols)
            interleave='bil',
            dtype=np.float32,
            metadata={'wavelength': list(wavelengths)}
        )
        plot_id += 1


import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path

PLOTS_DIR = Path("output_plots")
WL1 = 900
WL2 = 1100
MAX_PLOTS = 10

def find_nearest_idx(target, arr):
    return np.argmin(np.abs(arr - target))

def compute_ratio(cube, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    band1 = cube[:, i1, :]
    band2 = cube[:, i2, :]
    ratio = band1 / (band2 + 1e-8)
    ratio_norm = (ratio - ratio.min()) / (ratio.max() - ratio.min())
    return ratio_norm

plot_files = list(PLOTS_DIR.glob("*/*.hdr"))[:MAX_PLOTS]

for hdr_file in plot_files:
    img = envi.open(str(hdr_file))
    cube = np.array(img.load())  # shape (bands, rows, cols)
    cube = np.transpose(cube, (1,0,2))  # (rows, bands, cols)
    
    if 'wavelength' in img.metadata:
        wavelengths = np.array([float(w) for w in img.metadata['wavelength']])
    else:
        bands = cube.shape[1]
        wavelengths = np.linspace(400, 1100, bands)
    
    ratio_map = compute_ratio(cube, wavelengths)
    plt.figure(figsize=(6,4))
    plt.imshow(ratio_map, cmap='gray', aspect='auto')
    plt.title(f"Ratio {WL1}nm/{WL2}nm - {hdr_file.stem}")
    plt.axis('off')
    plt.show()


import numpy as np
from pathlib import Path
from specarray import SpecArray
import json
import spectral.io.envi as envi
from skimage.morphology import dilation, disk
import matplotlib.pyplot as plt
import random
import cv2


def load_annotations_labelme(json_path):

    with open(json_path) as f:
        data = json.load(f)

    plots = []
    holes = []
    extrudes = []

    for s in data["shapes"]:

        label = s["label"]
        pts = np.array(s["points"],dtype=np.int32)

        if label == "plot":

            x = pts[:,0]
            y = pts[:,1]

            bbox = [int(x.min()),int(y.min()),int(x.max()),int(y.max())]

            plots.append(bbox)

        elif label == "trou":

            holes.append(pts)

        else:

            extrudes.append(pts)

    return plots,holes,extrudes



def polygon_mask(H,W,polygons,dilate_r=5):

    mask = np.zeros((H,W),dtype=np.uint8)

    for poly in polygons:

        cv2.fillPoly(mask,[poly],1)

    if dilate_r>0:
        mask = dilation(mask,disk(dilate_r))

    return mask.astype(bool)



def fill_mask(cube,remove_mask,holes_mask,window=7):

    B,H,W = cube.shape

    cube_out = cube.copy()

    mask = remove_mask.copy()

    ys,xs = np.where(mask)

    for y,x in zip(ys,xs):

        found=False

        for r in range(1,window):

            y0=max(0,y-r)
            y1=min(H,y+r+1)

            x0=max(0,x-r)
            x1=min(W,x+r+1)

            local_remove = remove_mask[y0:y1,x0:x1]
            local_holes = holes_mask[y0:y1,x0:x1]

            valid = (~local_remove) & (~local_holes)

            if np.any(valid):

                yy,xx = np.where(valid)

                k = random.randint(0,len(yy)-1)

                sy = yy[k] + y0
                sx = xx[k] + x0

                cube_out[:,y,x] = cube[:,sy,sx]

                found=True
                break

        if not found:
            cube_out[:,y,x] = cube[:,y,x]

    return cube_out



def process_all(hsi_root,ann_root,out_root):

    hsi_root = Path(hsi_root)
    ann_root = Path(ann_root)
    out_root = Path(out_root)

    out_root.mkdir(exist_ok=True,parents=True)

    for cube_folder in hsi_root.iterdir():

        if not cube_folder.is_dir():
            continue

        json_path = ann_root / f"{cube_folder.name}.json"

        if not json_path.exists():
            print("json manquant",cube_folder.name)
            continue

        plots,holes,extrudes = load_annotations_labelme(json_path)

        for hdr in cube_folder.glob("*.hdr"):

            spec = SpecArray.from_folder(hdr.parent)

            cube = np.array(spec.spectral_albedo).transpose(1,0,2)

            B,H,W = cube.shape


            holes_mask = polygon_mask(H,W,holes,0) if holes else np.zeros((H,W),bool)

            extrude_mask = polygon_mask(H,W,extrudes,7)

            remove_mask = extrude_mask & (~holes_mask)


            cube_clean = fill_mask(cube,remove_mask,holes_mask)


            i996 = np.argmin(np.abs(spec.wavelengths-996))
            i1197 = np.argmin(np.abs(spec.wavelengths-1197))


            for i,b in enumerate(plots):

                x1,y1,x2,y2 = b

                plot_cube = cube_clean[:,y1:y2,x1:x2]

                ratio = plot_cube[i996] / (plot_cube[i1197] + 1e-8)


                meta = spec.metadata.copy()

                meta["lines"]=plot_cube.shape[1]
                meta["samples"]=plot_cube.shape[2]
                meta["bands"]=plot_cube.shape[0]


                out_hdr = out_root / f"{hdr.stem}_plot{i}.hdr"

                envi.save_image(
                    str(out_hdr),
                    plot_cube,
                    dtype=np.float32,
                    force=True,
                    interleave="bil",
                    metadata=meta
                )


                plt.figure(figsize=(6,6))

                plt.imshow(ratio,cmap="inferno")

                plt.axis("off")

                plt.savefig(out_root / f"{hdr.stem}_plot{i}_ratio.png")

                plt.close()

            print("cube traité",hdr.name)



process_all(
    "ann/hsi_cube",
    "ann",
    "plots_clean"
)