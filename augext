import numpy as np
import cv2
from pathlib import Path
from specarray import SpecArray
from ultralytics import YOLO
import spectral.io.envi as envi

DATA_ROOT = Path("data")
MODEL_PATH = "best.pt"
OUT_DIR = Path("output_plots")
WL1 = 900
WL2 = 1100
YOLO_H = 640

OUT_DIR.mkdir(exist_ok=True)

def find_nearest_idx(target, arr):
    return np.argmin(np.abs(arr - target))

def compute_ratio(cube, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    b1 = cube[:, i1, :]
    b2 = cube[:, i2, :]
    r = b1 / (b2 + 1e-8)
    r = (r - r.min()) / (r.max() - r.min())
    return r

def prepare_yolo_image(ratio, target_h):
    img = (ratio * 255).astype(np.uint8)
    img = cv2.cvtColor(img, cv2.COLOR_GRAY2BGR)
    H, W = ratio.shape
    img = cv2.resize(img, (W, target_h))
    return img

model = YOLO(MODEL_PATH)
plot_id = 0

for cube_dir in DATA_ROOT.iterdir():
    if not cube_dir.is_dir():
        continue

    spec = SpecArray.from_folder(cube_dir)
    cube = np.array(spec.spectral_albedo)
    wavelengths = np.array(spec.wavelengths)
    H, B, W = cube.shape

    ratio = compute_ratio(cube, wavelengths)
    yolo_img = prepare_yolo_image(ratio, YOLO_H)
    results = model.predict(source=yolo_img, imgsz=(YOLO_H, W), conf=0.3, device=0, verbose=False)
    boxes = results[0].boxes
    if boxes is None:
        continue

    scale_y = H / YOLO_H

    for i, box in enumerate(boxes):
        x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
        x1 = int(x1)
        x2 = int(x2)
        y1 = int(y1 * scale_y)
        y2 = int(y2 * scale_y)
        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(W, x2)
        y2 = min(H, y2)

        plot_cube = cube[y1:y2, :, x1:x2]

        out_plot_dir = OUT_DIR / f"{cube_dir.name}_plot_{plot_id}"
        out_plot_dir.mkdir(exist_ok=True)

        hdr_path = out_plot_dir / f"plot_{plot_id}.hdr"
        raw_path = out_plot_dir / f"plot_{plot_id}.raw"

        envi.save_image(
            str(hdr_path),
            plot_cube.transpose(1,0,2),  # ENVI attends (bands, rows, cols)
            interleave='bil',
            dtype=np.float32,
            metadata={'wavelength': list(wavelengths)}
        )
        plot_id += 1


import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path

PLOTS_DIR = Path("output_plots")
WL1 = 900
WL2 = 1100
MAX_PLOTS = 10

def find_nearest_idx(target, arr):
    return np.argmin(np.abs(arr - target))

def compute_ratio(cube, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    band1 = cube[:, i1, :]
    band2 = cube[:, i2, :]
    ratio = band1 / (band2 + 1e-8)
    ratio_norm = (ratio - ratio.min()) / (ratio.max() - ratio.min())
    return ratio_norm

plot_files = list(PLOTS_DIR.glob("*/*.hdr"))[:MAX_PLOTS]

for hdr_file in plot_files:
    img = envi.open(str(hdr_file))
    cube = np.array(img.load())  # shape (bands, rows, cols)
    cube = np.transpose(cube, (1,0,2))  # (rows, bands, cols)
    
    if 'wavelength' in img.metadata:
        wavelengths = np.array([float(w) for w in img.metadata['wavelength']])
    else:
        bands = cube.shape[1]
        wavelengths = np.linspace(400, 1100, bands)
    
    ratio_map = compute_ratio(cube, wavelengths)
    plt.figure(figsize=(6,4))
    plt.imshow(ratio_map, cmap='gray', aspect='auto')
    plt.title(f"Ratio {WL1}nm/{WL2}nm - {hdr_file.stem}")
    plt.axis('off')
    plt.show()


import numpy as np
import cv2
from pathlib import Path
from specarray import SpecArray
import json
import spectral.io.envi as envi
from skimage.morphology import dilation, disk
import matplotlib.pyplot as plt

def load_annotations(json_path):
    with open(json_path, 'r') as f:
        data = json.load(f)
    plots, trous, autres = [], [], []
    for obj in data['objects']:
        if obj['class'] == 'plot':
            plots.append(obj)
        elif obj['class'] == 'trou':
            trous.append(obj)
        else:
            autres.append(obj)
    return plots, trous, autres

def create_mask_from_polygons(cube_shape, polygons, dilate_radius=3):
    _, H, W = cube_shape
    mask = np.zeros((H, W), dtype=np.uint8)
    for poly in polygons:
        pts = np.array(poly, dtype=np.int32)
        cv2.fillPoly(mask, [pts], 1)
    mask = dilation(mask, disk(dilate_radius))
    return mask.astype(bool)

def remove_objects_and_interpolate(cube, polygons_to_remove, keep_mask):
    bands, H, W = cube.shape
    remove_mask = create_mask_from_polygons(cube.shape, polygons_to_remove)
    mask_to_clear = remove_mask & (~keep_mask)
    cube_clean = cube.copy()
    for b in range(bands):
        band = cube[b]
        inpainted = cv2.inpaint((band*255).astype(np.uint8),
                                mask_to_clear.astype(np.uint8), 3, cv2.INPAINT_TELEA)
        cube_clean[b] = inpainted.astype(np.float32)/255
    return cube_clean

def process_plot_cube(cube_path, json_path, output_path, dilate_radius=3):
    spec = SpecArray.from_folder(cube_path.parent)
    cube = np.array(spec.spectral_albedo).transpose(1,0,2)
    plots, trous, autres = load_annotations(json_path)
    trous_mask = create_mask_from_polygons(cube.shape, [t['polygon'] for t in trous], dilate_radius=0)
    polygons_to_remove = [obj['polygon'] for obj in autres]
    cube_clean = remove_objects_and_interpolate(cube, polygons_to_remove, keep_mask=trous_mask)
    meta = spec.metadata.copy()
    meta['lines'] = cube_clean.shape[1]
    meta['samples'] = cube_clean.shape[2]
    meta['bands'] = cube_clean.shape[0]
    output_path.parent.mkdir(parents=True, exist_ok=True)
    envi.save_image(str(output_path), cube_clean, dtype=np.float32, force=True, interleave='bil', metadata=meta)

    plots_mask = np.zeros((cube_clean.shape[1], cube_clean.shape[2]), dtype=np.uint8)
    for plot in plots:
        x1, y1, x2, y2 = plot['bbox']
        plots_mask[y1:y2, x1:x2] = 1

    plt.figure(figsize=(8,8))
    plt.imshow(plots_mask, cmap='jet')
    plt.title(f"Plots cartographie - {cube_path.stem}")
    plt.axis('off')
    plt.tight_layout()
    plt.savefig(output_path.parent / f"{cube_path.stem}_plots_map.png")
    plt.close()
    return plots, cube_clean