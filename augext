import numpy as np
import cv2
from pathlib import Path
from specarray import SpecArray
from ultralytics import YOLO
import spectral.io.envi as envi

DATA_ROOT = Path("data")
MODEL_PATH = "best.pt"
OUT_DIR = Path("output_plots")
WL1 = 900
WL2 = 1100
YOLO_H = 640

OUT_DIR.mkdir(exist_ok=True)

def find_nearest_idx(target, arr):
    return np.argmin(np.abs(arr - target))

def compute_ratio(cube, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    b1 = cube[:, i1, :]
    b2 = cube[:, i2, :]
    r = b1 / (b2 + 1e-8)
    r = (r - r.min()) / (r.max() - r.min())
    return r

def prepare_yolo_image(ratio, target_h):
    img = (ratio * 255).astype(np.uint8)
    img = cv2.cvtColor(img, cv2.COLOR_GRAY2BGR)
    H, W = ratio.shape
    img = cv2.resize(img, (W, target_h))
    return img

model = YOLO(MODEL_PATH)
plot_id = 0

for cube_dir in DATA_ROOT.iterdir():
    if not cube_dir.is_dir():
        continue

    spec = SpecArray.from_folder(cube_dir)
    cube = np.array(spec.spectral_albedo)
    wavelengths = np.array(spec.wavelengths)
    H, B, W = cube.shape

    ratio = compute_ratio(cube, wavelengths)
    yolo_img = prepare_yolo_image(ratio, YOLO_H)
    results = model.predict(source=yolo_img, imgsz=(YOLO_H, W), conf=0.3, device=0, verbose=False)
    boxes = results[0].boxes
    if boxes is None:
        continue

    scale_y = H / YOLO_H

    for i, box in enumerate(boxes):
        x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
        x1 = int(x1)
        x2 = int(x2)
        y1 = int(y1 * scale_y)
        y2 = int(y2 * scale_y)
        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(W, x2)
        y2 = min(H, y2)

        plot_cube = cube[y1:y2, :, x1:x2]

        out_plot_dir = OUT_DIR / f"{cube_dir.name}_plot_{plot_id}"
        out_plot_dir.mkdir(exist_ok=True)

        hdr_path = out_plot_dir / f"plot_{plot_id}.hdr"
        raw_path = out_plot_dir / f"plot_{plot_id}.raw"

        envi.save_image(
            str(hdr_path),
            plot_cube.transpose(1,0,2),  # ENVI attends (bands, rows, cols)
            interleave='bil',
            dtype=np.float32,
            metadata={'wavelength': list(wavelengths)}
        )
        plot_id += 1


import numpy as np
from pathlib import Path
import json
import matplotlib.pyplot as plt
from specarray import SpecArray
import spectral.io.envi as envi
import cv2
import random

def load_labelme(json_path):
    with open(json_path) as f:
        data = json.load(f)

    plots = []
    polygons_to_remove = []

    for shape in data["shapes"]:
        label = shape["label"]
        pts = np.array(shape["points"], dtype=np.int32)

        if label == "plot":
            x1 = int(np.min(pts[:,0]))
            x2 = int(np.max(pts[:,0]))
            y1 = int(np.min(pts[:,1]))
            y2 = int(np.max(pts[:,1]))
            plots.append((x1, y1, x2, y2))
        elif label != "trou":
            polygons_to_remove.append(pts)

    return plots, polygons_to_remove

def build_mask(H, W, polygons):
    mask = np.zeros((H, W), dtype=np.uint8)
    for poly in polygons:
        cv2.fillPoly(mask, [poly], 1)
    return mask.astype(bool)

def fill_mask_iterative(cube, mask_to_fill, window_size=3):
    filled_cube = cube.copy()
    mask = mask_to_fill.copy()

    iteration = 0
    while np.any(filled_cube[:, mask] == 0):
        iteration += 1
        ys, xs = np.where(mask)
        for y, x in zip(ys, xs):
            for b in range(filled_cube.shape[0]):
                if filled_cube[b, y, x] != 0:
                    continue
                y0 = max(0, y-window_size)
                y1 = min(filled_cube.shape[1], y+window_size+1)
                x0 = max(0, x-window_size)
                x1 = min(filled_cube.shape[2], x+window_size+1)

                neighborhood = filled_cube[b, y0:y1, x0:x1]
                neighbor_mask = neighborhood != 0
                if np.any(neighbor_mask):
                    filled_cube[b, y, x] = np.median(neighborhood[neighbor_mask])
    return filled_cube

def process_cube(cube_folder, json_path, out_dir, window_size=3):
    spec = SpecArray.from_folder(cube_folder)
    cube = np.array(spec.spectral_albedo).transpose(1,0,2)  # (B,H,W)
    B, H, W = cube.shape
    wavelengths = np.array(spec.wavelengths)

    plots, polygons = load_labelme(json_path)
    remove_mask = build_mask(H, W, polygons)

    cube[:, remove_mask] = 0
    cube = fill_mask_iterative(cube, remove_mask, window_size=window_size)

    i1 = np.argmin(np.abs(wavelengths - 996))
    i2 = np.argmin(np.abs(wavelengths - 1197))
    ratio = cube[i1] / (cube[i2] + 1e-8)

    for i, (x1, y1, x2, y2) in enumerate(plots):
        plot_cube = cube[:, y1:y2, x1:x2]
        meta = spec.metadata.copy()
        meta["lines"] = plot_cube.shape[1]
        meta["samples"] = plot_cube.shape[2]
        meta["bands"] = plot_cube.shape[0]

        hdr_path = out_dir / f"{cube_folder.name}_plot_{i}.hdr"
        envi.save_image(
            str(hdr_path),
            plot_cube,
            dtype=np.float32,
            interleave="bil",
            force=True,
            metadata=meta
        )

        ratio_plot = ratio[y1:y2, x1:x2]
        plt.figure(figsize=(5,5))
        plt.imshow(ratio_plot, cmap="inferno")
        plt.axis("off")
        plt.title(f"{cube_folder.name} plot {i}")
        plt.savefig(out_dir / f"{cube_folder.name}_plot_{i}_ratio.png")
        plt.close()
        print("plot sauvegardé :", hdr_path.name)

def process_all(hsi_root, ann_root, out_dir, window_size=3):
    hsi_root = Path(hsi_root)
    ann_root = Path(ann_root)
    out_dir = Path(out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    for cube_folder in hsi_root.iterdir():
        if not cube_folder.is_dir():
            continue
        json_path = ann_root / f"{cube_folder.name}.json"
        if not json_path.exists():
            print("json manquant :", cube_folder.name)
            continue
        process_cube(cube_folder, json_path, out_dir, window_size=window_size)

