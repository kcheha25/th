import os
import numpy as np
import matplotlib.pyplot as plt
from spectral import envi
from sklearn.decomposition import IncrementalPCA
from glob import glob

REAL_DIR = "extrudes_cubes_vf"
AUG_DIR = "aug_data"
OUTPUT_DIR = "results"

os.makedirs(OUTPUT_DIR, exist_ok=True)

def load_cube(hdr_path):
    img = envi.open(hdr_path)
    cube = np.array(img.load())
    if cube.shape[-1] != 272:
        for i, dim in enumerate(cube.shape):
            if dim == 272:
                if i == 0:
                    cube = np.transpose(cube, (1, 2, 0))
                elif i == 1:
                    cube = np.transpose(cube, (0, 2, 1))
                break
    return cube

def extract_spectra(cube):
    spectra = cube.reshape(-1, cube.shape[-1])
    mask = np.any(spectra != 0, axis=1)
    return spectra[mask]

BATCH_SIZE = 5000

pca = IncrementalPCA(n_components=2)

def fit_pca_on_real_only(directory):
    print(f"Fitting PCA on {directory}...")
    file_count = 0
    total_spectra = 0
    
    for folder in os.listdir(directory):
        folder_path = os.path.join(directory, folder)
        if not os.path.isdir(folder_path):
            continue
            
        hdr_files = glob(os.path.join(folder_path, "*.hdr"))
        for hdr in hdr_files:
            cube = load_cube(hdr)
            spectra = extract_spectra(cube)
            total_spectra += len(spectra)
            
            for i in range(0, len(spectra), BATCH_SIZE):
                pca.partial_fit(spectra[i:i + BATCH_SIZE])
            
            file_count += 1
            if file_count % 10 == 0:
                print(f"  Processed {file_count} files, {total_spectra:,} spectra")
    
    print(f"Completed: {file_count} files, {total_spectra:,} spectra")
    return total_spectra

n_real_spectra = fit_pca_on_real_only(REAL_DIR)

print(f"\nPCA fitted on {n_real_spectra:,} real spectra")
print(f"Explained variance ratio: {pca.explained_variance_ratio_}")
print(f"Total variance explained: {sum(pca.explained_variance_ratio_):.2%}")

