import os
import numpy as np
import random
import matplotlib.pyplot as plt
from spectral import envi
from sklearn.decomposition import PCA
from sklearn.neighbors import NearestNeighbors
from glob import glob

REAL_DIR = "extrudes_cubes_vf"
AUG_DIR = "aug_data"
OUTPUT_DIR = "results"

os.makedirs(OUTPUT_DIR, exist_ok=True)

def load_cube(hdr_path):
    img = envi.open(hdr_path)
    cube = np.array(img.load())
    if cube.shape[-1] != 272:
        for i, dim in enumerate(cube.shape):
            if dim == 272:
                if i == 0:
                    cube = np.transpose(cube, (1, 2, 0))
                elif i == 1:
                    cube = np.transpose(cube, (0, 2, 1))
                break
    return cube

def extract_non_zero_spectra(cube):
    spectra = cube.reshape(-1, cube.shape[-1])
    mask = np.any(spectra != 0, axis=1)
    return spectra[mask]

def get_class_name(folder_name):
    return folder_name.split("_")[0]

real_class_folders = {}
for folder in os.listdir(REAL_DIR):
    class_name = get_class_name(folder)
    real_class_folders.setdefault(class_name, []).append(os.path.join(REAL_DIR, folder))

for class_name in real_class_folders:

    print(f"\n===== Classe {class_name} =====")

    real_spectra_list = []
    for folder in real_class_folders[class_name]:
        hdr_files = glob(os.path.join(folder, "*.hdr"))
        for hdr in hdr_files:
            cube = load_cube(hdr)
            spectra = extract_non_zero_spectra(cube)
            real_spectra_list.append(spectra)

    real_spectra = np.vstack(real_spectra_list)

    aug_folder = os.path.join(AUG_DIR, class_name)
    if not os.path.exists(aug_folder):
        continue

    aug_spectra_list = []
    hdr_files = glob(os.path.join(aug_folder, "*.hdr"))
    for hdr in hdr_files:
        cube = load_cube(hdr)
        spectra = extract_non_zero_spectra(cube)
        aug_spectra_list.append(spectra)

    if len(aug_spectra_list) == 0:
        continue

    aug_spectra = np.vstack(aug_spectra_list)

    pca = PCA(n_components=2)
    all_data = np.vstack([real_spectra, aug_spectra])
    pca.fit(all_data)

    real_pca = pca.transform(real_spectra)
    aug_pca = pca.transform(aug_spectra)

    plt.figure()
    plt.scatter(aug_pca[:, 0], aug_pca[:, 1], s=1, alpha=0.1, label="Augmented")
    plt.scatter(real_pca[:, 0], real_pca[:, 1], s=5, alpha=1.0, label="Real")
    plt.legend()
    plt.title(f"PCA - Classe {class_name}")
    plt.savefig(os.path.join(OUTPUT_DIR, f"PCA_{class_name}.png"), dpi=300)
    plt.close()

    real_norm = real_spectra / np.linalg.norm(real_spectra, axis=1, keepdims=True)
    aug_norm = aug_spectra / np.linalg.norm(aug_spectra, axis=1, keepdims=True)

    nn = NearestNeighbors(n_neighbors=1, metric="cosine")
    nn.fit(real_norm)

    dist_all, idx_all = nn.kneighbors(aug_norm)

    threshold = 1e-6

    overlap_count = 0

    for i in range(len(aug_spectra)):
        if dist_all[i][0] < threshold:
            overlap_count += 1
            real_idx = idx_all[i][0]
            aug_spec = aug_spectra[i]
            real_spec = real_spectra[real_idx]

            cos_sim = 1 - dist_all[i][0]
            sam = np.arccos(np.clip(cos_sim, -1, 1))

            print(f"Overlap détecté classe {class_name} | SAM: {sam:.8f}")

            plt.figure()
            plt.plot(aug_spec, label="Augmenté")
            plt.plot(real_spec, label="Réel")
            plt.legend()
            plt.title(f"{class_name} overlap SAM: {sam:.8f}")
            plt.savefig(os.path.join(OUTPUT_DIR, f"{class_name}_overlap_{overlap_count}.png"), dpi=300)
            plt.close()

    print(f"Nombre de superpositions détectées: {overlap_count}")

    selected_indices = random.sample(range(len(aug_spectra)), min(3, len(aug_spectra)))

    for i, idx_sample in enumerate(selected_indices):
        dist, idx = nn.kneighbors(aug_norm[idx_sample].reshape(1, -1))
        nearest_real = real_spectra[idx[0][0]]
        cos_sim = 1 - dist[0][0]
        sam = np.arccos(np.clip(cos_sim, -1, 1))

        print(f"\nSpectre {i+1} (classe {class_name})")
        print(f"SAM min: {sam:.6f} radians")

        plt.figure()
        plt.plot(aug_spectra[idx_sample], label="Augmenté")
        plt.plot(nearest_real, label="Réel (plus proche)")
        plt.legend()
        plt.title(f"{class_name} - SAM: {sam:.6f}")
        plt.savefig(os.path.join(OUTPUT_DIR, f"{class_name}_spec_{i+1}_SAM.png"), dpi=300)
        plt.close()


import os
import numpy as np
import random
import torch
import matplotlib.pyplot as plt
from spectral import envi
from glob import glob
from sklearn.neighbors import NearestNeighbors

REAL_DIR = "extrudes_cubes_vf"
GAN_DIR = "wgans_weight"
OUTPUT_DIR = "results_gan_eval"

os.makedirs(OUTPUT_DIR, exist_ok=True)

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

def load_cube(hdr_path):
    img = envi.open(hdr_path)
    cube = np.array(img.load())
    if cube.shape[-1] != 272:
        for i, dim in enumerate(cube.shape):
            if dim == 272:
                if i == 0:
                    cube = np.transpose(cube, (1, 2, 0))
                elif i == 1:
                    cube = np.transpose(cube, (0, 2, 1))
                break
    return cube

def extract_spectra(cube):
    spectra = cube.reshape(-1, cube.shape[-1])
    mask = np.any(spectra != 0, axis=1)
    return spectra[mask]

def get_class_name(folder):
    return folder.split("_")[0]

real_class_folders = {}

for folder in os.listdir(REAL_DIR):
    class_name = get_class_name(folder)
    real_class_folders.setdefault(class_name, []).append(os.path.join(REAL_DIR, folder))

for class_name in real_class_folders:

    print(f"\n===== Classe {class_name} =====")

    real_list = []

    for folder in real_class_folders[class_name]:
        hdrs = glob(os.path.join(folder, "*.hdr"))
        for h in hdrs:
            cube = load_cube(h)
            real_list.append(extract_spectra(cube))

    real_spectra = np.vstack(real_list)

    nn = NearestNeighbors(n_neighbors=1, metric="euclidean")
    nn.fit(real_spectra)

    gan_path = os.path.join(GAN_DIR, class_name, "netG_best.pth")
    netG = torch.load(gan_path, map_location=device)
    netG.eval()

    fake_spectra = []

    with torch.no_grad():
        for _ in range(100):
            noise = torch.randn(1, 64, 1, device=device)
            fake = netG(noise).cpu().squeeze().numpy()
            fake = (fake + 1) / 2
            fake_spectra.append(fake)

    fake_spectra = np.array(fake_spectra)

    selected = random.sample(range(100), 3)

    for i, idx in enumerate(selected):

        gan_spec = fake_spectra[idx].reshape(1, -1)

        dist, nn_idx = nn.kneighbors(gan_spec)
        real_spec = real_spectra[nn_idx[0][0]]

        diff = gan_spec.flatten() - real_spec

        L1 = np.sum(np.abs(diff))
        L2 = np.sqrt(np.sum(diff ** 2))

        diff_mean = np.mean(diff)
        diff_max = np.max(np.abs(diff))
        diff_min = np.min(diff)

        nn_distance = dist[0][0]

        plt.figure()
        plt.plot(real_spec, label="Real")
        plt.plot(gan_spec.flatten(), label="GAN")
        plt.legend()
        plt.title(
            f"{class_name} | NN={nn_distance:.4e} | L1={L1:.4e} | L2={L2:.4e} | "
            f"mean={diff_mean:.2e} | max={diff_max:.2e}"
        )
        plt.savefig(os.path.join(OUTPUT_DIR, f"{class_name}_gan_vs_real_{i}.png"))
        plt.close()

        plt.figure()
        plt.plot(diff)
        plt.title(
            f"{class_name} diff | min={diff_min:.2e} | max={diff_max:.2e} | mean={diff_mean:.2e}"
        )
        plt.savefig(os.path.join(OUTPUT_DIR, f"{class_name}_diff_{i}.png"))
        plt.close()

    print(f"Classe {class_name} OK")



