    for hdr in hdr_files:
        cube = load_cube(hdr)
        spectra = extract_spectra(cube)
        
        for i in range(0, len(spectra), BATCH_SIZE):
            batch = spectra[i:i + BATCH_SIZE]
            transformed = pca.transform(batch)
            
            plt.scatter(transformed[:, 0], transformed[:, 1], 
                       s=2, alpha=0.2, c='red', 
                       label='Augmented' if aug_total == 0 else "",
                       edgecolors='none', zorder=1)
            
            aug_total += len(transformed)
            aug_batch_count += 1
            
            if aug_batch_count % 20 == 0:
                print(f"  Plotted {aug_total:,} augmented points...")
        
        aug_file_count += 1
        if aug_file_count % 10 == 0:
            print(f"  Processed {aug_file_count} augmented files, {aug_total:,} points")

print(f"Finished plotting {aug_total:,} augmented points")

