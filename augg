def forward(self, x, mask=None):
    b = x.shape[0]  # taille réelle du batch sur CE GPU

    x = self.conv3d_features(x)
    x = rearrange(x, 'b c h w y -> b (c h) w y')
    x = self.conv2d_features(x)
    x = rearrange(x, 'b c h w -> b (h w) c')

    # Expand explicitement sur le batch de CE GPU
    wa = self.token_wA.expand(b, -1, -1)          # (b, L, 64)
    wa = rearrange(wa, 'b h w -> b w h')
    A = torch.einsum('bij,bjk->bik', x, wa)
    A = rearrange(A, 'b h w -> b w h')
    A = A.softmax(dim=-1)

    wv = self.token_wV.expand(b, -1, -1)          # (b, 64, cT)
    VV = torch.einsum('bij,bjk->bik', x, wv)
    T = torch.einsum('bij,bjk->bik', A, VV)

    cls_tokens = self.cls_token.expand(b, -1, -1)  # (b, 1, dim)
    x = torch.cat((cls_tokens, T), dim=1)
    x += self.pos_embedding                         # broadcast ok
    x = self.dropout(x)
    x = self.transformer(x, mask)
    x = self.to_cls_token(x[:, 0])
    x = self.nn1(x)
    return x

