class SpectralPatchDataset(Dataset):
    def __init__(self, root_dir, patch_size=5, stride=5, class_mapping_file=None, file_list=None):
        self.root_dir = Path(root_dir)
        self.patch_size = patch_size
        self.stride = stride
        self.samples = []
        self.labels = []

        # mapping classes
        self.class_mapping = {}
        if class_mapping_file is not None:
            with open(class_mapping_file, 'r') as f:
                self.class_mapping = json.load(f)

        if file_list is not None:
            hdr_files = [f for f in sorted(self.root_dir.rglob("*.hdr")) if f.name in file_list]
        else:
            hdr_files = sorted(self.root_dir.rglob("*.hdr"))

        original_classes = sorted(list({f.stem.split("_")[0] for f in hdr_files}))
        self.original_to_mapped = {}
        if self.class_mapping:
            for old_class in original_classes:
                for new_class, old_list in self.class_mapping.items():
                    if old_class in old_list:
                        self.original_to_mapped[old_class] = new_class
                        break
        else:
            for old_class in original_classes:
                self.original_to_mapped[old_class] = old_class

        self.mapped_class_names = sorted(list(set(self.original_to_mapped.values())))
        self.class_map = {name: idx for idx, name in enumerate(self.mapped_class_names)}

        # extract patches
        for hdr_file in hdr_files:
            prefix = hdr_file.stem.split("_")[0]
            if prefix not in self.original_to_mapped:
                continue
            mapped_class = self.original_to_mapped[prefix]
            class_id = self.class_map[mapped_class]

            img = envi.open(str(hdr_file))
            cube = np.array(img.load(), dtype=np.float32)  # shape: H×W×B
            H, W, B = cube.shape

            for i in range(0, H - patch_size*2, stride):
                for j in range(0, W - patch_size*2, stride):
                    patch = cube[i:i+patch_size*2+1, j:j+patch_size*2+1, :]
                    self.samples.append(patch)
                    self.labels.append(class_id)

        self.num_classes = len(self.mapped_class_names)

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        x = self.samples[idx]  # shape (H, W, B)
        y = self.labels[idx]
        x = torch.from_numpy(x).float().permute(2,0,1)  # to (B,H,W) for conv3D
        return x.unsqueeze(0), torch.LongTensor([y])[0]  # add channel dim -> (1,B,H,W)

