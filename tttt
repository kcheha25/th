    # ── LOG ───────────────────────────────────────────────────────────────
    def _log(self, msg):
        self.log.configure(state="normal")
        self.log.insert("end", f"► {msg}\n")
        self.log.see("end")
        self.log.configure(state="disabled")

    # ── ZOOM ──────────────────────────────────────────────────────────────
    def _on_scroll(self, event):
        if event.inaxes not in self.axes:
            return
        ax     = event.inaxes
        factor = 0.85 if event.button == "up" else 1.15
        xlim   = ax.get_xlim(); ylim = ax.get_ylim()
        cx, cy = event.xdata, event.ydata
        ax.set_xlim([cx + (x - cx) * factor for x in xlim])
        ax.set_ylim([cy + (y - cy) * factor for y in ylim])
        self.canvas.draw_idle()

    # ── LOAD PLOTS ────────────────────────────────────────────────────────
    def _load_plots(self):
        folder = filedialog.askdirectory(title="Dossier des plots HDR")
        if not folder:
            return
        self.plots = []
        self.plot_list.delete(0, "end")
        for hdr in rglob_hdr(folder):
            try:
                cube, meta = load_hdr(hdr)
                B, H, W    = cube.shape
                # wavelengths depuis metadata
                wl = None
                if "wavelength" in meta:
                    wl = np.array([float(x) for x in meta["wavelength"]])
                else:
                    wl = np.arange(B, dtype=np.float32)
                ratio = compute_ratio(cube, wl)
                self.plots.append({
                    "name"       : hdr.stem,
                    "cube"       : cube,
                    "meta"       : meta,
                    "wavelengths": wl,
                    "ratio"      : ratio,
                    "hdr_path"   : hdr
                })
                self.plot_list.insert("end", hdr.stem)
            except Exception as e:
                self._log(f"Erreur {hdr.name}: {e}")

        self._log(f"{len(self.plots)} plot(s) chargé(s)")
        if self.plots:
            self._show_plot(0)

    def _on_plot_select(self, event):
        sel = self.plot_list.curselection()
        if sel:
            self._show_plot(sel[0])

    def _show_plot(self, idx):
        self.current_plot = idx
        self._clear_polygon()
        self.result_cube  = None
        self.placed_rects = []
        self.annotations  = []
        p = self.plots[idx]
        self.axes[0].clear()
        self.axes[1].clear()
        for ax in self.axes:
            ax.set_facecolor("#0a0a12"); ax.axis("off")
        self.axes[0].imshow(p["ratio"], cmap="RdYlGn", aspect="auto")
        self.axes[0].set_title(f"{p['name']} — ratio {WL1}/{WL2}nm",
                               color="#e2e8f0", fontsize=9)
        self.axes[1].imshow(p["ratio"], cmap="RdYlGn", aspect="auto")
        self.axes[1].set_title("Après placement", color="#e2e8f0", fontsize=9)
        self.canvas.draw()
        self._log(f"Plot : {p['name']}  shape={p['cube'].shape}")

    def _recalc_ratio(self):
        global WL1, WL2
        try:
            WL1 = float(self.wl1_var.get())
            WL2 = float(self.wl2_var.get())
        except ValueError:
            messagebox.showerror("Erreur", "Valeurs de longueur d'onde invalides.")
            return
        if self.plots:
            p = self.plots[self.current_plot]
            p["ratio"] = compute_ratio(p["cube"], p["wavelengths"])
            self._show_plot(self.current_plot)
        self._log(f"Ratio recalculé : {WL1}nm / {WL2}nm")

    # ── LOAD EXTRUDES ─────────────────────────────────────────────────────
    def _load_extrudes(self):
        folder = filedialog.askdirectory(title="Dossier des extrudes HDR")
        if not folder:
            return
        self.extrudes = []
        classes = set()
        for hdr in rglob_hdr(folder):
            try:
                cube, meta = load_hdr(hdr)
                # classe = nom du dossier parent
                class_name = hdr.parent.name
                self.extrudes.append({
                    "name"      : hdr.stem,
                    "cube"      : cube,
                    "class_name": class_name,
                    "hdr_path"  : hdr
                })
                classes.add(class_name)
            except Exception as e:
                self._log(f"Erreur {hdr.name}: {e}")

        self.extrude_info.configure(text=f"{len(self.extrudes)} extrude(s) chargé(s)")
        self.class_combo["values"] = ["Toutes"] + sorted(classes)
        self.class_combo.set("Toutes")
        self._log(f"{len(self.extrudes)} extrude(s) | classes : {sorted(classes)}")

    # ── POLYGON ───────────────────────────────────────────────────────────
    def _start_polygon(self):
        self._drawing_polygon = True
        self.polygon_pts      = []
        self.polygon_done     = False
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
            self.polygon_patch = None
        self.draw_var.set("✏️  Dessin polygon actif")
        self.canvas.draw_idle()

    def _close_polygon(self):
        if len(self.polygon_pts) < 3:
            messagebox.showwarning("Polygon", "Il faut au moins 3 points.")
            return
        self._drawing_polygon = False
        self.polygon_done     = True
        self.draw_var.set("✅ Polygon fermé")
        self._redraw_polygon()
        self._log(f"Polygon fermé : {len(self.polygon_pts)} points")

    def _clear_polygon(self):
        self._drawing_polygon = False
        self.polygon_pts      = []
        self.polygon_done     = False
        self.draw_var.set("Navigation")
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
            self.polygon_patch = None
        self.canvas.draw_idle()

    def _on_press(self, event):
        if not self._drawing_polygon:
            return
        if event.inaxes not in self.axes:
            return
        if event.xdata is None or event.ydata is None:
            return
        self.polygon_pts.append((event.xdata, event.ydata))
        self._redraw_polygon()

    def _redraw_polygon(self):
        if self.polygon_patch:
            try:
                self.polygon_patch.remove()
            except:
                pass
        if len(self.polygon_pts) < 2:
            self.canvas.draw_idle()
            return
        pts   = np.array(self.polygon_pts)
        closed = self.polygon_done
        patch  = MplPolygon(pts, closed=closed,
                            linewidth=1.5, edgecolor="#7c83fd",
                            facecolor="#7c83fd" if closed else "none",
                            alpha=0.25 if closed else 1.0, linestyle="--")
        self.axes[0].add_patch(patch)
        self.polygon_patch = patch
        self.canvas.draw_idle()

    # ── PLACE EXTRUDES ────────────────────────────────────────────────────
    def _place_extrudes(self):
        if not self.plots:
            messagebox.showwarning("Plots", "Chargez d'abord des plots.")
            return
        if not self.extrudes:
            messagebox.showwarning("Extrudes", "Chargez d'abord des extrudes.")
            return
        if not self.polygon_done or len(self.polygon_pts) < 3:
            messagebox.showwarning("Polygon", "Dessinez et fermez un polygon d'abord.")
            return

        try:
            n_place = int(self.n_place_var.get())
        except ValueError:
            messagebox.showerror("Erreur", "Nombre d'extrudes invalide.")
            return

        p          = self.plots[self.current_plot]
        B, H, W    = p["cube"].shape
        result     = p["cube"].copy()
        rng        = np.random.default_rng()
        annotations= []

        # polygon en coordonnées pixel (x=col, y=row)
        poly_pts_px = [(int(round(x)), int(round(y))) for x, y in self.polygon_pts]
        mask        = polygon_mask(H, W, [(y, x) for x, y in poly_pts_px])
        # mask est (H,W) avec row=y, col=x

        # filtrer les extrudes par classe
        selected_class = self.class_var.get()
        pool = self.extrudes if selected_class in ("Toutes", "") else \
               [e for e in self.extrudes if e["class_name"] == selected_class]

        if not pool:
            messagebox.showwarning("Extrudes", f"Aucun extrude pour la classe '{selected_class}'.")
            return

        placed_rects = []
        for _ in range(n_place):
            ext        = pool[rng.integers(len(pool))]
            ext_cube   = ext["cube"]               # (B, He, We)
            class_name = ext["class_name"]

            # adapter B si nécessaire
            Be, He, We = ext_cube.shape
            if Be != B:
                self._log(f"  Attention : bandes extrude ({Be}) ≠ plot ({B}), ignoré")
                continue

            result, rect = place_extrude_random(result, ext_cube, mask, rng=rng)
            if rect is None:
                self._log("  Pas de place trouvée pour un extrude")
                continue

            r0, c0, r1, c1 = rect
            placed_rects.append((r0, c0, r1, c1, class_name))

            # annotation labelme : polygon rectangulaire
            # points en [x, y] = [col, row]
            pts_ann = [
                [c0, r0], [c1, r0], [c1, r1], [c0, r1]
            ]
            annotations.append({
                "label" : class_name,
                "points": pts_ann
            })
            self._log(f"  Placé {class_name} @ ({r0},{c0})-({r1},{c1})")

        self.result_cube  = result
        self.placed_rects = placed_rects
        self.annotations  = annotations

        # calcul du ratio du résultat
        wl    = p["wavelengths"]
        ratio = compute_ratio(result, wl)

        # redessiner le panneau droit
        self.axes[1].clear()
        self.axes[1].set_facecolor("#0a0a12")
        self.axes[1].imshow(ratio, cmap="RdYlGn", aspect="auto")
        self.axes[1].set_title("Après placement", color="#e2e8f0", fontsize=9)

        # afficher les rectangles
        from matplotlib.patches import Rectangle
        for r0, c0, r1, c1, cname in placed_rects:
            rect_patch = Rectangle((c0, r0), c1-c0, r1-r0,
                                   linewidth=1.5, edgecolor="#f9a825",
                                   facecolor="#f9a825", alpha=0.25)
            self.axes[1].add_patch(rect_patch)
            self.axes[1].text(c0+1, r0+1, cname, color="#f9a825",
                              fontsize=6, va="top",
                              bbox=dict(fc="#0f0f17", alpha=0.6, pad=1))

        # afficher aussi le polygon sur les deux panneaux
        from matplotlib.patches import Polygon as MplPoly
        for ax in self.axes:
            ax.add_patch(MplPoly(np.array(self.polygon_pts), closed=True,
                                 linewidth=1.2, edgecolor="#7c83fd",
                                 facecolor="none", linestyle="--"))

        self.canvas.draw()
        self._log(f"{len(placed_rects)} extrude(s) placé(s) sur '{p['name']}'")

    # ── SAVE ──────────────────────────────────────────────────────────────
    def _pick_outdir(self):
        d = filedialog.askdirectory()
        if d:
            self.out_var.set(d)

    def _save(self):
        if self.result_cube is None:
            messagebox.showwarning("Sauvegarde", "Placez d'abord des extrudes.")
            return

        out_dir = Path(self.out_var.get())
        out_dir.mkdir(parents=True, exist_ok=True)

        p        = self.plots[self.current_plot]
        B, H, W  = self.result_cube.shape
        stem     = p["name"]

        # sauvegarde HDR
        meta = p["meta"].copy()
        meta["lines"]   = H
        meta["samples"] = W
        meta["bands"]   = B
        hdr_out = out_dir / f"{stem}_placed.hdr"
        envi.save_image(str(hdr_out), self.result_cube, dtype=np.float32,
                        interleave="bil", force=True, metadata=meta)
        self._log(f"HDR sauvegardé : {hdr_out.name}")

        # sauvegarde JSON labelme
        # ajouter le polygon dessiné comme annotation "zone_placement"
        ann_full = list(self.annotations)
        ann_full.append({
            "label" : "zone_placement",
            "points": [[x, y] for x, y in self.polygon_pts]
        })
        json_data = make_labelme_json(f"{stem}_placed.png", H, W, ann_full)
        json_out  = out_dir / f"{stem}_placed.json"
        with open(json_out, "w") as f:
            json.dump(json_data, f, indent=2)
        self._log(f"JSON sauvegardé : {json_out.name}")

        # sauvegarde cartographie ratio PNG
        wl    = p["wavelengths"]
        ratio = compute_ratio(self.result_cube, wl)
        fig, axes = plt.subplots(1, 2, figsize=(12, 5), facecolor="#0f0f17")
        for ax in axes:
            ax.set_facecolor("#0a0a12"); ax.axis("off")
        axes[0].imshow(p["ratio"], cmap="RdYlGn", aspect="auto")
        axes[0].set_title("Original", color="#e2e8f0")
        axes[1].imshow(ratio, cmap="RdYlGn", aspect="auto")
        axes[1].set_title("Après placement", color="#e2e8f0")
        from matplotlib.patches import Rectangle, Polygon as MplPoly
        for r0, c0, r1, c1, cname in self.placed_rects:
            rp = Rectangle((c0, r0), c1-c0, r1-r0,
                           linewidth=1.5, edgecolor="#f9a825",
                           facecolor="#f9a825", alpha=0.3)
            axes[1].add_patch(rp)
            axes[1].text(c0+1, r0+1, cname, color="#f9a825", fontsize=6,
                         va="top", bbox=dict(fc="#0f0f17", alpha=0.6, pad=1))
        axes[1].add_patch(MplPoly(np.array(self.polygon_pts), closed=True,
                                  linewidth=1.2, edgecolor="#7c83fd",
                                  facecolor="none", linestyle="--"))
        fig.suptitle(stem, color="#e2e8f0", fontsize=11)
        plt.tight_layout()
        png_out = out_dir / f"{stem}_placed_ratio.png"
        plt.savefig(png_out, dpi=120, facecolor="#0f0f17")
        plt.close()
        self._log(f"PNG sauvegardé : {png_out.name}")

        messagebox.showinfo("Sauvegarde",
                            f"Fichiers sauvegardés dans :\n{out_dir}")


