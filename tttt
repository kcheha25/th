# UTILS
# ─────────────────────────────────────────────
WL1 = 996
WL2 = 1197

def find_nearest_idx(target, arr):
    return int(np.argmin(np.abs(arr - target)))

def compute_ratio(cube_BHW, wavelengths):
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    r  = cube_BHW[i1] / (cube_BHW[i2] + 1e-8)
    rmin, rmax = r.min(), r.max()
    if rmax > rmin:
        r = (r - rmin) / (rmax - rmin)
    return r

def load_hdr(hdr_path):
    img  = envi_io.open(str(hdr_path))
    cube = np.array(img.load(), dtype=np.float32)  # (B, H, W)
    meta = img.metadata.copy()
    return cube, meta

def rglob_hdr(root):
    return sorted(Path(root).rglob("*.hdr"))

def polygon_mask(H, W, pts):
    mask = np.zeros((H, W), dtype=np.uint8)
    cv2.fillPoly(mask, [np.array(pts, dtype=np.int32)], 1)
    return mask.astype(bool)

def place_extrude_random(plot_cube, extrude_cube, mask, rng=None):
    """
    Place extrude_cube (B, He, We) dans plot_cube (B, H, W)
    à une position aléatoire dans le polygon mask.
    Retourne le plot modifié et la position (r0, c0).
    """
    if rng is None:
        rng = np.random.default_rng()

    B,  H,  W  = plot_cube.shape
    Be, He, We = extrude_cube.shape
    result     = plot_cube.copy()

    # pixels valides dans le masque où l extrude peut rentrer entièrement
    valid = []
    for r in range(H - He + 1):
        for c in range(W - We + 1):
            sub_mask = mask[r:r+He, c:c+We]
            if sub_mask.all():
                valid.append((r, c))

    if not valid:
        # fallback : n importe quelle position dans le masque
        rows, cols = np.where(mask)
        if len(rows) == 0:
            return result, None
        idx = rng.integers(len(rows))
        r0  = max(0, min(rows[idx], H - He))
        c0  = max(0, min(cols[idx], W - We))
    else:
        r0, c0 = valid[rng.integers(len(valid))]

    r1 = min(r0 + He, H)
    c1 = min(c0 + We, W)
    he = r1 - r0
    we = c1 - c0
    result[:, r0:r1, c0:c1] = extrude_cube[:, :he, :we]
    return result, (r0, c0, r1, c1)

def make_labelme_json(image_name, H, W, annotations):
    """
    annotations : liste de dict {label, points (liste de [x,y])}
    """
    shapes = []
    for ann in annotations:
        shapes.append({
            "label"     : ann["label"],
            "points"    : ann["points"],
            "group_id"  : None,
            "shape_type": "polygon",
            "flags"     : {}
        })
    return {
        "version"  : "5.0.1",
        "flags"    : {},
        "shapes"   : shapes,
        "imagePath": image_name,
        "imageData": None,
        "imageHeight": H,
        "imageWidth" : W
    }

