def compute_velocity(x):
    vel = np.zeros_like(x)
    vel[:, 1:] = x[:, 1:] - x[:, :-1]
    return vel

def prepare_graph_stream(x):
    vel = compute_velocity(x)
    combined = np.concatenate([x, vel], axis=-1)
    combined = combined.transpose(0, 3, 1, 2)
    return combined.astype('float32')

