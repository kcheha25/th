# Construction du graphe multi-subset
# ----------------------------------------------------------------------
EDGES = [(0, 1), (1, 2), (2, 3), (3, 4),
         (0, 5), (5, 6), (6, 7), (7, 8),
         (0, 9), (9, 10), (10, 11), (11, 12),
         (0, 13), (13, 14), (14, 15), (15, 16),
         (0, 17), (17, 18), (18, 19), (19, 20),
         (5, 9), (9, 13), (13, 17)]

def build_multi_subset_adjacency(num_nodes=21):
    """
    Construit la matrice d'adjacence 3-subset attendue par unit_gcn.
    Retourne un np.array de forme (3, V, V).
    Subset 0 : self-connections.
    Subset 1 : centripète (voisin plus proche du poignet).
    Subset 2 : centrifuge  (voisin plus éloigné du poignet).
    """
    # Distance au poignet (articulation 0)
    dist = np.zeros(num_nodes)
    visited = np.zeros(num_nodes, dtype=bool)
    queue = [(0, 0)]
    visited[0] = True
    while queue:
        u, d = queue.pop(0)
        dist[u] = d
        for v in range(num_nodes):
            if ((u, v) in EDGES or (v, u) in EDGES) and not visited[v]:
                visited[v] = True
                queue.append((v, d+1))

    A = np.zeros((3, num_nodes, num_nodes), dtype=np.float32)
    # self-connections
    for i in range(num_nodes):
        A[0, i, i] = 1.0
    # edges
    for i, j in EDGES:
        if dist[j] < dist[i]:
            A[1, i, j] = 1.0
            A[1, j, i] = 1.0
        elif dist[j] > dist[i]:
            A[2, i, j] = 1.0
            A[2, j, i] = 1.0
        else:
            A[1, i, j] = 1.0
            A[1, j, i] = 1.0
    # Normalisation par ligne
    for k in range(3):
        D = np.sum(A[k], axis=1)
        D[D == 0] = 1
        D_inv = np.diag(1.0 / D)
        A[k] = D_inv @ A[k]
    return A

