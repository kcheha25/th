    # ── Cube loading ──────────────────────────────────────────────────────
    def _load_cubes(self):
        folder = filedialog.askdirectory(title="Sélectionner le dossier racine des cubes")
        if not folder:
            return
        root = Path(folder)
        loaded = 0
        errors = []
        for sub in sorted(root.iterdir()):
            if not sub.is_dir():
                continue
            try:
                spec       = SpecArray.from_folder(str(sub))
                cube       = np.array(spec.spectral_albedo)   # (H, B, W)
                wavelengths= np.array(spec.wavelengths)
                ratio      = compute_ratio(cube, wavelengths)
                self.cubes.append({
                    "name"       : sub.name,
                    "cube"       : cube,
                    "wavelengths": wavelengths,
                    "ratio"      : ratio,
                    "path"       : str(sub)
                })
                self.cube_list.insert("end", sub.name)
                loaded += 1
            except Exception as e:
                errors.append(f"{sub.name}: {e}")

        if errors:
            messagebox.showwarning("Erreurs de chargement",
                                   "\n".join(errors[:10]))
        if loaded:
            self.current_idx = 0
            self._show_cube(0)
            messagebox.showinfo("Cubes chargés", f"{loaded} cube(s) chargé(s).")

    def _on_cube_select(self, event):
        sel = self.cube_list.curselection()
        if sel:
            self._show_cube(sel[0])

    def _show_cube(self, idx):
        if idx >= len(self.cubes):
            return
        self.current_idx = idx
        c = self.cubes[idx]
        self.ax.clear()
        self.ax.set_facecolor("#181825")
        self.ax.imshow(c["ratio"], cmap="RdYlGn", aspect="auto",
                       vmin=0, vmax=1)
        self.ax.set_title(
            f"{c['name']}  —  Ratio {WL1}nm / {WL2}nm",
            color="#cdd6f4", fontsize=11
        )
        self.ax.tick_params(colors="#585b70")
        for spine in self.ax.spines.values():
            spine.set_edgecolor("#585b70")
        # Redraw existing ROIs for this cube
        for roi in self.rois:
            if roi["cube_idx"] == idx:
                self._draw_roi_patch(roi)
        self.canvas.draw()

    # ── ROI drawing ───────────────────────────────────────────────────────
    COLORS = list(mcolors.TABLEAU_COLORS.values())

    def _toggle_draw_mode(self):
        self._drawing = not self._drawing
        if self._drawing:
            self.draw_mode_var.set("Mode: ✏️  Dessin ROI")
            self.toolbar.mode = ""          # disable pan/zoom while drawing
        else:
            self.draw_mode_var.set("Mode: Navigation")

    def _on_press(self, event):
        if not self._drawing or event.inaxes != self.ax:
            return
        self._rect_start = (event.xdata, event.ydata)

    def _on_motion(self, event):
        if not self._drawing or not self._rect_start or event.inaxes != self.ax:
            return
        x0, y0 = self._rect_start
        x1, y1 = event.xdata, event.ydata
        if self._temp_rect:
            self._temp_rect.remove()
        self._temp_rect = Rectangle(
            (min(x0,x1), min(y0,y1)),
            abs(x1-x0), abs(y1-y0),
            linewidth=1.5, edgecolor="#f38ba8",
            facecolor="none", linestyle="--"
        )
        self.ax.add_patch(self._temp_rect)
        self.canvas.draw_idle()

    def _on_release(self, event):
        if not self._drawing or not self._rect_start or event.inaxes != self.ax:
            self._rect_start = None
            return
        if self._temp_rect:
            self._temp_rect.remove()
            self._temp_rect = None

        x0, y0 = self._rect_start
        x1, y1 = event.xdata, event.ydata
        self._rect_start = None

        if abs(x1-x0) < 2 or abs(y1-y0) < 2:
            self.canvas.draw_idle()
            return

        # Convert display coords (x=col, y=row) to array indices
        c_idx = self.current_idx
        c = self.cubes[c_idx]
        H, _, W = c["cube"].shape

        col0 = max(0, int(round(min(x0, x1))))
        col1 = min(W, int(round(max(x0, x1))))
        row0 = max(0, int(round(min(y0, y1))))
        row1 = min(H, int(round(max(y0, y1))))

        cname = self.pending_class_name.get().strip() or f"class_{len(self.rois)}"
        color = self.COLORS[len(self.rois) % len(self.COLORS)]

        roi = {
            "cube_idx"  : c_idx,
            "rect"      : (row0, col0, row1, col1),
            "label"     : self._label_for_class(cname),
            "class_name": cname,
            "color"     : color
        }
        self.rois.append(roi)
        self._draw_roi_patch(roi)
        self._add_roi_tree_row(roi)
        self.canvas.draw()

    def _label_for_class(self, name):
        existing = {r["class_name"]: r["label"] for r in self.rois}
        if name in existing:
            return existing[name]
        return max((r["label"] for r in self.rois), default=-1) + 1

    def _draw_roi_patch(self, roi):
        r0, c0, r1, c1 = roi["rect"]
        patch = Rectangle(
            (c0, r0), c1-c0, r1-r0,
            linewidth=2, edgecolor=roi["color"],
            facecolor=roi["color"], alpha=0.15, label=roi["class_name"]
        )
        self.ax.add_patch(patch)
        self.ax.text(
            c0+2, r0+2, roi["class_name"],
            color=roi["color"], fontsize=7,
            va="top", ha="left",
            bbox=dict(boxstyle="round,pad=0.2", fc="#1e1e2e", alpha=0.7)
        )
        self.roi_patches.append(patch)

    def _add_roi_tree_row(self, roi):
        r0, c0, r1, c1 = roi["rect"]
        cname = self.cubes[roi["cube_idx"]]["name"]
        self.roi_tree.insert("", "end",
                             values=(cname, roi["class_name"],
                                     f"({r0},{c0})-({r1},{c1})"))

    def _delete_last_roi(self):
        if not self.rois:
            return
        self.rois.pop()
        rows = self.roi_tree.get_children()
        if rows:
            self.roi_tree.delete(rows[-1])
        self._show_cube(self.current_idx)

    def _clear_rois(self):
        self.rois.clear()
        self.roi_patches.clear()
        for row in self.roi_tree.get_children():
            self.roi_tree.delete(row)
        self._show_cube(self.current_idx)

    # ── Training ──────────────────────────────────────────────────────────
    def _pick_outdir(self):
        d = filedialog.askdirectory()
        if d:
            self.out_dir_var.set(d)

    def _update_cls_info(self):
        if not self.rois:
            text = "Aucun ROI défini."
        else:
            counts = defaultdict(int)
            for roi in self.rois:
                counts[roi["class_name"]] += 1
            lines = ["ROI définis :"]
            for cname, n in counts.items():
                lines.append(f"  • {cname} : {n} rectangle(s)")
            text = "\n".join(lines)
        self.cls_info.configure(state="normal")
        self.cls_info.delete("1.0","end")
        self.cls_info.insert("end", text)
        self.cls_info.configure(state="disabled")

    def _log(self, msg):
        self.log_text.configure(state="normal")
        self.log_text.insert("end", msg + "\n")
        self.log_text.see("end")
        self.log_text.configure(state="disabled")

    def _poll_log(self):
        try:
            while True:
                msg = self.log_queue.get_nowait()
                self._log(msg)
        except queue.Empty:
            pass
        self.after(200, self._poll_log)

    def _start_training(self):
        if not self.rois:
            messagebox.showwarning("Pas de ROI", "Dessinez d'abord des rectangles ROI.")
            return

        # Parse hyper-params
        try:
            ep  = int(self.hp_vars["Epochs"].get())
            bs  = int(self.hp_vars["Batch size"].get())
            nz  = int(self.hp_vars["nz"].get())
            lr_ = float(self.hp_vars["lr"].get())
            nc  = int(self.hp_vars["n_critic"].get())
            lam = float(self.hp_vars["lambda_gp"].get())
        except ValueError:
            messagebox.showerror("Paramètre invalide",
                                 "Vérifiez les valeurs des hyper-paramètres.")
            return

        # Patch globals used inside train_single_class
        global EPOCH_NUM, BATCH_SIZE, NZ, LR, N_CRITIC, P_COEFF
        EPOCH_NUM, BATCH_SIZE, NZ, LR, N_CRITIC, P_COEFF = ep, bs, nz, lr_, nc, lam

        # Build ROI dataset
        roi_dicts = []
        for roi in self.rois:
            roi_dicts.append({
                "cube"      : self.cubes[roi["cube_idx"]]["cube"],
                "rect"      : roi["rect"],
                "label"     : roi["label"],
                "class_name": roi["class_name"]
            })

        dataset = ROISpectralDataset(roi_dicts)
        if len(dataset) == 0:
            messagebox.showerror("Dataset vide",
                                 "Aucun spectre valide extrait des ROI.")
            return

        n_bands = dataset.n_bands
        loaders = create_class_dataloaders(dataset, batch_size=bs)
        out_dir = self.out_dir_var.get()

        self.stop_event.clear()
        self._log(f"=== Démarrage de l'entraînement | {len(loaders)} classe(s) | "
                  f"{len(dataset)} spectres | {n_bands} bandes | device={DEVICE} ===")

        for label, loader in loaders.items():
            cname = dataset.class_names.get(label, f"class_{label}")
            t = threading.Thread(
                target=train_single_class,
                args=(loader, n_bands, cname, out_dir,
                      self.log_queue, self.stop_event),
                daemon=True
            )
            t.start()
            self.train_threads.append(t)

    def _stop_training(self):
        self.stop_event.set()
        self._log("⏹  Signal d'arrêt envoyé. L'entraînement s'arrêtera à la fin de l'epoch en cours.")


