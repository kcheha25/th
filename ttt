# ─────────────────────────────────────────────
# UTILITIES
# ─────────────────────────────────────────────
def find_nearest_idx(target, arr):
    return int(np.argmin(np.abs(arr - target)))

def compute_ratio(cube_HBW, wavelengths):
    """cube shape: (H, B, W)"""
    i1 = find_nearest_idx(WL1, wavelengths)
    i2 = find_nearest_idx(WL2, wavelengths)
    b1 = cube_HBW[:, i1, :]
    b2 = cube_HBW[:, i2, :]
    r  = b1 / (b2 + 1e-8)
    rmin, rmax = r.min(), r.max()
    if rmax > rmin:
        r = (r - rmin) / (rmax - rmin)
    return r  # (H, W)

# ─────────────────────────────────────────────
# DATASET  (extraction depuis rectangles ROI)
# ─────────────────────────────────────────────
class ROISpectralDataset(Dataset):
    """
    Construit un dataset de spectres extraits depuis des ROI (rectangles)
    définis sur des cubes hyperspectraux.

    rois : liste de dict  {
        'cube'  : np.ndarray (H, B, W),
        'rect'  : (row0, col0, row1, col1),  # en pixels image
        'label' : int
    }
    null_threshold  : variance minimale d'un spectre pour être gardé
    deriv_threshold : seuil sur les dérivées (filtre spectres plats)
    flat_ratio      : proportion max de bandes "plates" tolérée
    """
    def __init__(self, rois, null_threshold=1e-6,
                 deriv_threshold=1e-4, flat_ratio=0.3):
        self.samples    = []
        self.class_names= {}

        for roi in rois:
            cube  = roi['cube']           # (H, B, W)
            r0, c0, r1, c1 = roi['rect']
            label = roi['label']
            cname = roi.get('class_name', f"class_{label}")
            self.class_names[label] = cname

            # Extraction des pixels dans le rectangle
            patch = cube[r0:r1, :, c0:c1]   # (dH, B, dW)
            dH, B, dW = patch.shape
            spectra = patch.reshape(dH * dW, B)

            for s in spectra:
                if np.var(s) <= null_threshold:
                    continue
                d    = np.diff(s)
                flat = np.mean(np.abs(d) < deriv_threshold)
                if flat > flat_ratio:
                    continue
                s_norm = 2.0 * s - 1.0
                self.samples.append(
                    (torch.tensor(s_norm, dtype=torch.float32), label)
                )

        print(f"[ROISpectralDataset] {len(self.samples)} spectres extraits")
        for lid, lname in self.class_names.items():
            n = sum(1 for _, l in self.samples if l == lid)
            print(f"  classe {lid} ({lname}): {n} spectres")

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        return self.samples[idx]

    @property
    def n_bands(self):
        if self.samples:
            return self.samples[0][0].shape[0]
        return 0


def create_class_dataloaders(dataset, batch_size=64):
    class_indices = defaultdict(list)
    for i, (_, label) in enumerate(dataset):
        class_indices[label].append(i)
    loaders = {}
    for label, indices in class_indices.items():
        subset  = Subset(dataset, indices)
        loaders[label] = DataLoader(
            subset, batch_size=batch_size, shuffle=True, drop_last=True
        )
    return loaders

# ─────────────────────────────────────────────
# WGAN-GP ARCHITECTURES
# ─────────────────────────────────────────────
def weights_init(m):
    if isinstance(m, (nn.Conv1d, nn.ConvTranspose1d)):
        nn.init.normal_(m.weight, 0.0, 0.02)
    elif isinstance(m, nn.BatchNorm1d):
        nn.init.normal_(m.weight, 1.0, 0.02)
        nn.init.constant_(m.bias, 0)

class Generator(nn.Module):
    def __init__(self, nz, n_bands):
        super().__init__()
        self.net = nn.Sequential(
            nn.ConvTranspose1d(nz, 512, 4, 1, 0, bias=False),
            nn.BatchNorm1d(512), nn.ReLU(True),
            nn.ConvTranspose1d(512, 256, 4, 2, 1, bias=False),
            nn.BatchNorm1d(256), nn.ReLU(True),
            nn.ConvTranspose1d(256, 128, 4, 2, 1, bias=False),
            nn.BatchNorm1d(128), nn.ReLU(True),
            nn.ConvTranspose1d(128,  64, 4, 2, 1, bias=False),
            nn.BatchNorm1d(64),  nn.ReLU(True),
            nn.ConvTranspose1d( 64,   1, 4, 2, 1, bias=False),
            nn.Tanh()
        )
        self._n_bands = n_bands

    def forward(self, z):
        x = self.net(z)                        # (B, 1, L)
        return x[:, :, :self._n_bands]

class Discriminator(nn.Module):
    def __init__(self, n_bands):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv1d(  1,  64, 4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),
            nn.Conv1d( 64, 128, 4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),
            nn.Conv1d(128, 256, 4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),
            nn.Conv1d(256, 512, 4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),
            nn.Conv1d(512,   1, 4, 1, 0, bias=False)
        )

    def forward(self, x):
        return self.net(x).mean(dim=[1, 2])

def compute_metrics(real, fake):
    real_np = real.detach().cpu().numpy().reshape(real.size(0), -1)
    fake_np = fake.detach().cpu().numpy().reshape(fake.size(0), -1)
    mse = float(np.mean((real_np - fake_np) ** 2))
    # Pearson on means
    r_m = real_np.mean(axis=0); f_m = fake_np.mean(0)
    num = np.sum((real_np - r_m) * (fake_np - f_m))
    den = np.sqrt(np.sum((real_np - r_m)**2) * np.sum((fake_np - f_m)**2)) + 1e-8
    pearson = float(num / den)
    # SAM
    dot  = np.sum(real_np * fake_np, axis=1)
    nr   = np.linalg.norm(real_np, axis=1) + 1e-8
    nf   = np.linalg.norm(fake_np, axis=1) + 1e-8
    sam  = float(np.mean(np.arccos(np.clip(dot / (nr * nf), -1, 1))))
    return {'MSE': mse, 'Pearson': pearson, 'SAM': sam}

# ─────────────────────────────────────────────
# TRAINING FUNCTION  (runs in a thread)
# ─────────────────────────────────────────────
def train_single_class(loader, n_bands, class_name, out_dir,
                       log_queue, stop_event):
    """Entraîne un WGAN-GP sur une classe. Envoie les logs dans log_queue."""
    netD = Discriminator(n_bands).to(DEVICE)
    netG = Generator(NZ, n_bands).to(DEVICE)
    netD.apply(weights_init)
    netG.apply(weights_init)

    optD = optim.Adam(netD.parameters(), lr=LR, betas=(0, 0.9))
    optG = optim.Adam(netG.parameters(), lr=LR, betas=(0, 0.9))

    fixed_noise = torch.randn(16, NZ, 1, device=DEVICE)
    best_sam, best_G, best_D = float('inf'), None, None

    out = Path(out_dir) / class_name
    out.mkdir(parents=True, exist_ok=True)

    for epoch in range(EPOCH_NUM):
        if stop_event.is_set():
            log_queue.put(f"[{class_name}] Entraînement interrompu à l'epoch {epoch}.")
            break
        epoch_metrics = {'MSE': [], 'Pearson': [], 'SAM': []}

        for data in loader:
            real = data[0].to(DEVICE)
            if real.dim() == 2:
                real = real.unsqueeze(1)
            b = real.size(0)

            for _ in range(N_CRITIC):
                netD.zero_grad()
                noise = torch.randn(b, NZ, 1, device=DEVICE)
                fake  = netG(noise)
                eps   = torch.rand(b, 1, 1, device=DEVICE)
                xp    = eps * real + (1 - eps) * fake
                xp.requires_grad_(True)
                grad  = autograd.grad(netD(xp).sum(), xp,
                                      create_graph=True, retain_graph=True)[0]
                gp    = P_COEFF * ((grad.view(b,-1).norm(2,dim=1)-1)**2).mean()
                lD    = torch.mean(netD(fake)) - torch.mean(netD(real)) + gp
                lD.backward()
                optD.step()

            netG.zero_grad()
            noise = torch.randn(b, NZ, 1, device=DEVICE)
            fake  = netG(noise)
            lG    = -torch.mean(netD(fake))
            lG.backward()
            optG.step()

            m = compute_metrics(real, fake)
            for k in epoch_metrics:
                epoch_metrics[k].append(m[k])

        avg = {k: float(np.mean(v)) for k, v in epoch_metrics.items()}
        msg = (f"[{class_name}] Epoch {epoch:03d} | "
               f"D:{lD.item():.4f} G:{lG.item():.4f} | "
               f"MSE:{avg['MSE']:.4f} Pearson:{avg['Pearson']:.4f} SAM:{avg['SAM']:.4f}")
        log_queue.put(msg)

        if avg['SAM'] < best_sam:
            best_sam = avg['SAM']
            best_G = {k: v.cpu().clone() for k, v in netG.state_dict().items()}
            best_D = {k: v.cpu().clone() for k, v in netD.state_dict().items()}

        if (epoch + 1) % 50 == 0:
            torch.save(netG.state_dict(), out / f"netG_epoch_{epoch:03d}.pth")
            torch.save(netD.state_dict(), out / f"netD_epoch_{epoch:03d}.pth")

    torch.save(best_G, out / "netG_best.pth")
    torch.save(best_D, out / "netD_best.pth")
    log_queue.put(f"[{class_name}] ✓ Terminé. Best SAM={best_sam:.4f}. Modèles sauvegardés dans {out}")

