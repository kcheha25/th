def match_gan_to_local_neighbors_vectorized(cube_gan, remove_mask, smooth_sigma=15.0):
    from scipy.ndimage import gaussian_filter

    result = cube_gan.copy()
    B      = cube_gan.shape[0]

    for b in range(B):
        band      = cube_gan[b].copy()
        real_mean = band[~remove_mask].mean()
        real_std  = band[~remove_mask].std() + 1e-8

        band_filled              = band.copy()
        band_filled[remove_mask] = real_mean
        local_mean               = gaussian_filter(band_filled, sigma=smooth_sigma)

        gan_zone_mean = band[remove_mask].mean()
        gan_zone_std  = band[remove_mask].std() + 1e-8

        result[b][remove_mask] = (
            local_mean[remove_mask] +
            (band[remove_mask] - gan_zone_mean) / gan_zone_std * real_std
        )

    return result

