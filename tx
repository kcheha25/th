import numpy as np
import matplotlib.pyplot as plt
from spectral import envi
from pathlib import Path

def plot_real_with_its_augmented(cube_path, augmented_class_dir, null_threshold=1e-6):
    cube_path = Path(cube_path)
    class_name = cube_path.stem.split("_")[0]

    # --- Cube réel ---
    hdr_img = envi.open(str(cube_path))
    cube = np.array(hdr_img.load(), dtype=np.float32)
    B, H, W = cube.shape
    spectra = cube.reshape(B, -1).T
    valid_spectra = np.array([s for s in spectra if np.var(s) > null_threshold])
    if len(valid_spectra) == 0:
        print(f"Aucun spectre valide pour {cube_path}")
        return
    real_mean = np.mean(valid_spectra, axis=0)
    real_std = np.std(valid_spectra, axis=0)

    # --- Cubes augmentés associés à ce cube ---
    cube_index = cube_path.stem.split("_")[1]  # ex: '0' pour A1_0.hdr
    aug_dir = Path(augmented_class_dir) / class_name
    aug_files = sorted(aug_dir.rglob(f"{class_name}_cube{cube_index}_aug_*.hdr"))

    all_aug_spectra = []
    for f in aug_files:
        hdr_aug = envi.open(str(f))
        cube_aug = np.array(hdr_aug.load(), dtype=np.float32)
        B_aug, H_aug, W_aug = cube_aug.shape
        spectra_aug = cube_aug.reshape(B_aug, -1).T
        valid_aug = np.array([s for s in spectra_aug if np.var(s) > null_threshold])
        if len(valid_aug) > 0:
            all_aug_spectra.append(valid_aug)

    if len(all_aug_spectra) == 0:
        print(f"Aucun cube augmenté valide pour {cube_path}")
        return

    all_aug_spectra = np.vstack(all_aug_spectra)
    aug_mean = np.mean(all_aug_spectra, axis=0)
    aug_std = np.std(all_aug_spectra, axis=0)

    # --- Plot ---
    plt.figure(figsize=(10,5))
    plt.plot(real_mean, color='blue', linewidth=2, label='Real Mean')
    plt.fill_between(range(len(real_mean)), real_mean - real_std, real_mean + real_std,
                     color='blue', alpha=0.2, label='Real ± STD')

    plt.plot(aug_mean, color='orange', linewidth=2, label='Augmented Mean')
    plt.fill_between(range(len(aug_mean)), aug_mean - aug_std, aug_mean + aug_std,
                     color='orange', alpha=0.2, label='Augmented ± STD')

    plt.title(f"{class_name} - {cube_path.stem}")
    plt.xlabel("Indice bande")
    plt.ylabel("Reflectance")
    plt.legend()
    plt.tight_layout()
    plt.show()


def plot_all_real_and_augmented(data_dir, augmented_dir, null_threshold=1e-6):
    data_dir = Path(data_dir)
    real_hdr_files = sorted(data_dir.rglob("*.hdr"))
    for cube_path in real_hdr_files:
        plot_real_with_its_augmented(cube_path, augmented_dir, null_threshold=null_threshold)


