def inpaint_cube(cube, remove_mask, netG, device,
                 n_neighbors=5, search_radius=10,
                 n_candidates=5, sam_threshold=0.10,
                 save_plots=False, plot_dir=None, plot_max=10):
    B, H, W       = cube.shape
    result_cube   = cube.copy()
    masked_pixels = list(zip(*np.where(remove_mask)))
    print(f"  {len(masked_pixels)} pixels à inpainter...")
    plot_count = 0
    if save_plots and plot_dir:
        Path(plot_dir).mkdir(parents=True, exist_ok=True)
    for k, (row, col) in enumerate(masked_pixels):
        neighbors = get_real_neighbors(cube, remove_mask, row, col,
                                       n_neighbors=n_neighbors,
                                       search_radius=search_radius)
        if neighbors is None:
            continue
        new_spec, sam = generate_pixel_spectrum(netG, neighbors, device,
                                                n_candidates=n_candidates,
                                                sam_threshold=sam_threshold)
        result_cube[:, row, col] = new_spec
        if save_plots and plot_dir and plot_count < plot_max:
            ref = neighbors.mean(axis=0)
            plt.figure(figsize=(8, 4))
            for nb in neighbors:
                plt.plot(nb, color="gray", alpha=0.3, linewidth=0.8)
            plt.plot(ref,      color="blue",  linewidth=1.5, label="Voisins (moy)")
            plt.plot(new_spec, color="red",   linewidth=1.5, label=f"Généré SAM={sam:.3f}")
            plt.title(f"Pixel ({row},{col})")
            plt.xlabel("Bande"); plt.ylabel("Réflectance")
            plt.legend(); plt.tight_layout()
            plt.savefig(Path(plot_dir) / f"pixel_{k}.png")
            plt.close()
            plot_count += 1
        if k % 500 == 0:
            print(f"    {k}/{len(masked_pixels)} pixels traités")
    return result_cube


def plot_random_band(cube, remove_mask, title, out_path=None):
    B, H, W  = cube.shape
    band_idx = np.random.randint(0, B)
    band_img = cube[band_idx]
    fig, ax = plt.subplots(figsize=(7, 5))
    im = ax.imshow(band_img, cmap="inferno", aspect="auto")
    plt.colorbar(im, ax=ax, fraction=0.03)
    if remove_mask is not None:
        ax.contour(remove_mask.astype(float), levels=[0.5], colors="cyan", linewidths=1.2)
    ax.set_title(f"{title}  —  bande {band_idx}")
    ax.axis("off")
    plt.tight_layout()
    if out_path:
        plt.savefig(out_path, dpi=120)
    plt.show()
    plt.close()


def smooth_inpainted_zone(cube, remove_mask, sigma=1.2, blend_radius=3):
    B, H, W = cube.shape
    result  = cube.copy()
    dist_from_edge = distance_transform_edt(remove_mask)
    max_dist       = dist_from_edge.max()
    if max_dist == 0:
        return result
    alpha = np.clip(dist_from_edge / blend_radius, 0, 1)
    for b in range(B):
        band          = result[b].copy()
        band_smoothed = gaussian_filter(band, sigma=sigma)
        blended       = alpha * band + (1 - alpha) * band_smoothed
        result[b][remove_mask] = blended[remove_mask]
    return result


def process_cube_inpaint(cube_folder, json_path, netG_path, out_dir,
                         dilate_radius=3, n_neighbors=5, search_radius=10,
                         n_candidates=5, sam_threshold=0.10,
                         device="cpu", save_plots=True,
                         smooth_sigma=1.2, blend_radius=3):
    device = torch.device(device if torch.cuda.is_available() else "cpu")
    netG = torch.load(netG_path, weights_only=False)
    netG.to(device)
    netG.eval()
    spec        = SpecArray.from_folder(str(cube_folder))
    cube_HBW    = np.array(spec.spectral_albedo).transpose(1, 0, 2)
    B, H, W     = cube_HBW.shape
    wavelengths = np.array(spec.wavelengths)
    meta        = spec.metadata.copy()
    plots, polygons = load_labelme(json_path)
    remove_mask     = build_mask(H, W, polygons, dilate_radius=dilate_radius)
    cube_HBW[:, remove_mask] = 0
    out_dir = Path(out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    print(f"\n{'='*50}\nInpainting : {cube_folder.name}\n{'='*50}")
    inpainted = inpaint_cube(
        cube_HBW, remove_mask, netG, device,
        n_neighbors=n_neighbors, search_radius=search_radius,
        n_candidates=n_candidates, sam_threshold=sam_threshold,
        save_plots=save_plots, plot_dir=out_dir / f"{cube_folder.name}_plots_pixels"
    )
    plot_random_band(inpainted, remove_mask,
                     title=f"{cube_folder.name} — inpainté (avant lissage)",
                     out_path=out_dir / f"{cube_folder.name}_before_smooth.png")
    print("  Lissage des zones inpaintées...")
    smoothed = smooth_inpainted_zone(inpainted, remove_mask,
                                     sigma=smooth_sigma, blend_radius=blend_radius)
    plot_random_band(smoothed, remove_mask,
                     title=f"{cube_folder.name} — inpainté (après lissage)",
                     out_path=out_dir / f"{cube_folder.name}_after_smooth.png")
    i1 = np.argmin(np.abs(wavelengths - 996))
    i2 = np.argmin(np.abs(wavelengths - 1197))
    for i, (x1, y1, x2, y2) in enumerate(plots):
        plot_cube = smoothed[:, y1:y2, x1:x2]
        plot_mask = remove_mask[y1:y2, x1:x2]
        m = meta.copy()
        m["lines"]   = plot_cube.shape[1]
        m["samples"] = plot_cube.shape[2]
        m["bands"]   = plot_cube.shape[0]
        hdr_path = out_dir / f"{cube_folder.name}_plot_{i}_inpainted.hdr"
        envi.save_image(str(hdr_path), plot_cube, dtype=np.float32,
                        interleave="bil", force=True, metadata=m)
        ratio_before = inpainted[i1, y1:y2, x1:x2] / (inpainted[i2, y1:y2, x1:x2] + 1e-8)
        rb_min, rb_max = ratio_before.min(), ratio_before.max()
        if rb_max > rb_min:
            ratio_before = (ratio_before - rb_min) / (rb_max - rb_min)
        ratio_after = plot_cube[i1] / (plot_cube[i2] + 1e-8)
        ra_min, ra_max = ratio_after.min(), ratio_after.max()
        if ra_max > ra_min:
            ratio_after = (ratio_after - ra_min) / (ra_max - ra_min)
        band_idx  = np.random.randint(0, plot_cube.shape[0])
        band_plot = plot_cube[band_idx]
        fig, axes = plt.subplots(1, 3, figsize=(16, 5))
        im0 = axes[0].imshow(band_plot, cmap="inferno", aspect="auto")
        axes[0].contour(plot_mask.astype(float), levels=[0.5], colors="cyan", linewidths=1)
        plt.colorbar(im0, ax=axes[0], fraction=0.03)
        axes[0].set_title(f"Bande {band_idx}")
        axes[0].axis("off")
        im1 = axes[1].imshow(ratio_before, cmap="RdYlGn", aspect="auto", vmin=0, vmax=1)
        axes[1].contour(plot_mask.astype(float), levels=[0.5], colors="cyan", linewidths=1)
        plt.colorbar(im1, ax=axes[1], fraction=0.03)
        axes[1].set_title("Ratio 996/1197nm — avant lissage")
        axes[1].axis("off")
        im2 = axes[2].imshow(ratio_after, cmap="RdYlGn", aspect="auto", vmin=0, vmax=1)
        axes[2].contour(plot_mask.astype(float), levels=[0.5], colors="cyan", linewidths=1)
        plt.colorbar(im2, ax=axes[2], fraction=0.03)
        axes[2].set_title("Ratio 996/1197nm — après lissage")
        axes[2].axis("off")
        fig.suptitle(f"{cube_folder.name} — plot {i}", fontsize=13)
        plt.tight_layout()
        plt.savefig(out_dir / f"{cube_folder.name}_plot_{i}_compare.png", dpi=120)
        plt.show()
        plt.close()
        print(f"  ✓ Plot {i} sauvegardé : {hdr_path.name}")
    print(f"\n✓ {cube_folder.name} terminé — {len(plots)} plot(s) sauvegardés\n")


def process_all_inpaint(hsi_root, ann_root, netG_path, out_dir, **kwargs):
