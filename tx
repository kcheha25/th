from skimage.morphology import dilation, disk


# ─────────────────────────────────────────────
# UTILS MASK
# ─────────────────────────────────────────────
def load_labelme(json_path):
    with open(json_path) as f:
        data = json.load(f)
    plots, polygons_to_remove = [], []
    for shape in data["shapes"]:
        label = shape["label"]
        pts   = np.array(shape["points"], dtype=np.int32)
        if label == "plot":
            x1 = int(np.min(pts[:,0])); x2 = int(np.max(pts[:,0]))
            y1 = int(np.min(pts[:,1])); y2 = int(np.max(pts[:,1]))
            plots.append((x1, y1, x2, y2))
        elif label != "trou":
            polygons_to_remove.append(pts)
    return plots, polygons_to_remove

def build_mask(H, W, polygons, dilate_radius=3):
    mask = np.zeros((H, W), dtype=np.uint8)
    for poly in polygons:
        cv2.fillPoly(mask, [poly], 1)
    mask = dilation(mask, disk(dilate_radius))
    return mask.astype(bool)


# ─────────────────────────────────────────────
# VOISINS REELS autour d un pixel masqué
# ─────────────────────────────────────────────
def get_real_neighbors(cube, remove_mask, row, col,
                       n_neighbors=5, search_radius=10):
    """
    Retourne jusqu'à n_neighbors spectres réels (non masqués)
    dans un carré de search_radius autour de (row, col).
    cube : (B, H, W)
    """
    B, H, W = cube.shape
    r0 = max(0, row - search_radius)
    r1 = min(H, row + search_radius + 1)
    c0 = max(0, col - search_radius)
    c1 = min(W, col + search_radius + 1)

    neighbors = []
    for r in range(r0, r1):
        for c in range(c0, c1):
            if not remove_mask[r, c] and np.var(cube[:, r, c]) > 1e-6:
                neighbors.append(cube[:, r, c])

    if not neighbors:
        return None

    neighbors = np.array(neighbors)          # (N, B)
    # tirage aléatoire de n_neighbors parmi les voisins disponibles
    idx = np.random.choice(len(neighbors),
                           size=min(n_neighbors, len(neighbors)),
                           replace=False)
    return neighbors[idx]                    # (k, B)


# ─────────────────────────────────────────────
# SAM
# ─────────────────────────────────────────────
def compute_sam(s1, s2):
    num   = np.dot(s1, s2)
    denom = np.linalg.norm(s1) * np.linalg.norm(s2) + 1e-8
    return float(np.arccos(np.clip(num / denom, -1, 1)))


# ─────────────────────────────────────────────
# GENERATION D UN SPECTRE pour un pixel masqué
# ─────────────────────────────────────────────
def generate_pixel_spectrum(netG, real_neighbors, device,
                             n_candidates=5, sam_threshold=0.10):
    """
    - Tire n_candidates spectres GAN
    - Choisit celui le plus proche (SAM minimal) d'un voisin réel tiré aléatoirement
    - Applique inject_local_variation inspiré du premier code
    """
    # spectre réel de référence : moyenne des voisins
    ref_spec = real_neighbors.mean(axis=0)          # (B,)

    best_sam  = float("inf")
    best_fake = None

    for _ in range(n_candidates):
        noise = torch.randn(1, 1, 1, device=device)  # (1,1,1) — adapté à votre G
        with torch.no_grad():
            fake = netG(noise).cpu().squeeze().numpy()   # (B,)
        sam = compute_sam(ref_spec, fake)
        if sam < best_sam:
            best_sam  = sam
            best_fake = fake

    if best_sam < sam_threshold:
        # injection des variations locales du voisin réel dans le fake
        new_spec = inject_local_variation(ref_spec, best_fake,
                                          selected_indices=range(len(ref_spec)),
                                          beta=1.0, window_size=1)
    else:
        # GAN trop éloigné → on ajoute du bruit sur le voisin réel
        sigma    = real_neighbors.std(axis=0)         # variabilité inter-voisins
        noise_np = np.random.randn(len(ref_spec)) * sigma * 0.05
        new_spec = np.clip(ref_spec + noise_np, 0, 1)

    return new_spec, best_sam


def inject_local_variation(real_spec, gan_spec, selected_indices,
                            beta=1.0, window_size=1):
    S_aug = gan_spec.copy()
    B     = len(real_spec)
    for idx in selected_indices:
        i     = int(idx)
        start = max(0, i - window_size)
        end   = min(B, i + window_size + 1)
        real_win = real_spec[start:end]
        gan_win  = gan_spec[start:end]
        delta    = np.diff(real_win)
        aug_win  = [gan_win[0]]
        for d in delta:
            aug_win.append(aug_win[-1] + d)
        S_aug[start:end] = aug_win
    return S_aug


# ─────────────────────────────────────────────
# INPAINTING D UN CUBE
# ─────────────────────────────────────────────
def inpaint_cube(cube, remove_mask, netG, device,
                 n_neighbors=5, search_radius=10,
                 n_candidates=5, sam_threshold=0.10,
                 save_plots=False, plot_dir=None, plot_max=10):
    """
    cube        : (B, H, W)  — pixels masqués déjà mis à 0
    remove_mask : (H, W) bool — True = pixel à inpainter
    Retourne le cube inpainté (B, H, W)
    """
    B, H, W     = cube.shape
    result_cube = cube.copy()
    masked_pixels = list(zip(*np.where(remove_mask)))   # [(r,c), ...]
    print(f"  {len(masked_pixels)} pixels à inpainter...")

    plot_count = 0
    if save_plots and plot_dir:
        Path(plot_dir).mkdir(parents=True, exist_ok=True)

    for k, (row, col) in enumerate(masked_pixels):
        neighbors = get_real_neighbors(cube, remove_mask, row, col,
                                       n_neighbors=n_neighbors,
                                       search_radius=search_radius)
        if neighbors is None:
            # aucun voisin trouvé → laisser à zéro
            continue

        new_spec, sam = generate_pixel_spectrum(
            netG, neighbors, device,
            n_candidates=n_candidates,
            sam_threshold=sam_threshold
        )
        result_cube[:, row, col] = new_spec

        if save_plots and plot_dir and plot_count < plot_max:
            ref = neighbors.mean(axis=0)
            plt.figure(figsize=(8, 4))
            for nb in neighbors:
                plt.plot(nb, color="gray", alpha=0.3, linewidth=0.8)
            plt.plot(ref,      color="blue",  linewidth=1.5, label="Voisins (moy)")
            plt.plot(new_spec, color="red",   linewidth=1.5, label=f"Généré SAM={sam:.3f}")
            plt.title(f"Pixel ({row},{col})")
            plt.xlabel("Bande"); plt.ylabel("Réflectance")
            plt.legend(); plt.tight_layout()
            plt.savefig(Path(plot_dir) / f"pixel_{k}.png")
            plt.close()
            plot_count += 1

        if k % 500 == 0:
            print(f"    {k}/{len(masked_pixels)} pixels traités")

    return result_cube


