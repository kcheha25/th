import numpy as np
import matplotlib.pyplot as plt
from spectral import envi
from pathlib import Path

def plot_mean_std_for_cube(cube_path, null_threshold=1e-6):
    cube_path = Path(cube_path)
    class_name = cube_path.stem.split("_")[0]
    hdr_img = envi.open(str(cube_path))
    cube = np.array(hdr_img.load(), dtype=np.float32)
    B, H, W = cube.shape
    spectra = cube.reshape(B, -1).T
    valid_spectra = np.array([s for s in spectra if np.var(s) > null_threshold])
    if len(valid_spectra) == 0:
        return
    mean_spec = np.mean(valid_spectra, axis=0)
    std_spec = np.std(valid_spectra, axis=0)
    plt.figure(figsize=(10,5))
    plt.plot(mean_spec, linewidth=2)
    plt.plot(mean_spec + std_spec, linestyle="--")
    plt.plot(mean_spec - std_spec, linestyle="--")
    plt.title(f"{class_name} - {cube_path.stem}")
    plt.xlabel("Indice bande")
    plt.ylabel("Reflectance")
    plt.tight_layout()
    plt.show()

def plot_all_extrudes(dataset_root):
    dataset_root = Path(dataset_root)
    hdr_files = sorted(dataset_root.rglob("*.hdr"))
    for cube_path in hdr_files:
        plot_mean_std_for_cube(cube_path)

import numpy as np
import matplotlib.pyplot as plt
from spectral import envi
from pathlib import Path
from collections import defaultdict

def compute_mean_std_cube(cube_path, null_threshold=1e-6):
    cube_path = Path(cube_path)
    class_name = cube_path.stem.split("_")[0]
    hdr_img = envi.open(str(cube_path))
    cube = np.array(hdr_img.load(), dtype=np.float32)
    B, H, W = cube.shape
    spectra = cube.reshape(B, -1).T
    valid_spectra = np.array([s for s in spectra if np.var(s) > null_threshold])
    if len(valid_spectra) == 0:
        return class_name, None, None
    mean_spec = np.mean(valid_spectra, axis=0)
    std_spec = np.std(valid_spectra, axis=0)
    return class_name, mean_spec, std_spec

def plot_all_extrudes_and_overlay_by_class(dataset_root, null_threshold=1e-6):
    dataset_root = Path(dataset_root)
    hdr_files = sorted(dataset_root.rglob("*.hdr"))
    class_means = defaultdict(list)

    for cube_path in hdr_files:
        class_name, mean_spec, std_spec = compute_mean_std_cube(cube_path, null_threshold)
        if mean_spec is None:
            continue

        plt.figure(figsize=(8,4))
        plt.plot(mean_spec, linewidth=2)
        plt.plot(mean_spec + std_spec, linestyle="--")
        plt.plot(mean_spec - std_spec, linestyle="--")
        plt.title(f"{class_name} - {cube_path.stem}")
        plt.xlabel("Indice bande")
        plt.ylabel("Reflectance")
        plt.tight_layout()
        plt.show()

        class_means[class_name].append(mean_spec)

    for class_name, means in class_means.items():
        plt.figure(figsize=(10,5))
        for mean_spec in means:
            plt.plot(mean_spec)
        plt.title(f"Superposition des spectres moyens - {class_name}")
        plt.xlabel("Indice bande")
        plt.ylabel("Reflectance")
        plt.tight_layout()
        plt.show()


import numpy as np
import matplotlib.pyplot as plt
from spectral import envi
from pathlib import Path

def plot_radial_spectra_for_cube(cube_path, null_threshold=1e-6):
    cube_path = Path(cube_path)
    class_name = cube_path.stem.split("_")[0]

    hdr_img = envi.open(str(cube_path))
    cube = np.array(hdr_img.load(), dtype=np.float32)
    B, H, W = cube.shape

    mask = np.var(cube, axis=0) > null_threshold
    coords = np.column_stack(np.where(mask))

    if len(coords) == 0:
        return

    cy = np.mean(coords[:, 0])
    cx = np.mean(coords[:, 1])

    distances = np.sqrt((coords[:, 0] - cy) ** 2 + (coords[:, 1] - cx) ** 2)
    max_d = np.max(distances)

    center_idx = np.argmin(distances)
    contour_idx = np.argmax(distances)

    mid_target = 0.5 * max_d
    mid_idx = np.argmin(np.abs(distances - mid_target))

    near_contour_target = 0.85 * max_d
    near_contour_idx = np.argmin(np.abs(distances - near_contour_target))

    y_center, x_center = coords[center_idx]
    y_mid, x_mid = coords[mid_idx]
    y_near, x_near = coords[near_contour_idx]
    y_contour, x_contour = coords[contour_idx]

    spec_center = cube[:, y_center, x_center]
    spec_mid = cube[:, y_mid, x_mid]
    spec_near = cube[:, y_near, x_near]
    spec_contour = cube[:, y_contour, x_contour]

    plt.figure(figsize=(10,5))
    plt.plot(spec_center, label="Centre")
    plt.plot(spec_mid, label="Milieu")
    plt.plot(spec_near, label="Proche contour")
    plt.plot(spec_contour, label="Contour")
    plt.title(f"{class_name} - {cube_path.stem}")
    plt.xlabel("Indice bande")
    plt.ylabel("Reflectance")
    plt.legend()
    plt.tight_layout()
    plt.show()


def plot_radial_spectra_all_extrudes(dataset_root, null_threshold=1e-6):
    dataset_root = Path(dataset_root)
    hdr_files = sorted(dataset_root.rglob("*.hdr"))

    for cube_path in hdr_files:
        plot_radial_spectra_for_cube(cube_path, null_threshold)





