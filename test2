                model, val_loader, criterion, optimizer, scaler,
                device, args.amp, 1, 0,
                train=False, world_size=world_size)

        if ema is not None:
            raw.load_state_dict(orig_sd)

        scheduler.step()

        if main_proc:
            elapsed    = time.perf_counter() - t0
            lr_now     = optimizer.param_groups[0]["lr"]
            vram       = (torch.cuda.max_memory_allocated(device) / 1e9
                          if torch.cuda.is_available() else 0.0)
            torch.cuda.reset_peak_memory_stats(device)
            throughput = len(train_loader.dataset) / elapsed
            print(f"Ep {epoch:03d}/{args.epochs}"
                  f"  tr {tr_loss:.4f}/{tr_acc*100:.2f}%"
                  f"  va {va_loss:.4f}/{va_acc*100:.2f}%"
                  f"  lr {lr_now:.2e}"
                  f"  VRAM {vram:.1f}GB"
                  f"  {throughput:,.0f}p/s"
                  f"  {elapsed:.1f}s")

            if epoch % args.save_every == 0:
                save_ckpt(ckpt_dir / f"ckpt_ep{epoch:03d}.pt",
                          epoch, model, optimizer, scheduler, scaler, ema, va_acc)

            if va_acc > best_val_acc:
                best_val_acc = va_acc
                patience_cnt = 0
                save_ckpt(ckpt_dir / "best_model.pt",
                          epoch, model, optimizer, scheduler, scaler, ema, va_acc)
                print(f"  -> Meilleur modele  val acc={va_acc*100:.2f}%")
            else:
                patience_cnt += 1
                if patience_cnt >= args.patience:
                    print(f"  Early stopping apres {args.patience} epoques.")
                    break

        if world_size > 1:
            dist.barrier()

    if main_proc:
        print(f"\n{'='*65}")
        ckpt = torch.load(ckpt_dir / "best_model.pt", map_location=device)
        raw  = model.module if hasattr(model, "module") else model
        if ema is not None and "ema" in ckpt:
            raw.load_state_dict({k: v.to(device) for k, v in ckpt["ema"].items()})
        else:
            raw.load_state_dict(ckpt["model"])

        oa, aa, kappa, cm, per_cls = evaluate_metrics(
            model, test_loader, device, args.amp, meta["class_names"])
        print(f"  OA={oa:.2f}%  AA={aa:.2f}%  Kappa={kappa:.2f}%")
        print(f"\n  Par classe :")
        for name, acc in zip(meta["class_names"], per_cls):
            print(f"    {name:<25}: {acc:.2f}%")
        print(f"\n  Matrice de confusion :\n{cm}")

        results_dir = Path("cls_results")
        results_dir.mkdir(exist_ok=True)
        with open(results_dir / "report.txt", "w") as f:
            f.write(f"OA={oa:.2f}%  AA={aa:.2f}%  Kappa={kappa:.2f}%\n\n")
            for name, acc in zip(meta["class_names"], per_cls):
                f.write(f"{name}: {acc:.2f}%\n")
            f.write(f"\nConfusion Matrix:\n{cm}\n")
        print(f"{'='*65}\n")

    if world_size > 1:
        dist.destroy_process_group()


if __name__ == "__main__":
    main()