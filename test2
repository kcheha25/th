NUM_GPUS            = max(1, torch.cuda.device_count())
PATCH_EXTRACT_BATCH = 8192
PREFETCH_QUEUE_SIZE = 4
HDF5_CHUNK_PATCHES  = 256

_H5_REGISTRY = {}

def _get_h5(h5_path):
    key = (os.getpid(), h5_path)
    f   = _H5_REGISTRY.get(key)
    if f is None or not f.id.valid:
        f = h5py.File(h5_path, 'r', rdcc_nbytes=128*1024*1024, rdcc_nslots=10007)
        _H5_REGISTRY[key] = f
    return f

def detect_server():
    is_win       = platform.system() == "Windows"
    ram_avail_gb = psutil.virtual_memory().available / 1e9
    ram_total_gb = psutil.virtual_memory().total    / 1e9
    n_gpus       = torch.cuda.device_count()
    vram_list    = [torch.cuda.get_device_properties(i).total_memory / 1e9
                    for i in range(n_gpus)] if n_gpus > 0 else []
    cpu_count    = os.cpu_count() or 4
    info = {
        "is_windows":   is_win,
        "ram_avail_gb": ram_avail_gb,
        "ram_total_gb": ram_total_gb,
        "n_gpus":       n_gpus,
        "vram_list":    vram_list,
        "min_vram_gb":  min(vram_list) if vram_list else 0,
        "cpu_count":    cpu_count,
    }
    print(f"    OS        : {'Windows' if is_win else 'Linux'}")
    print(f"    RAM dispo : {ram_avail_gb:.1f} GB")
    print(f"    GPUs      : {n_gpus}x  VRAM={[f'{v:.0f}' for v in vram_list]}")
    print(f"    CPUs      : {cpu_count}")
    return info

def auto_config(server_info, world_size=1):
    is_win       = server_info["is_windows"]
    ram_avail_gb = server_info["ram_avail_gb"]
    n_gpus       = max(server_info["n_gpus"], 1)
    min_vram     = server_info["min_vram_gb"]
    cpu_count    = server_info["cpu_count"]
    patch_bytes  = 30 * 13 * 13 * 4

    if is_win:
        # Windows L40s : 400 GB RAM, 1 GPU, pas de torchrun multi-proc
        usable_ram   = ram_avail_gb * 0.80
        ram_cache_gb = min(usable_ram, 320.0)
        slab_size    = 32768
        batch_size   = 2048
        num_workers  = min(8, cpu_count)
        prefetch     = 4
        mp_ctx       = "spawn"
        strategy     = "WINDOWS_L40S"

    elif ram_avail_gb >= 200:
        # Linux grande RAM (664 GB)
        # IMPORTANT : world_size processus torchrun tournent en parallele
        # Chaque processus ne peut utiliser que ram_avail_gb / world_size
        ram_per_rank = ram_avail_gb / max(world_size, 1)
        # On prend 80% de la part de ce rank
        ram_cache_gb = ram_per_rank * 0.80

        if min_vram <= 10:
            batch_size = 256
        elif min_vram <= 16:
            batch_size = 512
        else:
            batch_size = 1024

        # Peu de workers : les donnees sont en RAM, pas besoin de beaucoup
        num_workers  = min(4, cpu_count // max(n_gpus, 1))
        prefetch     = 4
        mp_ctx       = None
        slab_size    = 8192
        strategy     = "LINUX_LARGERAM"

    else:
        # Linux RAM limitee
        ram_cache_gb = 0.0
        num_workers  = max(1, min(2, cpu_count // max(n_gpus, 1)))
        budget_b     = 0.5 * 1e9
        slab_size    = max(128, min(1024, int(budget_b / patch_bytes)))
        if min_vram <= 10:
            batch_size = 128
        elif min_vram <= 16:
            batch_size = 256
        else:
            batch_size = 512
        prefetch     = 2
        mp_ctx       = None
        strategy     = "LINUX_LOWRAM"

    cfg = {
        "strategy":     strategy,
        "slab_size":    slab_size,
        "batch_size":   batch_size,
        "num_workers":  num_workers,
        "prefetch":     prefetch,
        "mp_ctx":       mp_ctx,
        "ram_cache_gb": ram_cache_gb,
    }
    return cfg

def load_mapping(mapping_path):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names   = final_classes + ["background"]
    label2idx     = {name: i for i, name in enumerate(class_names)}
    return extrude2final, class_names, label2idx

def _load_envi_cube(hdr_path, source):
    img  = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wl   = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3:
        if source == "real" and wl and cube.shape[2] == len(wl):
            cube = cube.transpose(2, 0, 1)
        elif source != "real" and wl and cube.shape[1] == len(wl):
            cube = cube.transpose(1, 0, 2)
    if cube.ndim != 3:
        raise ValueError(f"Invalid cube shape: {cube.shape}")
    return cube, wl

def _load_shapes(json_path):
    with open(json_path) as f:
        return json.load(f).get("shapes", [])

def collect_plots_meta(real_dir=None, aug_dir=None):
    meta_list = []
    if real_dir:
        real_dir = Path(real_dir)
        for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
            m = re.match(r"plot_(\d+)_cube", hdr.stem)
            if not m: continue
            jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
            if jsn.exists():
                meta_list.append({"source": "real", "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if aug_dir:
        aug_dir = Path(aug_dir)
        for hdr in sorted(aug_dir.glob("*.hdr")):
            if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")): continue
            jsn = aug_dir / f"{hdr.stem}.json"
            if not jsn.exists(): continue
            source = "circle" if "circle" in hdr.stem.lower() else "aug"
            meta_list.append({"source": source, "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if not meta_list:
        raise RuntimeError("No plots found.")
    return meta_list

def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15, test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug  = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        train, val, test = aug[n_val:], aug[:n_val], real
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test, n_val = max(1, int(n * test_ratio)), max(1, int(n * val_ratio))
        test  = all_p[:n_test]
        val   = all_p[n_test:n_test + n_val]
        train = all_p[n_test + n_val:]
    else:
        raise ValueError(f"Unknown split_mode: {split_mode}")
    return train, val, test

def _rasterize_cpu(points, H, W):
    pts  = np.array(points, dtype=np.float32)
    n    = len(pts)
    cols = np.arange(W, dtype=np.float32) + 0.5
    rows = np.arange(H, dtype=np.float32) + 0.5
    gc_, gr_ = np.meshgrid(cols, rows)
    px, py   = gc_.ravel(), gr_.ravel()
    inside   = np.zeros(len(px), dtype=bool)
    x1, y1   = pts[:, 0], pts[:, 1]
    x2, y2   = np.roll(x1, -1), np.roll(y1, -1)
    for i in range(n):
        dy = y2[i] - y1[i]
        if abs(dy) < 1e-10: continue
        cond    = (y1[i] < py) != (y2[i] < py)
        xi      = x1[i] + (py - y1[i]) * (x2[i] - x1[i]) / dy
        inside ^= cond & (px < xi)
    return inside.reshape(H, W)

def build_label_map(H, W, shapes, extrude2final, label2idx):
    bg = label2idx["background"]
    lm = np.full((H, W), bg, dtype=np.int32)
    for shape in shapes:
        raw   = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw.lower() == "trou" or stype not in ("polygon", "rectangle"): continue
        final = extrude2final.get(raw)
        if final is None: continue
        pts = shape["points"]
        if len(pts) < 3: continue
        try:
            lm[_rasterize_cpu(pts, H, W)] = label2idx[final]
        except Exception as e:
            print(f"Warning rasterization '{raw}': {e}")
    return lm

def fit_or_load_pca(real_meta_list, pca_components, cache_dir, config_hash, fit_max_pixels=500_000):
    path = Path(cache_dir) / f"pca_{config_hash}.pkl"
    if path.exists():
        with open(path, "rb") as f:
            return pickle.load(f)
    pixels = []
    for meta in real_meta_list:
        try:
            cube, _ = _load_envi_cube(meta["hdr"], meta["source"])
            B, H, W = cube.shape
            n   = min(20_000, H * W)
            idx = np.random.choice(H * W, n, replace=False)
            pixels.append(cube.reshape(B, -1)[:, idx].T)
            del cube; gc.collect()
        except Exception as e:
            print(f"Warning {meta['name']}: {e}")
    pixels = np.concatenate(pixels)
    if len(pixels) > fit_max_pixels:
        pixels = pixels[np.random.choice(len(pixels), fit_max_pixels, replace=False)]
    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(pixels)
    del pixels; gc.collect()
    with open(path, "wb") as f:
        pickle.dump(pca, f, protocol=pickle.HIGHEST_PROTOCOL)
    return pca

def apply_pca_chunked(cube, pca, chunk=30_000):
    B, H, W = cube.shape
    flat = cube.reshape(B, -1).T
    out  = np.empty((H * W, pca.n_components_), dtype=np.float32)
    for s in range(0, len(flat), chunk):
        out[s:s + chunk] = pca.transform(flat[s:s + chunk])
    del flat
    return out.T.reshape(pca.n_components_, H, W).astype(np.float32)

def balance_background(labels, bg_idx, rng, bg_ratio=1.5):
    fg   = labels != bg_idx
    keep = fg.copy()
    n_fg = int(fg.sum())
    if n_fg > 0:
        bg_pool = np.where(~fg)[0]
        n_keep  = min(int(n_fg * bg_ratio), len(bg_pool))
        if n_keep > 0:
            keep[rng.choice(bg_pool, n_keep, replace=False)] = True
    return keep

def _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device):
    B, H, W = cube_pca.shape
    m       = patch_size // 2
    cube_t  = torch.from_numpy(cube_pca).to(device, non_blocking=True).unsqueeze(0)
    padded  = F.pad(cube_t, (m, m, m, m), mode="constant", value=0)
    del cube_t
    n_patches   = len(rows_k)
    all_patches = np.empty((n_patches, B, patch_size, patch_size), dtype=np.float32)
    for start in range(0, n_patches, PATCH_EXTRACT_BATCH):
        end    = min(start + PATCH_EXTRACT_BATCH, n_patches)
        rs, cs = rows_k[start:end], cols_k[start:end]
        batch  = torch.stack([padded[0, :, r:r+patch_size, c:c+patch_size]
                               for r, c in zip(rs, cs)])
        all_patches[start:end] = batch.cpu().numpy()
        del batch
    del padded; torch.cuda.empty_cache()
    return all_patches

def _gpu_worker(gpu_id, task_queue, h5_path, split_name, patch_size,
                extrude2final, label2idx, bg_ratio, random_state,
                pca, write_lock, counters):
    device = torch.device(f"cuda:{gpu_id}")
    bg_idx = label2idx["background"]
    while True:
        try:
            meta = task_queue.get(timeout=30)
        except queue.Empty:
            break
        if meta is None:
            task_queue.task_done(); break
        name, source = meta["name"], meta["source"]
        rng = np.random.default_rng(random_state + hash(name) % 10_000)
        try:
            cube_raw, _ = _load_envi_cube(meta["hdr"], source)
            if pca is not None:
                cube_pca = apply_pca_chunked(cube_raw, pca)
                del cube_raw; gc.collect()
            else:
                cube_pca = cube_raw
            B, H, W   = cube_pca.shape
            shapes    = _load_shapes(meta["jsn"])
            label_map = build_label_map(H, W, shapes, extrude2final, label2idx)
            r_all, c_all = np.where(label_map >= 0)
            labels_all   = label_map[r_all, c_all]
            del label_map
            keep     = balance_background(labels_all, bg_idx, rng, bg_ratio)
            rows_k   = r_all[keep].astype(np.int32)
            cols_k   = c_all[keep].astype(np.int32)
            labels_k = labels_all[keep].astype(np.int32)
            del r_all, c_all, labels_all, keep; gc.collect()
            if len(rows_k) == 0:
                del cube_pca; gc.collect()
                task_queue.task_done(); continue
            all_patches = _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device)
            del cube_pca; gc.collect()
            n_extracted = len(all_patches)
            with write_lock:
                with h5py.File(h5_path, 'a') as f:
                    dset_x = f[f"{split_name}/X"]
                    dset_y = f[f"{split_name}/y"]
                    cur    = dset_x.shape[0]
                    new_n  = cur + n_extracted
                    dset_x.resize((new_n, B, patch_size, patch_size))
                    dset_y.resize((new_n,))
                    dset_x[cur:new_n] = all_patches
                    dset_y[cur:new_n] = labels_k
            del all_patches, labels_k, rows_k, cols_k; gc.collect()
            with counters["lock"]:
                counters["patches"] += n_extracted
                counters["cubes"]   += 1
                done, total, ptch = counters["cubes"], counters["total"], counters["patches"]
                if done % 10 == 0 or done == total:
                    print(f"  GPU{gpu_id} | [{split_name}] {done}/{total} | {ptch:,} patches")
        except Exception as e:
            print(f"  GPU{gpu_id} | {name} : {e}")
        finally:
            task_queue.task_done(); torch.cuda.empty_cache()

def extract_split_to_hdf5(meta_list, split_name, patch_size, extrude2final,
                           label2idx, bg_ratio, random_state, pca, h5_path, balance_train=False):
    if not meta_list: return 0
    shuffled  = meta_list[:]
    random.shuffle(shuffled)
    num_bands = pca.n_components_ if pca is not None else \
                _load_envi_cube(shuffled[0]["hdr"], shuffled[0]["source"])[0].shape[0]
    with h5py.File(h5_path, 'a') as f:
        if split_name in f: del f[split_name]
        f.create_dataset(f"{split_name}/X",
                         shape=(0, num_bands, patch_size, patch_size),
                         maxshape=(None, num_bands, patch_size, patch_size),
                         dtype=np.float32,
                         chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size),
                         compression='lzf')
        f.create_dataset(f"{split_name}/y",
                         shape=(0,), maxshape=(None,),
                         dtype=np.int64, chunks=(4096,), compression='lzf')
    task_q     = queue.Queue(maxsize=PREFETCH_QUEUE_SIZE)
    counters   = {"cubes": 0, "patches": 0, "total": len(shuffled), "lock": threading.Lock()}
    write_lock = threading.Lock()
    workers    = []
    for gpu_id in range(NUM_GPUS):
        t = threading.Thread(target=_gpu_worker,
                             args=(gpu_id, task_q, h5_path, split_name, patch_size,
                                   extrude2final, label2idx, bg_ratio, random_state,
                                   pca, write_lock, counters), daemon=True)
        t.start(); workers.append(t)
    for meta in shuffled: task_q.put(meta)
    for _ in range(NUM_GPUS): task_q.put(None)
    for t in workers: t.join()
    total_patches = counters["patches"]
    if balance_train and split_name == "train" and total_patches > 0:
        total_patches = _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state)
    return total_patches

def _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state, read_chunk=50_000):
    with h5py.File(h5_path, 'r') as f:
        y_all = f[f"{split_name}/y"][:]
    by_label = defaultdict(list)
    for i, lbl in enumerate(y_all): by_label[int(lbl)].append(i)
    del y_all
    min_count = min(len(v) for v in by_label.values())
    rng = random.Random(random_state)
    kept_idx = []
    for lbl, idxs in sorted(by_label.items()):
        rng.shuffle(idxs); kept_idx.extend(idxs[:min_count])
    rng.shuffle(kept_idx)
    kept_idx    = np.array(kept_idx, dtype=np.int64)
    sorted_kept = kept_idx[np.argsort(kept_idx)]
    n_new = len(kept_idx)
    tmp   = f"{split_name}_tmp"
    with h5py.File(h5_path, 'a') as f:
        if tmp in f: del f[tmp]
        f.create_dataset(f"{tmp}/X",
                         shape=(n_new, num_bands, patch_size, patch_size),
                         dtype=np.float32,
                         chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size),
                         compression='lzf')
        f.create_dataset(f"{tmp}/y",
                         shape=(n_new,), dtype=np.int64, chunks=(4096,), compression='lzf')
    for cs in range(0, n_new, read_chunk):
        ce  = min(cs + read_chunk, n_new)
        idx = sorted_kept[cs:ce]
        with h5py.File(h5_path, 'r') as f:
            Xc = f[f"{split_name}/X"][idx]
            yc = f[f"{split_name}/y"][idx]
        with h5py.File(h5_path, 'a') as f:
            f[f"{tmp}/X"][cs:ce] = Xc
            f[f"{tmp}/y"][cs:ce] = yc
        del Xc, yc; gc.collect()
    with h5py.File(h5_path, 'a') as f:
        del f[split_name]; f.move(tmp, split_name)
    return n_new


class RamShardDataset(Dataset):
    """
    Chaque rank DDP charge uniquement sa fraction du dataset en RAM.

    Avec 4 ranks et 66M patches a 342 GB :
      rank 0 -> patches [0      .. 16.5M]  ~85 GB
      rank 1 -> patches [16.5M  .. 33M  ]  ~85 GB
      rank 2 -> patches [33M    .. 49.5M]  ~85 GB
      rank 3 -> patches [49.5M  .. 66M  ]  ~85 GB
    Total : 340 GB repartis, pas 4x340 GB.

    DistributedSampler n'est PAS utilise : chaque rank a deja
    sa propre portion du dataset, pas besoin de le re-partitionner.
    """
    def __init__(self, h5_path, split_name, rank, world_size,
                 max_ram_gb=80.0, shuffle=True, seed=0):
        import time as _t
        self.shuffle    = shuffle
        self.seed       = seed
        self.rank       = rank
        self.world_size = world_size

        with h5py.File(str(h5_path), 'r') as f:
            total       = int(f[f"{split_name}/y"].shape[0])
            x_shape     = tuple(f[f"{split_name}/X"].shape[1:])
            patch_bytes = int(np.prod(x_shape)) * 4

            shard_size  = math.ceil(total / world_size)
            start       = rank * shard_size
            end         = min(start + shard_size, total)

            max_patches = int(max_ram_gb * 1e9 / patch_bytes)
            end         = min(end, start + max_patches)

            n_load  = end - start
            gb_load = n_load * patch_bytes / 1e9
            pct     = n_load / total * 100

            if rank == 0:
                print(f"  RamShardDataset [{split_name}] : "
                      f"{world_size} ranks x ~{gb_load:.1f} GB = "
                      f"~{gb_load*world_size:.0f} GB total")

            print(f"    rank {rank} : patches [{start:,}..{end:,}] "
                  f"({n_load:,} patches — {gb_load:.1f} GB) ...")

            t0     = _t.perf_counter()
            self.X = f[f"{split_name}/X"][start:end]
            self.y = f[f"{split_name}/y"][start:end]
            print(f"    rank {rank} : charge en {_t.perf_counter()-t0:.1f}s")

        self.length = len(self.y)
        self._order = self._make_order(seed)

    def _make_order(self, seed):
        order = list(range(self.length))
        if self.shuffle:
            random.Random(seed + self.rank).shuffle(order)
        return order

    def reshuffle(self, epoch):
        random.Random(self.seed + self.rank + epoch * 1_000_003).shuffle(self._order)

    def __len__(self): return self.length

    def __getitem__(self, pos):
        idx = self._order[pos]
        X   = torch.from_numpy(self.X[idx].astype(np.float32)).unsqueeze(0)
        y   = int(self.y[idx])
        return X, torch.tensor(y, dtype=torch.long)


class SlabDataset(Dataset):
    """
    Lit le HDF5 par blocs contigus via registre PID.
    Utilise quand la RAM ne suffit pas pour RamShardDataset.
    Chaque rank recoit sa portion via DistributedSampler.
    """
    def __init__(self, h5_path, split_name, slab_size=512, shuffle=True, seed=0):
        self.h5_path    = str(h5_path)
        self.split_name = split_name
        self.slab_size  = slab_size
        self.shuffle    = shuffle
        self.seed       = seed
        with h5py.File(self.h5_path, 'r') as f:
            self.length  = int(f[f"{split_name}/y"].shape[0])
            self.x_shape = tuple(f[f"{split_name}/X"].shape[1:])
        self._order      = self._make_order(seed)
        self._slab_X     = None
        self._slab_y     = None
        self._slab_start = -1

    def _make_order(self, seed):
        n_slabs  = math.ceil(self.length / self.slab_size)
        slab_ids = list(range(n_slabs))
        if self.shuffle: random.Random(seed).shuffle(slab_ids)
        order = []
        for sid in slab_ids:
            s = sid * self.slab_size
            e = min(s + self.slab_size, self.length)
            order.extend(range(s, e))
        return order

    def reshuffle(self, epoch):
        self._order      = self._make_order(self.seed + epoch * 1_000_003)
        self._slab_start = -1
        self._slab_X     = None
        self._slab_y     = None

    def _load_slab(self, slab_start):
        slab_end         = min(slab_start + self.slab_size, self.length)
        f                = _get_h5(self.h5_path)
        self._slab_X     = f[f"{self.split_name}/X"][slab_start:slab_end]
        self._slab_y     = f[f"{self.split_name}/y"][slab_start:slab_end]
        self._slab_start = slab_start

    def __len__(self): return self.length

    def __getitem__(self, pos):
        real_idx   = self._order[pos]
        slab_start = (real_idx // self.slab_size) * self.slab_size
        if slab_start != self._slab_start:
            self._load_slab(slab_start)
        local = real_idx - self._slab_start
        X = torch.from_numpy(self._slab_X[local].astype(np.float32)).unsqueeze(0)
        y = int(self._slab_y[local])
        return X, torch.tensor(y, dtype=torch.long)


def worker_init_fn(worker_id):
    seed = (torch.initial_seed() + worker_id) % (2**32)
    np.random.seed(seed); random.seed(seed)

