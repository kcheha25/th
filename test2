    return p.parse_args()
def build_scheduler(optimizer, warmup, total):
    def lr_lambda(ep):
        if ep < warmup:
            return (ep + 1) / max(warmup, 1)
        prog = (ep - warmup) / max(total - warmup, 1)
        return 0.5 * (1.0 + math.cos(math.pi * prog))
    return LambdaLR(optimizer, lr_lambda)
def run_train_epoch(model, batch_iter, criterion, optimizer, device, use_amp, grad_accum, grad_clip, n_total, batch_size):
    model.train()
    total_loss = 0.0
    correct = 0
    total = 0
    optimizer.zero_grad(set_to_none=True)
    n_steps_est = math.ceil(n_total / batch_size)
    log_every = max(1, n_steps_est // 20)
    amp_ctx = torch.amp.autocast("cuda", enabled=use_amp, dtype=torch.bfloat16)
    for step, (X, y) in enumerate(batch_iter):
        X = X.to(device, non_blocking=True)
        y = y.to(device, non_blocking=True)
        with amp_ctx:
            logits = model(X)
            loss = criterion(logits, y)
            if grad_accum > 1:
                loss = loss / grad_accum
        loss.backward()
        is_update = (step + 1) % grad_accum == 0
        if is_update:
            if grad_clip > 0:
                nn.utils.clip_grad_norm_(model.parameters(), grad_clip)
            optimizer.step()
            optimizer.zero_grad(set_to_none=True)
        with torch.no_grad():
            bs = len(y)
            total_loss += loss.item() * (grad_accum if grad_accum > 1 else 1) * bs
            correct += (logits.argmax(1) == y).sum().item()
            total += bs
        if step % log_every == 0:
            print(f"    step {step:>6} | loss {total_loss/max(total,1):.4f} | acc {correct/max(total,1)*100:.2f}%", flush=True)
    remaining = total % grad_accum if grad_accum > 1 else 0
    if remaining:
        if grad_clip > 0:
            nn.utils.clip_grad_norm_(model.parameters(), grad_clip)
        optimizer.step()
        optimizer.zero_grad(set_to_none=True)
    return total_loss / max(total, 1), correct / max(total, 1)
def run_val_epoch(model, loader, criterion, device, use_amp):
    model.eval()
    total_loss = 0.0
    correct = 0
    total = 0
    amp_ctx = torch.amp.autocast("cuda", enabled=use_amp, dtype=torch.bfloat16)
    with torch.no_grad():
        for X, y in loader:
            X = X.to(device, non_blocking=True)
            y = y.to(device, non_blocking=True)
            with amp_ctx:
                logits = model(X)
                loss = criterion(logits, y)
            total_loss += loss.item() * len(y)
            correct += (logits.argmax(1) == y).sum().item()
            total += len(y)
    return total_loss / max(total, 1), correct / max(total, 1)
def evaluate_metrics(model, loader, device, use_amp, class_names):
    model.eval()
    all_pred, all_true = [], []
    amp_ctx = torch.amp.autocast("cuda", enabled=use_amp, dtype=torch.bfloat16)
    with torch.no_grad():
        for X, y in loader:
            X = X.to(device, non_blocking=True)
            with amp_ctx:
                logits = model(X)
            all_pred.extend(logits.argmax(1).cpu().numpy())
            all_true.extend(y.numpy())
    all_pred = np.array(all_pred)
    all_true = np.array(all_true)
    oa = accuracy_score(all_true, all_pred) * 100
    kappa = cohen_kappa_score(all_true, all_pred) * 100
    cm = confusion_matrix(all_true, all_pred)
    per_cls = np.diag(cm) / np.maximum(cm.sum(axis=1), 1) * 100
    aa = per_cls.mean()
    return oa, aa, kappa, cm, per_cls
def save_ckpt(path, epoch, model, optimizer, scheduler, val_acc):
    raw = model.module if hasattr(model, "module") else model
    torch.save({"epoch": epoch, "val_acc": val_acc, "model": raw.state_dict(), "optimizer": optimizer.state_dict(), "scheduler": scheduler.state_dict()}, path)
def load_ckpt(path, model, optimizer, scheduler, device):
    ckpt = torch.load(path, map_location=device)
    raw = model.module if hasattr(model, "module") else model
    raw.load_state_dict(ckpt["model"])
    optimizer.load_state_dict(ckpt["optimizer"])
    scheduler.load_state_dict(ckpt["scheduler"])
    return ckpt["epoch"], ckpt["val_acc"]
def main():
    args = parse_args()
    if not args.real_dir and not args.aug_dir:
        raise ValueError("Fournir --real_dir ou --aug_dir")
    n_gpus = torch.cuda.device_count()
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    torch.backends.cudnn.benchmark = True
    torch.backends.cuda.matmul.allow_tf32 = True
    torch.backends.cudnn.allow_tf32 = True
    print(f"\n{'='*65}")
    print(f"  OS={platform.system()}  GPUs={n_gpus}  device={device}")
    print(f"  AMP bfloat16={args.amp}  batch={args.batch_size}")
    print(f"  RAM/chunk={args.ram_budget_gb} GB  workers={args.num_workers}")
    print(f"{'='*65}\n")
    train_epoch_fn, val_loader, test_loader, meta, n_train = build_loaders(real_dir=args.real_dir, aug_dir=args.aug_dir, mapping_path=args.mapping_path, split_mode=args.split_mode, use_pca=args.use_pca, pca_components=args.pca_components, patch_size=args.patch_size, test_ratio=args.test_ratio, val_ratio=args.val_ratio, batch_size=args.batch_size, random_state=args.random_state, fit_max_pixels=args.fit_max_pixels, num_workers=args.num_workers, bg_ratio=args.bg_ratio, cache_dir=args.cache_dir, balance_train=args.balance_train, ram_budget_gb=args.ram_budget_gb)
    print(f"\n  Train : {n_train:,} patches")
    print(f"  Classes ({meta['num_classes']}) : {meta['class_names']}")
    print(f"  Bands  : {meta['num_bands']}  Patch : {meta['patch_size']}x{meta['patch_size']}\n")
    model = SSFTTnet(in_channels=1, num_classes=meta["num_classes"], num_tokens=args.num_tokens, dim=args.dim, depth=args.depth, heads=args.heads, mlp_dim=args.mlp_dim, dropout=args.dropout, emb_dropout=args.emb_dropout).to(device)
    if n_gpus > 1:
        model = nn.DataParallel(model)
        print(f"  DataParallel sur {n_gpus} GPUs")
    if args.compile and hasattr(torch, "compile"):
        model = torch.compile(model, mode="max-autotune")
        print("  torch.compile activé")
    n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"  Paramètres : {n_params:,}\n")
    criterion = nn.CrossEntropyLoss(label_smoothing=args.label_smooth)
    optimizer = AdamW(model.parameters(), lr=args.lr, weight_decay=args.weight_decay)
    scheduler = build_scheduler(optimizer, args.warmup_epochs, args.epochs)
    start_epoch = 1
    best_val_acc = 0.0
    patience_cnt = 0
    ckpt_dir = Path(args.checkpoint_dir)
    ckpt_dir.mkdir(parents=True, exist_ok=True)
    if args.resume and Path(args.resume).exists():
        start_epoch, best_val_acc = load_ckpt(args.resume, model, optimizer, scheduler, device)
        start_epoch += 1
        print(f"  Reprise époque {start_epoch}  (meilleure val={best_val_acc*100:.2f}%)")
    print(f"{'='*65}")
    print(f"  Début entraînement — {args.epochs} époques max")
    print(f"{'='*65}\n")
    for epoch in range(start_epoch, args.epochs + 1):
        t0 = time.perf_counter()
        print(f"\n── Époque {epoch:03d}/{args.epochs} ──────────────────────────")
        tr_loss, tr_acc = run_train_epoch(model, batch_iter=train_epoch_fn(epoch=epoch), criterion=criterion, optimizer=optimizer, device=device, use_amp=args.amp, grad_accum=args.grad_accum, grad_clip=args.grad_clip, n_total=n_train, batch_size=args.batch_size)
        va_loss, va_acc = run_val_epoch(model, val_loader, criterion, device, args.amp)
        scheduler.step()
        elapsed = time.perf_counter() - t0
        lr_now = optimizer.param_groups[0]["lr"]
        print(f"\n  Ep {epoch:03d}  tr {tr_loss:.4f}/{tr_acc*100:.2f}%  va {va_loss:.4f}/{va_acc*100:.2f}%  lr {lr_now:.2e}  ({elapsed:.0f}s)", flush=True)
        if epoch % args.save_every == 0:
            save_ckpt(ckpt_dir / f"ckpt_ep{epoch:03d}.pt", epoch, model, optimizer, scheduler, va_acc)
        if va_acc > best_val_acc:
            best_val_acc = va_acc
            patience_cnt = 0
            save_ckpt(ckpt_dir / "best_model.pt", epoch, model, optimizer, scheduler, va_acc)
            print(f"  ✓ Nouveau meilleur modèle (val={va_acc*100:.2f}%)")
        else:
            patience_cnt += 1
            if patience_cnt >= args.patience:
                print(f"\n  Early stopping (patience={args.patience})")
                break
    print(f"\n{'='*65}")
    print("  Chargement du meilleur modèle…")
    ckpt = torch.load(ckpt_dir / "best_model.pt", map_location=device)
    raw = model.module if hasattr(model, "module") else model
    raw.load_state_dict(ckpt["model"])
    oa, aa, kappa, cm, per_cls = evaluate_metrics(model, test_loader, device, args.amp, meta["class_names"])
    print(f"\n  OA={oa:.2f}%  AA={aa:.2f}%  Kappa={kappa:.2f}%\n")
    print("  Précision par classe :")
    for name, acc in zip(meta["class_names"], per_cls):
        print(f"    {name:<30} {acc:.2f}%")
    print(f"{'='*65}\n")
if __name__ == "__main__":
    main()





import gc
import json
import random
import re
import pickle
import hashlib
import threading
import queue
from collections import defaultdict
from pathlib import Path
from datetime import datetime
import numpy as np
import torch
import torch.nn.functional as F
from sklearn.decomposition import PCA
from spectral import envi
from torch.utils.data import DataLoader, Dataset
import h5py
NUM_GPUS = max(1, torch.cuda.device_count())
PATCH_EXTRACT_BATCH = 8192
PREFETCH_QUEUE_SIZE = 4
HDF5_CHUNK_PATCHES = 256
def load_mapping(mapping_path):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names = final_classes + ["background"]
    label2idx = {name: i for i, name in enumerate(class_names)}
    return extrude2final, class_names, label2idx
def _load_envi_cube(hdr_path, source):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wl = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3:
        if source == "real" and wl and cube.shape[2] == len(wl):
            cube = cube.transpose(2, 0, 1)
        elif source != "real" and wl and cube.shape[1] == len(wl):
            cube = cube.transpose(1, 0, 2)
    if cube.ndim != 3:
        raise ValueError(f"Cube invalide : {cube.shape}")
    return cube, wl
def _load_shapes(json_path):
    with open(json_path) as f:
        return json.load(f).get("shapes", [])
def collect_plots_meta(real_dir=None, aug_dir=None):
    meta_list = []
    if real_dir:
        real_dir = Path(real_dir)
        for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
            m = re.match(r"plot_(\d+)_cube", hdr.stem)
            if not m:
                continue
            jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
            if jsn.exists():
                meta_list.append({"source": "real", "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if aug_dir:
        aug_dir = Path(aug_dir)
        for hdr in sorted(aug_dir.glob("*.hdr")):
            if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")):
                continue
            jsn = aug_dir / f"{hdr.stem}.json"
            if not jsn.exists():
                continue
            source = "circle" if "circle" in hdr.stem.lower() else "aug"
            meta_list.append({"source": source, "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if not meta_list:
        raise RuntimeError("Aucun plot trouvé.")
    return meta_list
def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15, test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        train, val, test = aug[n_val:], aug[:n_val], real
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test = max(1, int(n * test_ratio))
        n_val = max(1, int(n * val_ratio))
        test = all_p[:n_test]
        val = all_p[n_test:n_test + n_val]
        train = all_p[n_test + n_val:]
    else:
        raise ValueError(f"split_mode inconnu : {split_mode}")
    return train, val, test
def _rasterize_cpu(points, H, W):
    pts = np.array(points, dtype=np.float32)
    n = len(pts)
    cols = np.arange(W, dtype=np.float32) + 0.5
    rows = np.arange(H, dtype=np.float32) + 0.5
    gc_, gr_ = np.meshgrid(cols, rows)
    px, py = gc_.ravel(), gr_.ravel()
    inside = np.zeros(len(px), dtype=bool)
    x1, y1 = pts[:, 0], pts[:, 1]
    x2, y2 = np.roll(x1, -1), np.roll(y1, -1)
    for i in range(n):
        dy = y2[i] - y1[i]
        if abs(dy) < 1e-10:
            continue
        cond = (y1[i] < py) != (y2[i] < py)
        xi = x1[i] + (py - y1[i]) * (x2[i] - x1[i]) / dy
        inside ^= cond & (px < xi)
    return inside.reshape(H, W)
def build_label_map(H, W, shapes, extrude2final, label2idx):
    bg = label2idx["background"]
    lm = np.full((H, W), bg, dtype=np.int32)
    for shape in shapes:
        raw = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw.lower() == "trou" or stype not in ("polygon", "rectangle"):
            continue
        final = extrude2final.get(raw)
        if final is None:
            continue
        pts = shape["points"]
        if len(pts) < 3:
            continue
        try:
            lm[_rasterize_cpu(pts, H, W)] = label2idx[final]
        except Exception as e:
            print(f"Warning rasterisation '{raw}': {e}")
    return lm
def fit_or_load_pca(real_meta_list, pca_components, cache_dir, config_hash, fit_max_pixels=500_000):
    path = Path(cache_dir) / f"pca_{config_hash}.pkl"
    if path.exists():
        with open(path, "rb") as f:
            return pickle.load(f)
    pixels = []
    for meta in real_meta_list:
        try:
            cube, _ = _load_envi_cube(meta["hdr"], meta["source"])
            B, H, W = cube.shape
            n = min(20_000, H * W)
            idx = np.random.choice(H * W, n, replace=False)
            pixels.append(cube.reshape(B, -1)[:, idx].T)
            del cube
            gc.collect()
        except Exception as e:
            print(f"Warning {meta['name']}: {e}")
    pixels = np.concatenate(pixels)
    if len(pixels) > fit_max_pixels:
        pixels = pixels[np.random.choice(len(pixels), fit_max_pixels, replace=False)]
    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(pixels)
    del pixels
    gc.collect()
    with open(path, "wb") as f:
        pickle.dump(pca, f, protocol=pickle.HIGHEST_PROTOCOL)
    return pca
def apply_pca_chunked(cube, pca, chunk=30_000):
    B, H, W = cube.shape
    flat = cube.reshape(B, -1).T
    out = np.empty((H * W, pca.n_components_), dtype=np.float32)
    for s in range(0, len(flat), chunk):
        out[s:s + chunk] = pca.transform(flat[s:s + chunk])
    del flat
    return out.T.reshape(pca.n_components_, H, W).astype(np.float32)
def balance_background(labels, bg_idx, rng, bg_ratio=1.5):
    fg = labels != bg_idx
    keep = fg.copy()
    n_fg = int(fg.sum())
    if n_fg > 0:
        bg_pool = np.where(~fg)[0]
        n_keep = min(int(n_fg * bg_ratio), len(bg_pool))
        if n_keep > 0:
            keep[rng.choice(bg_pool, n_keep, replace=False)] = True
    return keep
def _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device):
    B, H, W = cube_pca.shape
    m = patch_size // 2
    cube_t = torch.from_numpy(cube_pca).to(device, non_blocking=True).unsqueeze(0)
    padded = F.pad(cube_t, (m, m, m, m), mode="constant", value=0)
    del cube_t
    n_patches = len(rows_k)
    all_patches = np.empty((n_patches, B, patch_size, patch_size), dtype=np.float32)
    for start in range(0, n_patches, PATCH_EXTRACT_BATCH):
        end = min(start + PATCH_EXTRACT_BATCH, n_patches)
        rs = rows_k[start:end]
        cs = cols_k[start:end]
        batch = torch.stack([padded[0, :, r:r + patch_size, c:c + patch_size] for r, c in zip(rs, cs)])
        all_patches[start:end] = batch.cpu().numpy()
        del batch
    del padded
    torch.cuda.empty_cache()
    return all_patches
def _gpu_worker(gpu_id, task_queue, h5_path, split_name, patch_size, extrude2final, label2idx, bg_ratio, random_state, pca, write_lock, counters):
    device = torch.device(f"cuda:{gpu_id}")
    bg_idx = label2idx["background"]
    while True:
        try:
            meta = task_queue.get(timeout=30)
        except queue.Empty:
            break
        if meta is None:
            task_queue.task_done()
            break
        name = meta["name"]
        source = meta["source"]
        rng = np.random.default_rng(random_state + hash(name) % 10_000)
        try:
            cube_raw, _ = _load_envi_cube(meta["hdr"], source)
            if pca is not None:
                cube_pca = apply_pca_chunked(cube_raw, pca)
                del cube_raw
                gc.collect()
            else:
                cube_pca = cube_raw
            B, H, W = cube_pca.shape
            shapes = _load_shapes(meta["jsn"])
            label_map = build_label_map(H, W, shapes, extrude2final, label2idx)
            r_all, c_all = np.where(label_map >= 0)
            labels_all = label_map[r_all, c_all]
            del label_map
            keep = balance_background(labels_all, bg_idx, rng, bg_ratio)
            rows_k = r_all[keep].astype(np.int32)
            cols_k = c_all[keep].astype(np.int32)
            labels_k = labels_all[keep].astype(np.int32)
            del r_all, c_all, labels_all, keep
            gc.collect()
            if len(rows_k) == 0:
                del cube_pca
                gc.collect()
                task_queue.task_done()
                continue
            all_patches = _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device)
            del cube_pca
            gc.collect()
            n_extracted = len(all_patches)
            with write_lock:
                with h5py.File(h5_path, 'a') as f:
                    dset_x = f[f"{split_name}/X"]
                    dset_y = f[f"{split_name}/y"]
                    cur = dset_x.shape[0]
                    new_n = cur + n_extracted
                    dset_x.resize((new_n, B, patch_size, patch_size))
                    dset_y.resize((new_n,))
                    dset_x[cur:new_n] = all_patches
                    dset_y[cur:new_n] = labels_k
            del all_patches, labels_k, rows_k, cols_k
            gc.collect()
            with counters["lock"]:
                counters["patches"] += n_extracted
                counters["cubes"] += 1
                done = counters["cubes"]
                total = counters["total"]
                ptch = counters["patches"]
                if done % 10 == 0 or done == total:
                    print(f"  GPU{gpu_id} | [{split_name}] {done}/{total} cubes | {ptch:,} patches | VRAM {torch.cuda.memory_allocated(device)/1e9:.2f} GB")
        except Exception as e:
            print(f"  GPU{gpu_id} | {name} : {e}")
        finally:
            task_queue.task_done()
            torch.cuda.empty_cache()
def extract_split_to_hdf5(meta_list, split_name, patch_size, extrude2final, label2idx, bg_ratio, random_state, pca, h5_path, balance_train=False):
    if not meta_list:
        return 0
    shuffled = meta_list[:]
    random.shuffle(shuffled)
    if pca is not None:
        num_bands = pca.n_components_
    else:
        tmp, _ = _load_envi_cube(shuffled[0]["hdr"], shuffled[0]["source"])
        num_bands = tmp.shape[0]
        del tmp
        gc.collect()
    with h5py.File(h5_path, 'a') as f:
        if split_name in f:
            del f[split_name]
        f.create_dataset(f"{split_name}/X", shape=(0, num_bands, patch_size, patch_size), maxshape=(None, num_bands, patch_size, patch_size), dtype=np.float32, chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size), compression='lzf')
        f.create_dataset(f"{split_name}/y", shape=(0,), maxshape=(None,), dtype=np.int64, chunks=(4096,), compression='lzf')
    task_q = queue.Queue(maxsize=PREFETCH_QUEUE_SIZE)
    counters = {"cubes": 0, "patches": 0, "total": len(shuffled), "lock": threading.Lock()}
    write_lock = threading.Lock()
    workers = []
    for gpu_id in range(NUM_GPUS):
        t = threading.Thread(target=_gpu_worker, args=(gpu_id, task_q, h5_path, split_name, patch_size, extrude2final, label2idx, bg_ratio, random_state, pca, write_lock, counters), daemon=True)
        t.start()
        workers.append(t)
    for meta in shuffled:
        task_q.put(meta)
    for _ in range(NUM_GPUS):
        task_q.put(None)
    for t in workers:
        t.join()
    total_patches = counters["patches"]
    if balance_train and split_name == "train" and total_patches > 0:
        total_patches = _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state)
    return total_patches
def _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state, read_chunk=50_000):
    with h5py.File(h5_path, 'r') as f:
        y_all = f[f"{split_name}/y"][:]
    by_label = defaultdict(list)
    for i, lbl in enumerate(y_all):
        by_label[int(lbl)].append(i)
    del y_all
    min_count = min(len(v) for v in by_label.values())
    rng = random.Random(random_state)
    kept_idx = []
    for lbl, idxs in sorted(by_label.items()):
        rng.shuffle(idxs)
        kept_idx.extend(idxs[:min_count])
    rng.shuffle(kept_idx)
    kept_idx = np.array(kept_idx, dtype=np.int64)
    sort_order = np.argsort(kept_idx)
    sorted_kept = kept_idx[sort_order]
    n_new = len(kept_idx)
    tmp_split = f"{split_name}_tmp"
    with h5py.File(h5_path, 'a') as f:
        if tmp_split in f:
            del f[tmp_split]
        f.create_dataset(f"{tmp_split}/X", shape=(n_new, num_bands, patch_size, patch_size), dtype=np.float32, chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size), compression='lzf')
        f.create_dataset(f"{tmp_split}/y", shape=(n_new,), dtype=np.int64, chunks=(4096,), compression='lzf')
    written = 0
    for chunk_start in range(0, n_new, read_chunk):
        chunk_end = min(chunk_start + read_chunk, n_new)
        chunk_idx = sorted_kept[chunk_start:chunk_end]
        with h5py.File(h5_path, 'r') as f:
            X_chunk = f[f"{split_name}/X"][chunk_idx]
            y_chunk = f[f"{split_name}/y"][chunk_idx]
        with h5py.File(h5_path, 'a') as f:
            f[f"{tmp_split}/X"][chunk_start:chunk_end] = X_chunk
            f[f"{tmp_split}/y"][chunk_start:chunk_end] = y_chunk
        written += len(chunk_idx)
        del X_chunk, y_chunk
        gc.collect()
    with h5py.File(h5_path, 'a') as f:
        del f[split_name]
        f.move(tmp_split, split_name)
    return n_new
class HDF5DatasetRAM(Dataset):
    def __init__(self, h5_path, split_name):
        import time
        self.split_name = split_name
        with h5py.File(h5_path, 'r') as f:
            self.length = f[f"{split_name}/y"].shape[0]
            print(f"  [{split_name}] chargement {self.length:,} patches en RAM...", flush=True)
            t0 = time.time()
            X_np = f[f"{split_name}/X"][:]
            y_np = f[f"{split_name}/y"][:]
        self._X = torch.from_numpy(X_np.astype(np.float32)).share_memory_()
        self._y = torch.from_numpy(y_np.astype(np.int64)).share_memory_()
        del X_np, y_np
        gc.collect()
        print(f"  [{split_name}] OK en {time.time()-t0:.1f}s ({self._X.nbytes/1e9:.1f} GB)", flush=True)
    def __len__(self):
        return self.length
    def __getitem__(self, idx):
        return self._X[idx].unsqueeze(0), self._y[idx]
class _ChunkDataset(Dataset):
    def __init__(self, X: torch.Tensor, y: torch.Tensor):
        self.X = X
        self.y = y
    def __len__(self):
        return len(self.y)
    def __getitem__(self, i):
        return self.X[i].unsqueeze(0), self.y[i]
def make_chunked_train_loader(h5_path: str, batch_size: int, num_workers: int, ram_budget_gb: float = 150.0, seed: int = 42):
    with h5py.File(h5_path, 'r') as f:
        shape = f["train/X"].shape
        n_total = shape[0]
        n_bands = shape[1]
        patch_sz = shape[2]
    patch_bytes = int(n_bands) * int(patch_sz) * int(patch_sz) * 4
    chunk_size = int((ram_budget_gb * 1e9) / patch_bytes)
    chunk_size = max(1, min(chunk_size, n_total))
    n_chunks = int(np.ceil(n_total / chunk_size))
    print(f"\n  [train] {n_total:,} patches | chunk={chunk_size:,} ({ram_budget_gb:.0f} GB RAM) | {n_chunks} chunks/époque", flush=True)
    def _read_chunk(sorted_idx: np.ndarray):
        with h5py.File(h5_path, 'r', swmr=True) as f:
            X = f["train/X"][sorted_idx]
            y = f["train/y"][sorted_idx]
        return (torch.from_numpy(X.astype(np.float32)).share_memory_(), torch.from_numpy(y.astype(np.int64)).share_memory_())
    def epoch_loader(epoch: int = 0):
        rng = np.random.default_rng(seed + epoch)
        global_idx = rng.permutation(n_total).astype(np.int64)
        chunk_slices = [np.sort(global_idx[s:s + chunk_size]) for s in range(0, n_total, chunk_size)]
        pin = torch.cuda.is_available()
        pq = queue.Queue(maxsize=1)
        def _prefetch(idx_arr):
            try:
                pq.put(_read_chunk(idx_arr))
            except Exception as e:
                pq.put(e)
        t = threading.Thread(target=_prefetch, args=(chunk_slices[0],), daemon=True)
        t.start()
        for ci, slc in enumerate(chunk_slices):
            result = pq.get()
            if isinstance(result, Exception):
                raise result
            X_buf, y_buf = result
            if ci + 1 < n_chunks:
                t = threading.Thread(target=_prefetch, args=(chunk_slices[ci + 1],), daemon=True)
                t.start()
            perm = torch.randperm(len(y_buf), generator=torch.Generator().manual_seed(int(seed + epoch * 1000 + ci)))
            ds = _ChunkDataset(X_buf[perm], y_buf[perm])
            loader = DataLoader(ds, batch_size=batch_size, shuffle=False, num_workers=num_workers, pin_memory=pin, persistent_workers=(num_workers > 0), prefetch_factor=4 if num_workers > 0 else None, worker_init_fn=worker_init_fn)
            yield from loader
            del X_buf, y_buf, ds, loader
            gc.collect()
    return epoch_loader, n_total
def worker_init_fn(worker_id):
    seed = (torch.initial_seed() + worker_id) % (2 ** 32)
    np.random.seed(seed)
    random.seed(seed)
def build_loaders(real_dir=None, aug_dir=None, mapping_path="mapping.json", split_mode="aug_real", use_pca=True, pca_components=30, patch_size=13, test_ratio=0.15, val_ratio=0.15, batch_size=2048, random_state=345, fit_max_pixels=500_000, num_workers=6, bg_ratio=1.5, cache_dir="cache", force_recompute=False, balance_train=False, ram_budget_gb=150.0):
    extrude2final, class_names, label2idx = load_mapping(mapping_path)
    cache_dir = Path(cache_dir)
    cache_dir.mkdir(parents=True, exist_ok=True)
    config_str = f"{real_dir}_{aug_dir}_{split_mode}_{patch_size}_{random_state}_{bg_ratio}_{pca_components if use_pca else 0}_{balance_train}"
    config_hash = hashlib.md5(config_str.encode()).hexdigest()[:12]
    h5_path = cache_dir / f"patches_{config_hash}.h5"
    if not force_recompute and h5_path.exists():
        print(f"  Cache trouvé : {h5_path}", flush=True)
    else:
        plots_meta = collect_plots_meta(real_dir=real_dir, aug_dir=aug_dir)
        train_meta, val_meta, test_meta = split_plots(plots_meta, split_mode, val_ratio, test_ratio, random_state)
        pca_model = None
        if use_pca:
            real_meta = [m for m in plots_meta if m["source"] == "real"]
            if real_meta:
                pca_model = fit_or_load_pca(real_meta, pca_components, cache_dir, config_hash, fit_max_pixels)
        for meta_list, sname, do_balance in [(train_meta, "train", balance_train), (val_meta, "val", False), (test_meta, "test", False)]:
            extract_split_to_hdf5(meta_list, sname, patch_size, extrude2final, label2idx, bg_ratio, random_state, pca_model, str(h5_path), balance_train=do_balance)
        with h5py.File(h5_path, 'a') as f:
            f.attrs['class_names'] = json.dumps(class_names)
            f.attrs['label2idx'] = json.dumps(label2idx)
            f.attrs['patch_size'] = patch_size
            f.attrs['num_bands'] = pca_components if use_pca else -1
            f.attrs['created_at'] = datetime.now().isoformat()
    with h5py.File(h5_path, 'r') as f:
        num_bands = f['train/X'].shape[1]
    train_epoch_fn, n_train = make_chunked_train_loader(str(h5_path), batch_size, num_workers, ram_budget_gb=ram_budget_gb, seed=random_state)
    pin = torch.cuda.is_available()
    kw = dict(num_workers=num_workers, pin_memory=pin, worker_init_fn=worker_init_fn, persistent_workers=(num_workers > 0), prefetch_factor=4 if num_workers > 0 else None)
    val_ds = HDF5DatasetRAM(str(h5_path), 'val')
    test_ds = HDF5DatasetRAM(str(h5_path), 'test')
    val_loader = DataLoader(val_ds, batch_size=batch_size, shuffle=False, **kw)
    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, **kw)
    meta = {"class_names": class_names, "label2idx": label2idx, "num_classes": len(class_names), "num_bands": num_bands, "patch_size": patch_size, "balance_train": balance_train, "h5_path": str(h5_path)}
    return train_epoch_fn, val_loader, test_loader, meta, n_train
