def _make_loaders(h5_path, class_names, label2idx, patch_size,
                  balance_train, batch_size, num_workers,
                  slab_size, rank, world_size, server, cfg, ram_cache_gb):

    is_win = server["is_windows"]
    use_ram = ram_cache_gb >= 10.0

    if use_ram:
        train_ds = RamShardDataset(str(h5_path), 'train',
                                   rank=rank, world_size=world_size,
                                   max_ram_gb=ram_cache_gb,
                                   shuffle=True, seed=42)
        val_gb   = min(ram_cache_gb * 0.15, 30.0)
        test_gb  = min(ram_cache_gb * 0.15, 30.0)
        val_ds   = RamShardDataset(str(h5_path), 'val',
                                   rank=rank, world_size=world_size,
                                   max_ram_gb=val_gb,
                                   shuffle=False, seed=0)
        test_ds  = RamShardDataset(str(h5_path), 'test',
                                   rank=rank, world_size=world_size,
                                   max_ram_gb=test_gb,
                                   shuffle=False, seed=0)
        train_sampler = None
        val_sampler   = None
        test_sampler  = None
        shuffle_train = False
    else:
        train_ds = SlabDataset(str(h5_path), 'train', slab_size=slab_size, shuffle=True,  seed=42)
        val_ds   = SlabDataset(str(h5_path), 'val',   slab_size=slab_size, shuffle=False, seed=0)
        test_ds  = SlabDataset(str(h5_path), 'test',  slab_size=slab_size, shuffle=False, seed=0)
        if world_size > 1:
            train_sampler = DistributedSampler(train_ds, num_replicas=world_size, rank=rank, shuffle=False)
            val_sampler   = DistributedSampler(val_ds,   num_replicas=world_size, rank=rank, shuffle=False)
            test_sampler  = DistributedSampler(test_ds,  num_replicas=world_size, rank=rank, shuffle=False)
        else:
            train_sampler = val_sampler = test_sampler = None
        shuffle_train = False

    with h5py.File(h5_path, 'r') as f:
        num_bands = int(f['train/X'].shape[1])

    pin    = torch.cuda.is_available()
    mp_ctx = cfg["mp_ctx"]
    pf     = cfg["prefetch"] if num_workers > 0 else None

    kw = dict(
        num_workers        = num_workers,
        pin_memory         = pin,
        worker_init_fn     = worker_init_fn,
        persistent_workers = (num_workers > 0),
        prefetch_factor    = pf,
    )
    if mp_ctx is not None:
        kw["multiprocessing_context"] = mp_ctx

    train_loader = DataLoader(train_ds, batch_size=batch_size,
                              sampler=train_sampler, shuffle=shuffle_train,
                              drop_last=True, **kw)
    val_loader   = DataLoader(val_ds,   batch_size=batch_size * 2,
                              sampler=val_sampler,   shuffle=False, **kw)
    test_loader  = DataLoader(test_ds,  batch_size=batch_size * 2,
                              sampler=test_sampler,  shuffle=False, **kw)

    if rank == 0:
        print(f"\n  DataLoaders prets :")
        print(f"    mode         : {'RamShard' if use_ram else 'Slab'}")
        print(f"    batch/GPU    : {batch_size}  workers/GPU : {num_workers}")
        print(f"    Train/rank   : {len(train_ds):,}  Steps/epoch : {len(train_loader)}")
        print(f"    Val/rank     : {len(val_ds):,}")

    meta = {
        "class_names":   class_names,
        "label2idx":     label2idx,
        "num_classes":   len(class_names),
        "num_bands":     num_bands,
        "patch_size":    patch_size,
        "balance_train": balance_train,
        "train_sampler": train_sampler,
        "server":        server,
        "auto_cfg":      cfg,
    }
    return train_loader, val_loader, test_loader, meta

