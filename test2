class ModelEMA:
    def __init__(self,model,decay=0.9998):
        self.decay=decay
        self.shadow={k:v.detach().clone().cpu() for k,v in model.state_dict().items()}

    @torch.no_grad()
    def update(self,model):
        m=model.module if hasattr(model,"module") else model
        for k,v in m.state_dict().items():
            self.shadow[k].mul_(self.decay).add_(v.detach().cpu(),alpha=1-self.decay)

    def apply_to(self,model):
        m=model.module if hasattr(model,"module") else model
        dev=next(m.parameters()).device
        m.load_state_dict({k:v.to(dev) for k,v in self.shadow.items()})

    def state_dict(self): return self.shadow
    def load_state_dict(self,sd): self.shadow=sd

def build_scheduler(optimizer,warmup,total):
    def lr_lambda(ep):
        if ep<warmup:
            return (ep+1)/max(warmup,1)
        p=(ep-warmup)/max(total-warmup,1)
        return 0.5*(1.0+math.cos(math.pi*p))
    return LambdaLR(optimizer,lr_lambda)

def run_epoch(model,loader,criterion,optimizer,scaler,device,use_amp,grad_accum,grad_clip,train,ema=None):
    model.train() if train else model.eval()
    total_loss=0.0
    correct=0
    total=0
    optimizer.zero_grad(set_to_none=True)
    for step,(X,y) in enumerate(loader):
        X=X.to(device,non_blocking=True)
        y=y.to(device,non_blocking=True)
        is_last=(step+1)%grad_accum==0 or (step+1)==len(loader)
        with autocast(enabled=use_amp):
            logits=model(X)
            loss=criterion(logits,y)
            if grad_accum>1:
                loss=loss/grad_accum
        if train:
            scaler.scale(loss).backward()
        if train and is_last:
            if grad_clip>0:
                scaler.unscale_(optimizer)
                nn.utils.clip_grad_norm_(model.parameters(),grad_clip)
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad(set_to_none=True)
            if ema is not None:
                ema.update(model)
        with torch.no_grad():
            total_loss+=loss.detach().item()*(grad_accum if train else 1)*len(y)
            correct+=(logits.detach().argmax(1)==y).sum().item()
            total+=len(y)
    return total_loss/total,correct/total

def save_ckpt(path,epoch,model,optimizer,scheduler,scaler,ema,val_acc):
    raw=model.module if hasattr(model,"module") else model
    obj={"epoch":epoch,"val_acc":val_acc,"model":raw.state_dict(),
         "optimizer":optimizer.state_dict(),"scheduler":scheduler.state_dict(),
         "scaler":scaler.state_dict()}
    if ema is not None:
        obj["ema"]=ema.state_dict()
    torch.save(obj,path)

def load_ckpt(path,model,optimizer,scheduler,scaler,ema,device):
    ckpt=torch.load(path,map_location=device)
    raw=model.module if hasattr(model,"module") else model
    raw.load_state_dict(ckpt["model"])
    optimizer.load_state_dict(ckpt["optimizer"])
    scheduler.load_state_dict(ckpt["scheduler"])
    scaler.load_state_dict(ckpt["scaler"])
    if ema is not None and "ema" in ckpt:
        ema.load_state_dict(ckpt["ema"])
    return ckpt["epoch"],ckpt["val_acc"]

def evaluate_metrics(model,loader,device,use_amp,class_names):
    model.eval()
    all_pred,all_true=[],[]
    with torch.no_grad():
        for X,y in loader:
            X=X.to(device,non_blocking=True)
            with autocast(enabled=use_amp):
                logits=model(X)
            all_pred.extend(logits.argmax(1).cpu().numpy())
            all_true.extend(y.numpy())
    all_pred=np.array(all_pred)
    all_true=np.array(all_true)
    oa=accuracy_score(all_true,all_pred)*100
    kappa=cohen_kappa_score(all_true,all_pred)*100
    cm=confusion_matrix(all_true,all_pred)
    per_cls=np.diag(cm)/np.maximum(cm.sum(axis=1),1)*100
    aa=per_cls.mean()
    return oa,aa,kappa,cm,per_cls

def main():
    args=parse_args()
    if not args.real_dir and not args.aug_dir:
        raise ValueError("Fournir --real_dir ou --aug_dir")
    n_gpus=torch.cuda.device_count()
    device=torch.device("cuda" if torch.cuda.is_available() else "cpu")
    torch.backends.cudnn.benchmark=True
    torch.backends.cuda.matmul.allow_tf32=True
    torch.backends.cudnn.allow_tf32=True
    print(f"\n{'='*65}")
    print(f"  OS={platform.system()}  GPUs={n_gpus}  device={device}  AMP={args.amp}")
    train_loader,val_loader,test_loader,meta=build_loaders(
        real_dir=args.real_dir,aug_dir=args.aug_dir,mapping_path=args.mapping_path,
        split_mode=args.split_mode,use_pca=args.use_pca,pca_components=args.pca_components,
        patch_size=args.patch_size,test_ratio=args.test_ratio,val_ratio=args.val_ratio,
        batch_size=args.batch_size,random_state=args.random_state,
        fit_max_pixels=args.fit_max_pixels,num_workers=args.num_workers,
        bg_ratio=args.bg_ratio,cache_dir=args.cache_dir,balance_train=args.balance_train,
        max_ram_gb=args.max_ram_gb)
    model=SSFTTnet(in_channels=1,num_classes=meta["num_classes"],num_tokens=args.num_tokens,
                   dim=args.dim,depth=args.depth,heads=args.heads,mlp_dim=args.mlp_dim,
                   dropout=args.dropout,emb_dropout=args.emb_dropout).to(device)
    if n_gpus>1:
        model=nn.DataParallel(model)
        print(f"  DataParallel sur {n_gpus} GPUs")
    if args.compile and hasattr(torch,"compile"):
        model=torch.compile(model,mode="max-autotune")
        print("  torch.compile actif")
    n_params=sum(p.numel() for p in model.parameters() if p.requires_grad)
    batch_size=train_loader.batch_size
    eff_batch=batch_size*args.grad_accum
    print(f"  Params={n_params:,}  Classes={meta['num_classes']}  Bandes={meta['num_bands']}")
    print(f"  batch={batch_size}  grad_accum={args.grad_accum}  eff={eff_batch:,}")
    print(f"{'='*65}\n")
    ema=ModelEMA(model,decay=args.ema_decay) if args.use_ema else None
    criterion=nn.CrossEntropyLoss(label_smoothing=args.label_smooth)
    optimizer=AdamW(model.parameters(),lr=args.lr,weight_decay=args.weight_decay)
    scheduler=build_scheduler(optimizer,args.warmup_epochs,args.epochs)
    scaler=GradScaler(enabled=args.amp)
    start_epoch,best_val_acc,patience_cnt=1,0.0,0
    ckpt_dir=Path(args.checkpoint_dir)
    ckpt_dir.mkdir(parents=True,exist_ok=True)
    if args.resume and Path(args.resume).exists():
        start_epoch,best_val_acc=load_ckpt(args.resume,model,optimizer,scheduler,scaler,ema,device)
        start_epoch+=1
        print(f"  Resume depuis {args.resume} (epoch {start_epoch})")
    for epoch in range(start_epoch,args.epochs+1):
        train_ds=train_loader.dataset
        if hasattr(train_ds,'reshuffle'):
            train_ds.reshuffle(epoch)
        t0=time.perf_counter()
        tr_loss,tr_acc=run_epoch(model,train_loader,criterion,optimizer,scaler,
                                 device,args.amp,args.grad_accum,args.grad_clip,train=True,ema=ema)
        raw=model.module if hasattr(model,"module") else model
        orig_sd=deepcopy(raw.state_dict())
        if ema is not None:
            ema.apply_to(model)
        with torch.no_grad():
            va_loss,va_acc=run_epoch(model,val_loader,criterion,optimizer,scaler,
                                     device,args.amp,1,0,train=False)
        if ema is not None:
            raw.load_state_dict(orig_sd)
        scheduler.step()
        elapsed=time.perf_counter()-t0
        lr_now=optimizer.param_groups[0]["lr"]
        vram=torch.cuda.max_memory_allocated(device)/1e9 if torch.cuda.is_available() else 0
        torch.cuda.reset_peak_memory_stats(device)
        throughput=len(train_loader.dataset)/elapsed
        print(f"Ep {epoch:03d}/{args.epochs}"
              f"  tr {tr_loss:.4f}/{tr_acc*100:.2f}%"
              f"  va {va_loss:.4f}/{va_acc*100:.2f}%"
              f"  lr {lr_now:.2e}  VRAM {vram:.1f}GB"
              f"  {throughput:,.0f}p/s  {elapsed:.1f}s")
        if epoch%args.save_every==0:
            save_ckpt(ckpt_dir/f"ckpt_ep{epoch:03d}.pt",epoch,model,optimizer,scheduler,scaler,ema,va_acc)
        if va_acc>best_val_acc:
            best_val_acc=va_acc
            patience_cnt=0
            save_ckpt(ckpt_dir/"best_model.pt",epoch,model,optimizer,scheduler,scaler,ema,va_acc)
            print(f"  -> Meilleur modele  val acc={va_acc*100:.2f}%")
        else:
            patience_cnt+=1
            if patience_cnt>=args.patience:
                print(f"  Early stopping apres {args.patience} epoques.")
                break
    print(f"\n{'='*65}")
    ckpt=torch.load(ckpt_dir/"best_model.pt",map_location=device)
    raw=model.module if hasattr(model,"module") else model
    if ema is not None and "ema" in ckpt:
        raw.load_state_dict({k:v.to(device) for k,v in ckpt["ema"].items()})
    else:
        raw.load_state_dict(ckpt["model"])
    oa,aa,kappa,cm,per_cls=evaluate_metrics(model,test_loader,device,args.amp,meta["class_names"])
    print(f"  OA={oa:.2f}%  AA={aa:.2f}%  Kappa={kappa:.2f}%")
    for name,acc in zip(meta["class_names"],per_cls):
        print(f"    {name:<25}: {acc:.2f}%")
    print(f"\n  Matrice de confusion:\n{cm}")
    results_dir=Path("cls_results")
    results_dir.mkdir(exist_ok=True)
    with open(results_dir/"report.txt","w") as f:
        f.write(f"OA={oa:.2f}%  AA={aa:.2f}%  Kappa={kappa:.2f}%\n\n")
        for name,acc in zip(meta["class_names"],per_cls):
            f.write(f"{name}: {acc:.2f}%\n")
        f.write(f"\nConfusion Matrix:\n{cm}\n")
    print(f"{'='*65}\n")

if __name__=="__main__":
    main()