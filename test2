    )

    if world_size > 1:
        dist.barrier()

    batch_size = train_loader.batch_size
    eff_batch  = batch_size * world_size * (args.grad_accum or 1)

    if main_proc:
        print(f"  batch/GPU={batch_size}  grad_accum={args.grad_accum}  batch_eff={eff_batch:,}")
        print(f"{'='*65}\n")

