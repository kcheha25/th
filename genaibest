def linear_interpolation(landmarks, t_from, t_to):
    """
    Interpolate landmark sequences to a fixed number of frames.
    Handles missing frames by linearly interpolating between available frames.
    Returns zero-filled array if no landmarks are available.
    """
    if len(landmarks) == 0:
        return np.zeros((len(t_to), landmarks.shape[1]))
    interpolated = np.zeros((len(t_to), landmarks.shape[1]))
    for i in range(landmarks.shape[1]):
        f = interp1d(t_from, landmarks[:, i], kind='linear', bounds_error=False, fill_value='extrapolate')
        interpolated[:, i] = f(t_to)
    return interpolated


"""
BLOCK 3: DATA LOADING FUNCTIONS
---------------------------------
Functions to load training and test data from the competition dataset format.
Each video sequence is stored as landmark files with 21 hand keypoints in 3D.
