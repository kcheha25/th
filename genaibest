def compute_class_best_runs_automatic():
    print("\n" + "="*60)
    print("CALCUL AUTOMATIQUE DES MEILLEURS RUNS PAR CLASSE")
    print("="*60)
    
    train_landmarks, train_labels = load_train_data()
    train_landmarks = scale_normalize(train_landmarks)
    
    skf = StratifiedKFold(n_splits=N_FOLDS, shuffle=True, random_state=42)
    folds = list(skf.split(train_landmarks, train_labels.astype(int)))
    
    fold_f1_scores = np.zeros((N_FOLDS, NUM_CLASSES))
    fold_precision = np.zeros((N_FOLDS, NUM_CLASSES))
    fold_recall = np.zeros((N_FOLDS, NUM_CLASSES))
    
    for fold_idx in range(N_FOLDS):
        run_id = fold_idx + 1
        model_path = f"best_model_run{run_id}.pth"
        if not os.path.exists(model_path):
            print(f"  ⚠️  Run {run_id} non trouvé, skip...")
            continue
        
        print(f"\n  Évaluation Run {run_id} sur son set de validation...")
        model = load_model_for_run(run_id)
        scaler = load_scaler_for_run(run_id)
        
        _, val_idx = folds[fold_idx]
        val_landmarks = train_landmarks[val_idx]
        val_labels = train_labels[val_idx].astype(int)
        
        all_preds = []
        all_targets = []
        
        for i in tqdm(range(0, len(val_landmarks), 32), desc=f"    Run {run_id}", leave=False):
            batch = val_landmarks[i:i+32]
            batch_labels = val_labels[i:i+32]
            
            probs_list = []
            for angle in [0, np.pi/18, -np.pi/18]:
                aug = batch.copy()
                if angle != 0:
                    for j in range(len(aug)):
                        aug[j] = rotate_sequence(aug[j], angle, 2)
                
                lm, norm, diff_, feat = create_features(aug, with_normalized=True)
                feat = scaler.transform(feat.reshape(-1, 31)).reshape(feat.shape)
                
                landmark_in = torch.FloatTensor(prepare_graph_stream(lm)).to(device)
                norm_in = torch.FloatTensor(prepare_graph_stream(norm)).to(device)
                diff_in = torch.FloatTensor(prepare_graph_stream(diff_)).to(device)
                feat_in = torch.FloatTensor(feat).to(device)
                
                with torch.no_grad():
                    outputs, _ = model(landmark_in, norm_in, diff_in, feat_in)
                    probs_list.append(F.softmax(outputs, dim=1).cpu().numpy())
            
            avg_probs = np.mean(probs_list, axis=0)
            preds = np.argmax(avg_probs, axis=1)
            
            all_preds.extend(preds)
            all_targets.extend(batch_labels - 1)
        
        all_preds = np.array(all_preds)
        all_targets = np.array(all_targets)
        
        for cls in range(NUM_CLASSES):
            tp = np.sum((all_preds == cls) & (all_targets == cls))
            fp = np.sum((all_preds == cls) & (all_targets != cls))
            fn = np.sum((all_preds != cls) & (all_targets == cls))
            
            precision = tp / (tp + fp) if (tp + fp) > 0 else 0
            recall = tp / (tp + fn) if (tp + fn) > 0 else 0
            f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
            
            fold_f1_scores[fold_idx, cls] = f1
            fold_precision[fold_idx, cls] = precision
            fold_recall[fold_idx, cls] = recall
        
        acc = (all_preds == all_targets).mean() * 100
        print(f"    Accuracy globale: {acc:.2f}%")
    
    class_best_runs_weighted = {}
    
    print("\n" + "="*60)
    print("MEILLEURS RUNS PAR CLASSE (AVEC POIDS)")
    print("="*60)
    
    for cls in range(NUM_CLASSES):
        f1_scores = fold_f1_scores[:, cls]
        sorted_folds = np.argsort(f1_scores)[::-1]
        
        runs_with_weights = []
        total_f1 = f1_scores.sum()
        
        for fold_idx in sorted_folds:
            run_id = fold_idx + 1
            f1 = f1_scores[fold_idx]
            
            if f1 > 0:
                weight = f1 / total_f1 if total_f1 > 0 else 1.0
                runs_with_weights.append((run_id, weight))
        
        class_best_runs_weighted[cls + 1] = runs_with_weights
        
        print(f"\n  Classe {cls+1:2d}:")
        for run_id, weight in runs_with_weights:
            f1 = fold_f1_scores[run_id-1, cls]
            prec = fold_precision[run_id-1, cls]
            rec = fold_recall[run_id-1, cls]
            print(f"    Run {run_id}: F1={f1:.4f}, Prec={prec:.4f}, Rec={rec:.4f}, Poids={weight:.4f}")
    
    class_best_runs_simple = {cls: [r[0] for r in runs] 
                              for cls, runs in class_best_runs_weighted.items()}
    
    print("\n" + "="*60)
    print("DICTIONNAIRE CLASS_BEST_RUNS (simple) :")
    print("="*60)
    print("CLASS_BEST_RUNS = {")
    for cls in range(1, NUM_CLASSES+1):
        runs = class_best_runs_simple[cls]
        print(f"    {cls}: {runs},")
    print("}")
    
    return class_best_runs_weighted, class_best_runs_simple


def get_ambiguous_samples(probs_matrix, margin_threshold=CONFIDENCE_MARGIN_THRESHOLD, top_k=TOP_K_CANDIDATES):
    sorted_probs = np.sort(probs_matrix, axis=1)[:, ::-1]
    top1 = sorted_probs[:, 0]
    top2 = sorted_probs[:, 1]
    margin = top1 - top2
    is_ambiguous = margin < margin_threshold

    ambiguous_info = []
    for idx in np.where(is_ambiguous)[0]:
        top_k_classes = np.argsort(probs_matrix[idx])[::-1][:top_k] + 1
        ambiguous_info.append({
            'sample_idx': int(idx),
            'candidates': top_k_classes.tolist(),
            'margin': float(margin[idx])
        })
    return ambiguous_info


def predict_single_sample_with_weighted_runs(landmarks_sample, run_ids_with_weights, use_tta=True):
    batch = landmarks_sample[np.newaxis, ...]
    
    all_probs = []
    all_weights = []
    
    for run_id, weight in run_ids_with_weights:
        model = load_model_for_run(run_id)
        scaler = load_scaler_for_run(run_id)
        
        configs = TTA_CONFIGS_INFERENCE if use_tta else [{"angle": 0.0, "axis": 2, "scale": 1.0}]
        probs_tta = []
        
        for cfg_tta in configs:
            aug = batch.copy()
            aug[0] = rotate_sequence(aug[0], cfg_tta["angle"], cfg_tta["axis"])
            aug[0] = scale_sequence(aug[0], cfg_tta["scale"])
            
            lm, norm, diff_, feat = create_features(aug, with_normalized=True)
            feat = scaler.transform(feat.reshape(-1, 31)).reshape(feat.shape)
            
            landmark_in = torch.FloatTensor(prepare_graph_stream(lm)).to(device)
            norm_in = torch.FloatTensor(prepare_graph_stream(norm)).to(device)
            diff_in = torch.FloatTensor(prepare_graph_stream(diff_)).to(device)
            feat_in = torch.FloatTensor(feat).to(device)
            
            with torch.no_grad():
                outputs, _ = model(landmark_in, norm_in, diff_in, feat_in)
                probs_tta.append(F.softmax(outputs, dim=1).cpu().numpy())
        
        avg_tta = np.mean(probs_tta, axis=0)
        all_probs.append(avg_tta[0] * weight)
        all_weights.append(weight)
    
    ensemble_probs = np.sum(all_probs, axis=0) / np.sum(all_weights)
    return ensemble_probs


def run_first_pass_ensemble_with_probs(test_landmarks):
    print("\n" + "="*60)
    print("PREMIÈRE PASSE : ENSEMBLE GLOBAL")
    print("="*60)
    
    available_runs = []
    for run_id in range(1, 6):
        if os.path.exists(f"best_model_run{run_id}.pth"):
            available_runs.append(run_id)
    
    print(f"Runs disponibles : {available_runs}")
    
    models = [load_model_for_run(r) for r in available_runs]
    scalers = [load_scaler_for_run(r) for r in available_runs]
    
    batch_size = 32
    all_preds = []
    all_probs = []
    
    for start in tqdm(range(0, len(test_landmarks), batch_size), desc="First pass"):
        batch_landmarks = test_landmarks[start:start + batch_size]
        model_probs = []
        
        for model, scaler in zip(models, scalers):
            probs_tta = []
            for cfg_tta in TTA_CONFIGS_INFERENCE:
                aug = batch_landmarks.copy()
                for i in range(len(aug)):
                    aug[i] = rotate_sequence(aug[i], cfg_tta["angle"], cfg_tta["axis"])
                    aug[i] = scale_sequence(aug[i], cfg_tta["scale"])
                
                lm, norm, diff_, feat = create_features(aug, with_normalized=True)
                feat = scaler.transform(feat.reshape(-1, 31)).reshape(feat.shape)
                
                landmark_in = torch.FloatTensor(prepare_graph_stream(lm)).to(device)
                norm_in = torch.FloatTensor(prepare_graph_stream(norm)).to(device)
                diff_in = torch.FloatTensor(prepare_graph_stream(diff_)).to(device)
                feat_in = torch.FloatTensor(feat).to(device)
                
                with torch.no_grad():
                    outputs, _ = model(landmark_in, norm_in, diff_in, feat_in)
                    probs_tta.append(F.softmax(outputs, dim=1))
            
            model_probs.append(torch.stack(probs_tta).mean(0))
        
        ensemble_probs = torch.stack(model_probs).mean(0)
        pred = ensemble_probs.argmax(1)
        all_preds.extend(pred.cpu().numpy())
        all_probs.append(ensemble_probs.cpu().numpy())
    
    all_probs = np.concatenate(all_probs, axis=0)
    return np.array(all_preds) + 1, all_probs


def run_second_pass_weighted_disambiguation(test_landmarks, first_pass_predictions, 
                                             first_pass_probs, class_best_runs_weighted):
    print("\n" + "="*60)
    print("SECONDE PASSE : DÉSAMBIGUÏSATION PONDÉRÉE")
    print("="*60)
    
    ambiguous_info = get_ambiguous_samples(first_pass_probs)
    print(f"Échantillons ambigus : {len(ambiguous_info)} / {len(test_landmarks)} "
          f"({100 * len(ambiguous_info) / len(test_landmarks):.2f}%)")
    
    corrected_predictions = first_pass_predictions.copy()
    n_changed = 0
    change_log = []
    
    for info in tqdm(ambiguous_info, desc="Disambiguation"):
        idx = info['sample_idx']
        candidates = info['candidates']
        original_pred = int(first_pass_predictions[idx])
        
        expert_runs_with_weights = []
        seen_runs = set()
        
        for cls in candidates:
            if cls in class_best_runs_weighted:
                for run_id, weight in class_best_runs_weighted[cls]:
                    if run_id not in seen_runs:
                        expert_runs_with_weights.append((run_id, weight))
                        seen_runs.add(run_id)
        
        if not expert_runs_with_weights:
            continue
        
        probs = predict_single_sample_with_weighted_runs(
            test_landmarks[idx], expert_runs_with_weights, use_tta=True
        )
        
        candidate_mask = np.zeros(NUM_CLASSES, dtype=bool)
        for cls in candidates:
            candidate_mask[cls - 1] = True
        
        restricted_probs = np.where(candidate_mask, probs, -1)
        new_pred = int(np.argmax(restricted_probs)) + 1
        
        if new_pred != original_pred:
            n_changed += 1
            change_log.append({
                'sample_idx': idx,
                'original_pred': original_pred,
                'corrected_pred': new_pred,
                'candidates': candidates,
                'margin_pass1': info['margin'],
                'experts_consulted': [r for r, _ in expert_runs_with_weights],
                'confidence_new': float(probs[new_pred - 1])
            })
            corrected_predictions[idx] = new_pred
    
    print(f"\nÉchantillons corrigés : {n_changed} / {len(ambiguous_info)}")
    
    if change_log:
        change_df = pd.DataFrame(change_log)
        print("\nDétail des corrections :")
        print(change_df.to_string(index=False))
        change_df.to_csv('second_pass_weighted_disambiguation.csv', index=False)
    
    return corrected_predictions


