            print(f"Mean: {np.mean(all_val_scores):.2f}% +/- {np.std(all_val_scores):.2f}%")

        else:
            indices = np.arange(len(train_landmarks))
            train_idx, val_idx = train_test_split(
                indices, test_size=0.1, random_state=42, stratify=train_labels.astype(int)
            )

            raw_train_landmarks = train_landmarks[train_idx]
            raw_train_labels = train_labels[train_idx]
            val_landmarks_raw = train_landmarks[val_idx]
            val_labels = train_labels[val_idx]

            print(f"Train raw samples: {len(train_idx)} | Validation samples: {len(val_idx)}")

            results = []
            for i, cfg in enumerate(CONFIGS, start=1):
                res = train_single_config(
                    i, cfg, raw_train_landmarks, raw_train_labels, val_landmarks_raw, val_labels
                )
                results.append(res)

            df = pd.DataFrame(results)
            df_sorted = df.sort_values('best_val_acc', ascending=False).reset_index(drop=True)
            print(f"\n=== RESULTS ===")
            print(df_sorted[['run_id', 'name', 'best_val_acc', 'best_train_acc', 'best_epoch', 'total_params']].to_string(index=False))

            best_row = df_sorted.iloc[0]
            best_run_id = int(best_row['run_id'])
            print(f"\nBEST MODEL: {best_row['name']} (run {best_run_id})")
            print(f"Val acc: {float(best_row['best_val_acc']):.2f}%")
            print(f"Weights: best_model_run{best_run_id}.pth")
            print(f"Scaler: {best_row['scaler_path']}")

    else:
        # INFERENCE MODE - Ensemble de plusieurs modèles (configurable) + TTA
        print("\n" + "="*60)
        print(f"INFERENCE MODE WITH {len(ENSEMBLE_RUN_IDS)}-MODEL ENSEMBLE + TTA (runs {ENSEMBLE_RUN_IDS})")
        print("="*60)
    
        models = []
        scalers = []
    
        for run_id in ENSEMBLE_RUN_IDS:
            model_path = f"best_model_run{run_id}.pth"
            scaler_path = f"scaler_best_run{run_id}.pkl"
    
            if not os.path.exists(model_path) or not os.path.exists(scaler_path):
                print(f"Warning: Model or scaler for fold {run_id} missing, skipping...")
                continue
    
            print(f"Loading model and scaler for fold {run_id}...")
    
            with open(scaler_path, 'rb') as f:
                scaler = pickle.load(f)
                scalers.append(scaler)
    
            cfg = CONFIGS[0].copy()
            A = build_adjacency(21).to(device)
    
            model = GestureMultiStreamMoEModel(
                num_classes=NUM_CLASSES, A=A,
                num_blocks=[int(x) for x in cfg['num_blocks']],
                transformer_embed_dim=int(cfg['transformer_embed_dim']),
                transformer_heads=int(cfg['transformer_heads']),
                transformer_layers=int(cfg['transformer_layers']),
                transformer_mlp_ratio=float(cfg['transformer_mlp_ratio']),
                hidden_size=int(cfg['hidden_size']),
                num_experts=int(cfg['num_experts']),
                k=int(cfg['k']),
                num_moe_layers=int(cfg['num_moe_layers']),
                dropout=float(cfg['dropout']),
                drop_path_rate=float(cfg['drop_path_rate'])
            ).to(device)
    
            model.load_state_dict(torch.load(model_path, map_location=device))
            model.eval()
            models.append(model)
    
        if not models:
            raise RuntimeError("No models loaded. Check ENSEMBLE_RUN_IDS and model files.")
    
        print(f"Successfully loaded {len(models)} models (runs {[run_id for run_id in ENSEMBLE_RUN_IDS if os.path.exists(f'best_model_run{run_id}.pth')]})")
    
        print("Loading test data...")
        test_landmarks = load_test_data()
        test_landmarks = scale_normalize(test_landmarks)
    
        test_landmarks_f, test_normalized_f, test_differences_f, test_features_f = create_features(
            test_landmarks, with_normalized=True
        )
    
        print("Generating predictions with ensemble + TTA...")
        predictions_ensemble = []
    
        tta_configs = [
            {"angle": 0.0, "axis": 2, "scale": 1.00},
            {"angle": np.pi/18, "axis": 2, "scale": 1.00},
            {"angle": -np.pi/18, "axis": 2, "scale": 1.00},
            {"angle": np.pi/36, "axis": 1, "scale": 1.05},
            {"angle": -np.pi/36, "axis": 1, "scale": 0.95},
            {"angle": np.pi/24, "axis": 0, "scale": 1.00},
            {"angle": -np.pi/24, "axis": 0, "scale": 1.00},
        ]
    
        batch_size = 32
        all_probs = []
    
        for start in tqdm(range(0, len(test_landmarks), batch_size), desc="TTA + Ensemble Prediction"):
            batch_landmarks = test_landmarks[start:start+batch_size]
    
            model_probs = []
            for model_idx, model in enumerate(models):
                scaler = scalers[model_idx]
                probs_all = []
    
                for cfg_tta in tta_configs:
                    aug = batch_landmarks.copy()
    
                    for i in range(len(aug)):
                        aug[i] = rotate_sequence(aug[i], cfg_tta["angle"], cfg_tta["axis"])
                        aug[i] = scale_sequence(aug[i], cfg_tta["scale"])
    
                    lm, norm, diff_, feat = create_features(aug, with_normalized=True)
                    feat = scaler.transform(feat.reshape(-1, 31)).reshape(feat.shape)
    
                    landmark_in = torch.FloatTensor(prepare_graph_stream(lm)).to(device)
                    norm_in = torch.FloatTensor(prepare_graph_stream(norm)).to(device)
                    diff_in = torch.FloatTensor(prepare_graph_stream(diff_)).to(device)
                    feat_in = torch.FloatTensor(feat).to(device)
    
                    with torch.no_grad():
                        outputs, _ = model(landmark_in, norm_in, diff_in, feat_in)
                        probs = F.softmax(outputs, dim=1)
                        probs_all.append(probs)
    
                probs_all = torch.stack(probs_all)
                avg_probs = probs_all.mean(0)
                model_probs.append(avg_probs)
    
            if model_probs:
                ensemble_probs = torch.stack(model_probs).mean(0)
                pred = ensemble_probs.argmax(1)
                all_probs.extend(pred.cpu().numpy())
    
        predictions = np.array(all_probs) + 1
        submission = pd.DataFrame({'Id': range(len(predictions)), 'Gesture': predictions})
        submission_file = f'submission_ensemble_runs{"_".join(map(str, ENSEMBLE_RUN_IDS))}.csv'
        submission.to_csv(submission_file, index=False)
        print(f"Submission saved: {submission_file}")
        print(submission.head())
        print(f"\nPrediction distribution:")
        print(pd.Series(predictions).value_counts().sort_index())
    
        if MAKE_PLOTS:
            pred_unique, pred_counts = np.unique(predictions, return_counts=True)
            plt.figure(figsize=(9, 4))
            plt.bar(pred_unique, pred_counts, color="#9467bd")
            plt.xlabel("Predicted gesture class")
            plt.ylabel("Number of test sequences")
            plt.title(f"Predicted class distribution (ensemble runs {ENSEMBLE_RUN_IDS})")
            plt.xticks(pred_unique)
            plt.tight_layout()
            save_and_show("11_test_prediction_distribution")
    
    wandb.finish()
