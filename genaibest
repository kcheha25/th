        num_classes=NUM_CLASSES, A=A,
        num_blocks=[int(x) for x in cfg['num_blocks']],
        transformer_embed_dim=int(cfg['transformer_embed_dim']),
        transformer_heads=int(cfg['transformer_heads']),
