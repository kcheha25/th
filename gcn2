class LandmarkDataset(Dataset):
    """Simple dataset that returns graph stream tensor and optional label."""
    def __init__(self, graph_stream, labels=None):
        self.graph_stream = torch.FloatTensor(graph_stream)
        self.labels = torch.LongTensor(labels.astype(int) - 1) if labels is not None else None

    def __len__(self):
        return len(self.graph_stream)

    def __getitem__(self, idx):
        if self.labels is not None:
            return self.graph_stream[idx], self.labels[idx]
        return self.graph_stream[idx]


def evaluate(model, loader, criterion, aux_loss_weight):
    """Evaluate model on a data loader."""
    model.eval()
    correct, total, running_loss = 0, 0, 0.0
    all_preds, all_targets = [], []
    
    with torch.no_grad():
        for inputs, targets in loader:
            inputs = inputs.to(device)
            targets = targets.to(device)
            
            outputs, moe_info = model(inputs)
            loss = criterion(outputs, targets) + aux_loss_weight * moe_info['aux_loss']
            
            running_loss += loss.item()
            _, predicted = outputs.max(1)
            total += targets.size(0)
            correct += predicted.eq(targets).sum().item()
            
            all_preds.extend(predicted.cpu().numpy())
            all_targets.extend(targets.cpu().numpy())
    
    return 100. * correct / total, running_loss / len(loader), np.array(all_preds), np.array(all_targets)

