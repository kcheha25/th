# TRAINING FUNCTION
# =============================================================================
def train_model(config, train_landmarks, train_labels, val_landmarks, val_labels):
    """Complete training pipeline for one configuration."""
    print(f"\n{'='*60}")
    print(f"Training configuration: {config['name']}")
    print(f"{'='*60}")
    
    torch.manual_seed(config.get('seed', 42))
    np.random.seed(config.get('seed', 42))
    
    train_landmarks_aug, train_labels_aug = augment_data_balanced(
        train_landmarks, train_labels, target_count=config.get('target_count', 450)
    )
    
    train_graph = prepare_graph_stream(train_landmarks_aug)
    val_graph = prepare_graph_stream(val_landmarks)
    
    print(f"Train graph stream shape: {train_graph.shape}")
    print(f"Val graph stream shape: {val_graph.shape}")
    
    train_dataset = LandmarkDataset(train_graph, train_labels_aug)
    val_dataset = LandmarkDataset(val_graph, val_labels)
    
    train_loader = DataLoader(train_dataset, batch_size=config['batch_size'], shuffle=True, num_workers=0)
    val_loader = DataLoader(val_dataset, batch_size=config['batch_size'], shuffle=False, num_workers=0)
    
    A = build_adjacency(21).to(device)
    alpha = compute_focal_alpha(train_labels_aug.astype(int), NUM_CLASSES, device)
    
    model = GestureSTGCNMoEModel(
        num_classes=NUM_CLASSES,
        A=A,
        num_blocks=config['num_blocks'],
        hidden_size=config['hidden_size'],
        num_experts=config['num_experts'],
        k=config['k'],
        num_moe_layers=config['num_moe_layers'],
        dropout=config['dropout'],
        drop_path_rate=config['drop_path_rate']
    ).to(device)
    
    ema_model = GestureSTGCNMoEModel(
        num_classes=NUM_CLASSES,
        A=A,
        num_blocks=config['num_blocks'],
        hidden_size=config['hidden_size'],
        num_experts=config['num_experts'],
        k=config['k'],
        num_moe_layers=config['num_moe_layers'],
        dropout=config['dropout'],
        drop_path_rate=config['drop_path_rate']
    ).to(device)
    
    total_params = sum(p.numel() for p in model.parameters())
    print(f"Total parameters: {total_params:,}")
    
    criterion = FocalLoss(alpha=alpha, gamma=config['focal_gamma'], label_smoothing=config['label_smoothing'])
    optimizer = optim.AdamW(model.parameters(), lr=config['learning_rate'], weight_decay=config['weight_decay'])
    scheduler = optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=config['T_0'], T_mult=1, eta_min=1e-6)
    ema = EMA(model, decay=config['ema_decay'])
    
    history = {"train_loss": [], "train_acc": [], "val_loss": [], "val_acc": []}
    
    best_val_acc = 0.0
    best_epoch = 0
    patience_counter = 0
    save_path = 'best_model_stgcn_moe.pth'
    
    for epoch in range(config['epochs']):
        model.train()
        correct, total, running_loss = 0, 0, 0.0
        
        for inputs, targets in train_loader:
            inputs = inputs.to(device)
            targets = targets.to(device)
            
            optimizer.zero_grad()
            outputs, moe_info = model(inputs)
            main_loss = criterion(outputs, targets)
            total_loss = main_loss + config['aux_loss_weight'] * moe_info['aux_loss']
            total_loss.backward()
            
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            optimizer.step()
            ema.update(model)
            
            running_loss += main_loss.item()
            _, predicted = outputs.max(1)
            total += targets.size(0)
            correct += predicted.eq(targets).sum().item()
        
        scheduler.step()
        train_acc = 100. * correct / total
        train_loss = running_loss / len(train_loader)
        
        ema_model.load_state_dict(ema.state_dict())
        val_acc, val_loss, _, _ = evaluate(ema_model, val_loader, criterion, config['aux_loss_weight'])
        
        history["train_loss"].append(train_loss)
        history["train_acc"].append(train_acc)
        history["val_loss"].append(val_loss)
        history["val_acc"].append(val_acc)
        
        print(f"Epoch {epoch+1}/{config['epochs']}: "
              f"Train Loss: {train_loss:.4f} Acc: {train_acc:.2f}% | "
              f"Val Loss: {val_loss:.4f} Acc: {val_acc:.2f}%")
        
        if val_acc > best_val_acc:
            best_val_acc = val_acc
            best_epoch = epoch + 1
            patience_counter = 0
            torch.save(ema_model.state_dict(), save_path)
            print(f"  → New best model saved (Val Acc: {val_acc:.2f}%)")
        else:
            patience_counter += 1
            if patience_counter >= config['patience']:
                print(f"Early stopping at epoch {epoch+1}")
                break
    
    plot_training_curves(history)
    
    if os.path.exists(save_path):
        ema_model.load_state_dict(torch.load(save_path, map_location=device))
        _, _, val_preds, val_targets = evaluate(ema_model, val_loader, criterion, config['aux_loss_weight'])
        plot_val_evaluation(val_preds, val_targets)
    
    print(f"\nTraining complete. Best Val Acc: {best_val_acc:.2f}% at epoch {best_epoch}")
    
    del model
    torch.cuda.empty_cache()
    
    return {
        'best_val_acc': best_val_acc,
        'best_epoch': best_epoch,
        'save_path': save_path,
        'total_params': total_params
    }

