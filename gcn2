def predict_test(config, model_path, test_landmarks):
    """Generate predictions for test data using a trained model."""
    print(f"\nLoading model from {model_path}...")
    
    test_graph = prepare_graph_stream(test_landmarks)
    test_dataset = LandmarkDataset(test_graph)
    test_loader = DataLoader(test_dataset, batch_size=config['batch_size'], shuffle=False, num_workers=0)
    
    A = build_adjacency(21).to(device)
    model = GestureSTGCNMoEModel(
        num_classes=NUM_CLASSES,
        A=A,
        num_blocks=config['num_blocks'],
        hidden_size=config['hidden_size'],
        num_experts=config['num_experts'],
        k=config['k'],
        num_moe_layers=config['num_moe_layers'],
        dropout=config['dropout'],
        drop_path_rate=config['drop_path_rate']
    ).to(device)
    
    model.load_state_dict(torch.load(model_path, map_location=device))
    model.eval()
    
    predictions = []
    with torch.no_grad():
        for inputs in tqdm(test_loader, desc="Predicting"):
            inputs = inputs.to(device)
            outputs, _ = model(inputs)
            _, predicted = outputs.max(1)
            predictions.extend(predicted.cpu().numpy())
    
    predictions = np.array(predictions) + 1
    return predictions

