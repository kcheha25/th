def load_mapping(mapping_path: str):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names = final_classes + ["background"]
    label2idx = {name: i for i, name in enumerate(class_names)}
    print(f"Mapping: {len(extrude2final)} labels -> {len(final_classes)} classes + background")
    return extrude2final, class_names, label2idx

def _load_envi_real(hdr_path: Path):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wavelengths = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3 and cube.shape[2] == len(wavelengths) and len(wavelengths) > 0:
        cube = cube.transpose(2, 0, 1)
    if cube.ndim != 3:
        raise ValueError(f"Invalid cube format: shape {cube.shape}")
    return cube, wavelengths

def _load_envi_augmented(hdr_path: Path):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wavelengths = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3:
        if len(wavelengths) > 0 and cube.shape[1] == len(wavelengths):
            cube = cube.transpose(1, 0, 2)
        elif cube.shape[0] == len(wavelengths):
            pass
        else:
            print(f"  Warning: Unexpected format for {hdr_path.name}: shape {cube.shape}, expected bands {len(wavelengths)}")
    if cube.ndim != 3:
        raise ValueError(f"Invalid cube format after transform: shape {cube.shape}")
    return cube, wavelengths

def _load_envi_auto(hdr_path: Path, source: str = "real"):
    if source == "real":
        return _load_envi_real(hdr_path)
    else:
        return _load_envi_augmented(hdr_path)

def _load_shapes(json_path: Path):
    with open(json_path) as f:
        ann = json.load(f)
    return ann.get("shapes", [])

def _iter_real_dir(real_dir: Path):
    for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
        m = re.match(r"plot_(\d+)_cube", hdr.stem)
        if not m:
            continue
        jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
        if jsn.exists():
            yield "real", hdr.stem, hdr, jsn
        else:
            print(f"Warning: No JSON for {hdr.name} -> ignored")

def _iter_aug_dir(aug_dir: Path):
    for hdr in sorted(aug_dir.glob("*.hdr")):
        if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")):
            continue
        jsn = aug_dir / f"{hdr.stem}.json"
        if not jsn.exists():
            print(f"Warning: No JSON for {hdr.name} -> ignored")
            continue
        source = "circle" if "circle" in hdr.stem.lower() else "aug"
        yield source, hdr.stem, hdr, jsn

def collect_plots_meta(real_dir=None, aug_dir=None):
    meta_list = []
    if real_dir is not None:
        real_dir = Path(real_dir)
        if real_dir.exists():
            for source, name, hdr, jsn in _iter_real_dir(real_dir):
                meta_list.append({"source": source, "name": name, "hdr": hdr, "jsn": jsn})
            n_real = sum(1 for m in meta_list if m["source"] == "real")
            print(f"Info: real_dir -> {n_real} real plots")
        else:
            print(f"Warning: real_dir='{real_dir}' not found")
    if aug_dir is not None:
        aug_dir = Path(aug_dir)
        if aug_dir.exists():
            before = len(meta_list)
            for source, name, hdr, jsn in _iter_aug_dir(aug_dir):
                meta_list.append({"source": source, "name": name, "hdr": hdr, "jsn": jsn})
            print(f"Info: aug_dir -> {len(meta_list) - before} augmented")
        else:
            print(f"Warning: aug_dir='{aug_dir}' not found")
    if not meta_list:
        raise RuntimeError("No plots found. Check --real_dir and --aug_dir.")
    n_real = sum(1 for m in meta_list if m["source"] == "real")
    n_aug = len(meta_list) - n_real
    print(f"Info: Total {len(meta_list)} plots ({n_real} real | {n_aug} augmented)\n")
    return meta_list

def _rasterize_polygon_gpu(points, H, W, device):
    pts = torch.tensor(points, dtype=torch.float32, device=device)
    n = len(pts)
    rows = torch.arange(H, device=device, dtype=torch.float32) + 0.5
    cols = torch.arange(W, device=device, dtype=torch.float32) + 0.5
    grid_c, grid_r = torch.meshgrid(cols, rows, indexing="xy")
    px = grid_c.reshape(-1)
    py = grid_r.reshape(-1)
    x1 = pts[:, 0]
    y1 = pts[:, 1]
    idx_next = (torch.arange(n, device=device) + 1) % n
    x2 = pts[idx_next, 0]
    y2 = pts[idx_next, 1]
    px_ = px.unsqueeze(1)
    py_ = py.unsqueeze(1)
    cond1 = (y1 < py_) != (y2 < py_)
    denom = (y2 - y1).clone()
    safe_denom = torch.where(denom == 0, torch.ones_like(denom) * 1e-10, denom)
    x_intersect = x1 + (py_ - y1) * (x2 - x1) / safe_denom
    cond2 = px_ < x_intersect
    inside = (cond1 & cond2).sum(dim=1) % 2 == 1
    return inside.reshape(H, W)

def build_label_map_gpu(cube_BHW, shapes, extrude2final, label2idx, device):
    B, H, W = cube_BHW.shape
    bg_idx = label2idx["background"]
    label_map_gpu = torch.full((H, W), bg_idx, dtype=torch.int64, device=device)
    for shape in shapes:
        raw_label = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw_label.lower() == "trou" or stype not in ("polygon", "rectangle"):
            continue
        final = extrude2final.get(raw_label)
        if final is None:
            print(f"  Warning: label '{raw_label}' missing from mapping -> ignored")
            continue
        points = shape["points"]
        if len(points) < 3:
            continue
        try:
            mask = _rasterize_polygon_gpu(points, H, W, device)
            label_map_gpu[mask] = label2idx[final]
        except Exception as e:
            print(f"  Warning: rasterization '{raw_label}' failed: {e}")
    n_bg = int((label_map_gpu == bg_idx).sum().item())
    n_total = H * W
    print(f"    Label map: {n_total} pixels | {n_total - n_bg} annotated | {n_bg} raw background")
    label_map = label_map_gpu.cpu().numpy()
    del label_map_gpu
    if device.type == "cuda":
        torch.cuda.empty_cache()
    return label_map

def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15, test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        val = aug[:n_val]
        train = aug[n_val:]
        test = real
        print(f"Split aug_real: train={len(train)} | val={len(val)} | test={len(test)}")
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test = max(1, int(n * test_ratio))
        n_val = max(1, int(n * val_ratio))
        test = all_p[:n_test]
        val = all_p[n_test:n_test + n_val]
        train = all_p[n_test + n_val:]
        print(f"Split shuffle: train={len(train)} | val={len(val)} | test={len(test)}")
    else:
        raise ValueError(f"Unknown split_mode: '{split_mode}'")
    return train, val, test

def balance_background(labels: np.ndarray, bg_idx: int, rng: np.random.Generator, bg_ratio: float = 1.5) -> np.ndarray:
    bg_mask = labels == bg_idx
    fg_mask = ~bg_mask
    n_fg = int(fg_mask.sum())
    n_bg = int(bg_mask.sum())
    keep_mask = fg_mask.copy()
    if n_fg == 0:
        return keep_mask
    n_bg_keep = min(int(n_fg * bg_ratio), n_bg)
    if n_bg_keep > 0:
        bg_indices = np.where(bg_mask)[0]
        chosen = rng.choice(bg_indices, size=n_bg_keep, replace=False)
        keep_mask[chosen] = True
    return keep_mask

def extract_patches_gpu(cube_BHW: np.ndarray, coords: np.ndarray, patch_size: int, device: torch.device) -> torch.Tensor:
    B, H, W = cube_BHW.shape
    margin = patch_size // 2
    cube_t = torch.from_numpy(cube_BHW).unsqueeze(0).to(device=device, dtype=torch.float32)
    cube_padded = F.pad(cube_t, (margin, margin, margin, margin), mode="constant", value=0)
    unfolded = F.unfold(cube_padded, kernel_size=patch_size, stride=1)
    rows = coords[:, 0]
    cols = coords[:, 1]
    lin_idx = torch.from_numpy((rows * W + cols).astype(np.int64)).to(device)
    selected = unfolded[0, :, lin_idx].T
    patches = selected.reshape(-1, B, patch_size, patch_size)
    del cube_t, cube_padded, unfolded, selected
    if device.type == "cuda":
        torch.cuda.empty_cache()
    return patches

def process_single_plot(meta, extrude2final, label2idx, patch_size, random_state, bg_ratio, device_id):
    device = torch.device(f"cuda:{device_id}")
    name = meta["name"]
    source = meta["source"]
    rng = np.random.default_rng(seed=random_state + hash(name) % 10000)
    bg_idx = label2idx["background"]
    
    try:
        cube, _ = _load_envi_auto(meta["hdr"], source)
        shapes = _load_shapes(meta["jsn"])
    except Exception as e:
        print(f"  Warning: {name} ignored: {e}")
        return None, None, None
    
    B, H, W = cube.shape
    label_map = build_label_map_gpu(cube, shapes, extrude2final, label2idx, device)
    rows, cols = np.where(label_map >= 0)
    labels_all = label_map[rows, cols]
    del label_map
    gc.collect()
    
    if len(rows) == 0:
        print(f"  Skip: {name} — no pixels")
        del cube
        gc.collect()
        return None, None, None
    
    keep_mask = balance_background(labels_all, bg_idx, rng, bg_ratio)
    rows_k = rows[keep_mask]
    cols_k = cols[keep_mask]
    labels_k = labels_all[keep_mask]
    
    n_fg = int((labels_all != bg_idx).sum())
    n_bg_raw = int((labels_all == bg_idx).sum())
    n_bg_kept = int((labels_k == bg_idx).sum())
    
    del labels_all, rows, cols, keep_mask
    gc.collect()
    
    if len(rows_k) == 0:
        print(f"  Skip: {name} — 0 pixels after balancing")
        del cube
        gc.collect()
        return None, None, None
    
    coords = np.stack([rows_k, cols_k], axis=1)
    
    n_patches = len(coords)
    batch_size = 50000
    all_patches = []
    
    for start in range(0, n_patches, batch_size):
        end = min(start + batch_size, n_patches)
        batch_coords = coords[start:end]
        patches_gpu = extract_patches_gpu(cube, batch_coords, patch_size, device)
        patches_cpu = patches_gpu.cpu().numpy()
        del patches_gpu
        if device.type == "cuda":
            torch.cuda.empty_cache()
        all_patches.append(patches_cpu)
        gc.collect()
    
    patches = np.concatenate(all_patches, axis=0)
    
    del cube, coords, all_patches
    if device.type == "cuda":
        torch.cuda.empty_cache()
    gc.collect()
    
    print(f"  GPU {device_id} | {source:6} | {name:30} | annotated={n_fg:6} | raw bg={n_bg_raw:7} -> kept bg={n_bg_kept:6} | total={len(labels_k):7}")
    
    return patches, labels_k, {int(lbl): 1 for lbl in labels_k}

def process_plots_parallel(plot_meta_list, extrude2final, label2idx, patch_size, random_state, bg_ratio, h5_file, dataset_name, num_gpus=NUM_GPUS):
    print(f"\nProcessing {len(plot_meta_list)} plots using {num_gpus} GPUs")
    
    class_counts = defaultdict(int)
    idx2name = {v: k for k, v in label2idx.items()}
    
    with h5py.File(h5_file, 'a') as f:
        if dataset_name in f:
            del f[dataset_name]
        
        dset_x = f.create_dataset(f"{dataset_name}/X", shape=(0, 1, patch_size, patch_size), maxshape=(None, 1, patch_size, patch_size), dtype=np.float32, chunks=True, compression='gzip')
        dset_y = f.create_dataset(f"{dataset_name}/y", shape=(0,), maxshape=(None,), dtype=np.int64, chunks=True, compression='gzip')
        
        total_samples = 0
        plot_index = 0
        
        while plot_index < len(plot_meta_list):
            batch_plots = []
            for gpu_id in range(num_gpus):
                if plot_index + gpu_id < len(plot_meta_list):
                    batch_plots.append((plot_index + gpu_id, plot_meta_list[plot_index + gpu_id], gpu_id))
            
            if not batch_plots:
                break
            
            results = []
            with ThreadPoolExecutor(max_workers=num_gpus) as executor:
                futures = {}
                for idx, meta, gpu_id in batch_plots:
                    future = executor.submit(process_single_plot, meta, extrude2final, label2idx, patch_size, random_state, bg_ratio, gpu_id)
                    futures[future] = (idx, meta)
                
                for future in as_completed(futures):
                    idx, meta = futures[future]
                    try:
                        patches, labels, counts = future.result()
                        if patches is not None and labels is not None:
                            n_new = len(labels)
                            dset_x.resize(total_samples + n_new, axis=0)
                            dset_y.resize(total_samples + n_new, axis=0)
                            
                            patches_ssftt = patches[:, np.newaxis, :, :, :]
                            dset_x[total_samples:total_samples + n_new] = patches_ssftt.astype(np.float32)
                            dset_y[total_samples:total_samples + n_new] = labels.astype(np.int64)
                            
                            for lbl, cnt in counts.items():
                                class_counts[idx2name[lbl]] += cnt
                            
                            total_samples += n_new
                            print(f"  Written to HDF5: {total_samples:,} total samples")
                    except Exception as e:
                        print(f"  Error processing {meta['name']}: {e}")
            
            plot_index += num_gpus
            
            torch.cuda.empty_cache()
            gc.collect()
    
    print(f"HDF5 saved: {h5_file} - {dataset_name} - {total_samples:,} samples")
    return class_counts

def apply_pca_to_hdf5(input_h5, output_h5, dataset_name, pca_components, fit_max_pixels=500000):
    print(f"Applying PCA to HDF5 dataset: {dataset_name}")
    
    with h5py.File(input_h5, 'r') as f:
        X = f[f"{dataset_name}/X"][:]
        y = f[f"{dataset_name}/y"][:]
    
    N, C, B, ps, _ = X.shape
    X_flat = X.reshape(-1, B)
    
    if len(X_flat) > fit_max_pixels:
        idx = np.random.choice(len(X_flat), fit_max_pixels, replace=False)
        X_fit = X_flat[idx]
    else:
        X_fit = X_flat
    
    print(f"  PCA fit on {len(X_fit):,} pixels")
    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(X_fit)
    print(f"  PCA explained variance: {pca.explained_variance_ratio_.sum():.3f}")
    
    X_flat_pca = pca.transform(X_flat).astype(np.float32)
    X_pca = X_flat_pca.reshape(N, C, pca_components, ps, ps)
    
    with h5py.File(output_h5, 'a') as f:
        if dataset_name in f:
            del f[dataset_name]
        f.create_dataset(f"{dataset_name}/X", data=X_pca, compression='gzip')
        f.create_dataset(f"{dataset_name}/y", data=y, compression='gzip')
        f.attrs['pca_components'] = pca_components
        f.attrs['original_bands'] = B
    
    print(f"PCA applied: {B} bands -> {pca_components} bands")
    return pca

class HDF5Dataset(Dataset):
    def __init__(self, h5_file, dataset_name):
        self.h5_file = h5_file
        self.dataset_name = dataset_name
        with h5py.File(h5_file, 'r') as f:
            self.len = f[f"{dataset_name}/y"].shape[0]
    
    def __len__(self):
        return self.len
    
    def __getitem__(self, idx):
        with h5py.File(self.h5_file, 'r') as f:
            X = torch.from_numpy(f[f"{self.dataset_name}/X"][idx]).float()
            y = torch.from_numpy(f[f"{self.dataset_name}/y"][idx]).long()
        return X, y

class HSIDataset(Dataset):
    def __init__(self, X: np.ndarray, y: np.ndarray):
        self.X = torch.from_numpy(X).float()
        self.y = torch.from_numpy(y).long()
    def __len__(self):
        return len(self.y)
    def __getitem__(self, idx):
        return self.X[idx], self.y[idx]

def to_ssftt_format(X):
    if len(X) == 0:
        return X
    return X[:, np.newaxis, :, :, :]

def build_loaders(real_dir=None, aug_dir=None, mapping_path="mapping.json", split_mode="aug_real", use_pca=True, pca_components=30, patch_size=13, test_ratio=0.15, val_ratio=0.15, batch_size=64, random_state=345, fit_max_pixels=500000, num_workers=4, bg_ratio=1.5, cache_dir="hdf5_cache", force_recompute=False):
    
    extrude2final, class_names, label2idx = load_mapping(mapping_path)
    
    cache_dir = Path(cache_dir)
    cache_dir.mkdir(exist_ok=True, parents=True)
    
    config_str = f"{real_dir}_{aug_dir}_{split_mode}_{patch_size}_{random_state}_{bg_ratio}_{use_pca}_{pca_components}"
    config_hash = hashlib.md5(config_str.encode()).hexdigest()[:12]
    
    train_h5 = cache_dir / f"train_{config_hash}.h5"
    val_h5 = cache_dir / f"val_{config_hash}.h5"
    test_h5 = cache_dir / f"test_{config_hash}.h5"
    
    if not force_recompute and train_h5.exists() and val_h5.exists() and test_h5.exists():
        print("\nLoading from HDF5 cache...")
        
        with h5py.File(train_h5, 'r') as f:
            num_bands = f.attrs.get('pca_components', pca_components) if use_pca else f[f"train/X"].shape[2]
        
        train_dataset = HDF5Dataset(str(train_h5), "train")
        val_dataset = HDF5Dataset(str(val_h5), "val")
        test_dataset = HDF5Dataset(str(test_h5), "test")
        
        pin = torch.cuda.is_available()
        train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=num_workers, pin_memory=pin)
        val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=num_workers, pin_memory=pin)
        test_loader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False, num_workers=num_workers, pin_memory=pin)
        
        meta = {"class_names": class_names, "label2idx": label2idx, "num_classes": len(class_names), "num_bands": num_bands, "patch_size": patch_size, "pca": None}
        
        print(f"Train: {len(train_dataset):,} patches")
        print(f"Val: {len(val_dataset):,} patches")
        print(f"Test: {len(test_dataset):,} patches")
        
        return train_loader, val_loader, test_loader, meta
    
    print("\nNo cache found. Processing from scratch...")
    
    plots_meta = collect_plots_meta(real_dir=real_dir, aug_dir=aug_dir)
    train_meta, val_meta, test_meta = split_plots(plots_meta, split_mode=split_mode, val_ratio=val_ratio, test_ratio=test_ratio, random_state=random_state)
    
    temp_h5 = cache_dir / f"temp_raw_{config_hash}.h5"
    if temp_h5.exists():
        temp_h5.unlink()
    
    print("\nProcessing TRAIN set with parallel GPUs...")
    cnt_train = process_plots_parallel(train_meta, extrude2final, label2idx, patch_size, random_state, bg_ratio, str(temp_h5), "train", NUM_GPUS)
    
    print("\nProcessing VAL set with parallel GPUs...")
    cnt_val = process_plots_parallel(val_meta, extrude2final, label2idx, patch_size, random_state, bg_ratio, str(temp_h5), "val", NUM_GPUS)
    
    print("\nProcessing TEST set with parallel GPUs...")
    cnt_test = process_plots_parallel(test_meta, extrude2final, label2idx, patch_size, random_state, bg_ratio, str(temp_h5), "test", NUM_GPUS)
    
    print("\nDistribution: Pixels per class:")
    all_cls = sorted(set(list(cnt_train) + list(cnt_val) + list(cnt_test)))
    print(f"  Class {'':24} Train      Val      Test")
    print(f"  {'-'*25}  {'-'*9}  {'-'*9}  {'-'*9}")
    for cls in all_cls:
        print(f"  {cls:25}  {cnt_train.get(cls,0):9}  {cnt_val.get(cls,0):9}  {cnt_test.get(cls,0):9}")
    
    if use_pca:
        print(f"\nApplying PCA ({pca_components} components) to TRAIN...")
        apply_pca_to_hdf5(temp_h5, train_h5, "train", pca_components, fit_max_pixels)
        print(f"Applying PCA to VAL...")
        apply_pca_to_hdf5(temp_h5, val_h5, "val", pca_components, fit_max_pixels)
        print(f"Applying PCA to TEST...")
        apply_pca_to_hdf5(temp_h5, test_h5, "test", pca_components, fit_max_pixels)
        num_bands = pca_components
    else:
        import shutil
        shutil.copy(temp_h5, train_h5)
        shutil.copy(temp_h5, val_h5)
        shutil.copy(temp_h5, test_h5)
        with h5py.File(train_h5, 'r') as f:
            num_bands = f["train/X"].shape[2]
    
    if temp_h5.exists():
        temp_h5.unlink()
    
    train_dataset = HDF5Dataset(str(train_h5), "train")
    val_dataset = HDF5Dataset(str(val_h5), "val")
    test_dataset = HDF5Dataset(str(test_h5), "test")
    
    pin = torch.cuda.is_available()
    train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=num_workers, pin_memory=pin)
    val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=num_workers, pin_memory=pin)
    test_loader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False, num_workers=num_workers, pin_memory=pin)
    
    meta = {"class_names": class_names, "label2idx": label2idx, "num_classes": len(class_names), "num_bands": num_bands, "patch_size": patch_size, "pca": None}
    
    print(f"\n{'='*60}")
    print(f"GPUs used: {NUM_GPUS}")
    print(f"BG ratio: {bg_ratio} (bg = {bg_ratio} × annotated)")
    print(f"Classes: {len(class_names)} -> {class_names}")
