class LRUCubeCache:
    """
    Cache LRU thread-safe qui garde les N derniers cubes en RAM.
    Chaque worker DataLoader a sa propre instance → pas de contention.

    Calcul de la taille : avec 30 bandes PCA, un cube 1000×1000 = 30×4 octets ≈ 120 MB.
    maxsize=4 → ~480 MB par worker. Ajuster selon RAM disponible.
    """
    def __init__(self, maxsize=4, pca=None):
        self.cache   = OrderedDict()
        self.maxsize = maxsize
        self.pca     = pca

    def get(self, hdr_path: str, source: str) -> np.ndarray:
        if hdr_path in self.cache:
            self.cache.move_to_end(hdr_path)
            return self.cache[hdr_path]

        cube, _ = _load_envi_cube(Path(hdr_path), source)
        if self.pca is not None:
            cube = apply_pca(cube, self.pca)

        self.cache[hdr_path] = cube
        self.cache.move_to_end(hdr_path)

        if len(self.cache) > self.maxsize:
            evicted_key, _ = self.cache.popitem(last=False)

        return cube


class LazyHSIDataset(Dataset):
    """
    Dataset lazy : les patches sont extraits à la volée depuis les cubes.
    Chaque worker garde un LRUCubeCache local → un cube est chargé
    une seule fois par worker tant qu'il reste dans le cache.

    Flux par __getitem__:
      1. Récupère le cube depuis le cache (ou le charge + PCA si absent)
      2. Extrait le patch (patch_size × patch_size) centré sur (row, col)
      3. Retourne (patch_tensor, label)
    """

    def __init__(self, indices: list[dict], patch_size: int,
                 pca=None, cache_maxsize: int = 4,
                 augment: bool = False):
        self.indices       = indices
        self.patch_size    = patch_size
        self.pca           = pca
        self.cache_maxsize = cache_maxsize
        self.augment       = augment

        # Le cache est initialisé par worker (voir worker_init_fn)
        self._cache: LRUCubeCache | None = None

    def _get_cache(self) -> LRUCubeCache:
        """Initialisation lazy du cache (une fois par worker)."""
        if self._cache is None:
            self._cache = LRUCubeCache(maxsize=self.cache_maxsize, pca=self.pca)
        return self._cache

    def __len__(self):
        return len(self.indices)

    def __getitem__(self, idx):
        item   = self.indices[idx]
        hdr    = item["hdr"]
        source = item["source"]
        r, c   = item["row"], item["col"]
        label  = item["label"]

        cube   = self._get_cache().get(hdr, source)   # (B, H, W)
        B, H, W = cube.shape
        m      = self.patch_size // 2

        # Extraction du patch avec padding de bord
        r0, r1 = max(0, r - m), min(H, r + m + 1)
        c0, c1 = max(0, c - m), min(W, c + m + 1)
        patch  = cube[:, r0:r1, c0:c1]               # peut être plus petit aux bords

        # Padding si nécessaire (pixels de bord de cube)
        if patch.shape[1] != self.patch_size or patch.shape[2] != self.patch_size:
            pad = np.zeros((B, self.patch_size, self.patch_size), dtype=np.float32)
            dr  = max(0, m - r)
            dc  = max(0, m - c)
            pad[:, dr:dr+patch.shape[1], dc:dc+patch.shape[2]] = patch
            patch = pad

        x = torch.from_numpy(patch.copy()).float()    # (B, P, P)

        # Augmentation légère optionnelle (train seulement)
        if self.augment:
            k = random.randint(0, 3)
            if k:
                x = torch.rot90(x, k, dims=[1, 2])
            if random.random() < 0.5:
                x = torch.flip(x, dims=[2])

        return x, torch.tensor(label, dtype=torch.long)


def worker_init_fn(worker_id):
    """Assure que chaque worker a son propre cache (pas de partage entre workers)."""
    # Rien à faire : le cache est initialisé lazy dans __getitem__
    # On seed numpy/random pour la reproductibilité des augmentations
    seed = torch.initial_seed() % (2**32)
    np.random.seed(seed)
    random.seed(seed)


