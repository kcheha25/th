def build_loaders(
    real_dir=None,
    aug_dir=None,
    mapping_path="mapping.json",
    split_mode="aug_real",
    use_pca=True,
    pca_components=30,
    patch_size=13,
    test_ratio=0.15,
    val_ratio=0.15,
    batch_size=64,
    random_state=345,
    fit_max_pixels=500_000,
    num_workers=4,          # workers DataLoader par GPU
    bg_ratio=1.5,
    cache_dir="indices_cache",
    force_recompute=False,
    balance_train=False,
    cache_maxsize=4,        # cubes en RAM par worker (ajuster selon RAM dispo)
):
    extrude2final, class_names, label2idx = load_mapping(mapping_path)
    cache_dir = Path(cache_dir)
    cache_dir.mkdir(parents=True, exist_ok=True)

    # Hash de config pour invalidation automatique du cache
    config_str   = (f"{real_dir}_{aug_dir}_{split_mode}_{patch_size}_"
                    f"{random_state}_{bg_ratio}_{pca_components if use_pca else 0}_"
                    f"{balance_train}")
    config_hash  = hashlib.md5(config_str.encode()).hexdigest()[:12]

    # ── Chargement du cache indices si disponible ──────────────────────────
    indices_data = None
    if not force_recompute:
        indices_data = load_indices_npz(cache_dir, config_hash)

    if indices_data is None:
        print("\n" + "="*60)
        print("PAS DE CACHE — COLLECTE DES INDICES")
        print("="*60)

        plots_meta = collect_plots_meta(real_dir=real_dir, aug_dir=aug_dir)
        train_meta, val_meta, test_meta = split_plots(
            plots_meta, split_mode=split_mode,
            val_ratio=val_ratio, test_ratio=test_ratio,
            random_state=random_state
        )

        # PCA (fittée une fois, mise en cache)
        pca_model = None
        if use_pca:
            real_meta = [m for m in plots_meta if m["source"] == "real"]
            if real_meta:
                pca_model = fit_or_load_pca(
                    real_meta, pca_components, cache_dir,
                    config_hash, fit_max_pixels
                )

        # Collecte parallèle des indices (CPU, rapide)
        cpu_workers = min(16, len(plots_meta))

        train_idx, cnt_train = collect_all_indices(
            train_meta, extrude2final, label2idx, bg_ratio, random_state, pca_model, cpu_workers)
        val_idx, cnt_val = collect_all_indices(
            val_meta, extrude2final, label2idx, bg_ratio, random_state, pca_model, cpu_workers)
        test_idx, cnt_test = collect_all_indices(
            test_meta, extrude2final, label2idx, bg_ratio, random_state, pca_model, cpu_workers)

        if balance_train:
            print("\nBalancing train...")
            train_idx = balance_indices(train_idx, label2idx, random_state)

        indices_data = {"train": train_idx, "val": val_idx, "test": test_idx}
        save_indices_npz(indices_data, cache_dir, config_hash)

        # Affichage distribution
        print("\nDistribution des patches:")
        idx2name = {v: k for k, v in label2idx.items()}
        all_cls  = sorted(set(list(cnt_train) + list(cnt_val) + list(cnt_test)))
        print(f"  {'Classe':25}  {'Train':>10}  {'Val':>10}  {'Test':>10}")
        print(f"  {'-'*25}  {'-'*10}  {'-'*10}  {'-'*10}")
        for cls in all_cls:
            print(f"  {cls:25}  {cnt_train.get(cls,0):10,}  "
                  f"{cnt_val.get(cls,0):10,}  {cnt_test.get(cls,0):10,}")
    else:
        # Recharger la PCA depuis cache
        pca_model = None
        if use_pca:
            pca_path = cache_dir / f"pca_{config_hash}.pkl"
            if pca_path.exists():
                with open(pca_path, "rb") as f:
                    pca_model = pickle.load(f)
                print(f"PCA rechargée: {pca_path.name}")

    # ── Construction des Datasets ──────────────────────────────────────────
    num_bands = pca_components if (use_pca and pca_model is not None) else None

    train_dataset = LazyHSIDataset(
        indices_data["train"], patch_size, pca_model,
        cache_maxsize=cache_maxsize, augment=True
    )
    val_dataset = LazyHSIDataset(
        indices_data["val"], patch_size, pca_model,
        cache_maxsize=cache_maxsize, augment=False
    )
    test_dataset = LazyHSIDataset(
        indices_data["test"], patch_size, pca_model,
        cache_maxsize=cache_maxsize, augment=False
    )

    pin = torch.cuda.is_available()

    # ── DataLoaders ────────────────────────────────────────────────────────
    # Pour multi-GPU avec DistributedDataParallel, utiliser DistributedSampler.
    # En mode non-distribué (DataParallel simple), shuffle=True suffit.
    train_loader = DataLoader(
        train_dataset, batch_size=batch_size,
        shuffle=True, num_workers=num_workers,
        pin_memory=pin, worker_init_fn=worker_init_fn,
        persistent_workers=(num_workers > 0)
    )
    val_loader = DataLoader(
        val_dataset, batch_size=batch_size,
        shuffle=False, num_workers=num_workers,
        pin_memory=pin, worker_init_fn=worker_init_fn,
        persistent_workers=(num_workers > 0)
    )
    test_loader = DataLoader(
        test_dataset, batch_size=batch_size,
        shuffle=False, num_workers=num_workers,
        pin_memory=pin, worker_init_fn=worker_init_fn,
        persistent_workers=(num_workers > 0)
    )

    meta = {
        "class_names": class_names,
        "label2idx": label2idx,
        "num_classes": len(class_names),
        "num_bands": num_bands,
        "patch_size": patch_size,
        "balance_train": balance_train,
    }

    print(f"\n{'='*60}")
    print("PRÊT POUR L'ENTRAÎNEMENT")
    print(f"  Train: {len(train_dataset):,} patches | Val: {len(val_dataset):,} | Test: {len(test_dataset):,}")
    print(f"  Bandes: {num_bands} | Patch: {patch_size}×{patch_size}")
    print(f"  Cache cubes par worker: {cache_maxsize} (≈{cache_maxsize * 120:.0f} MB/worker)")
    print(f"  Workers DataLoader: {num_workers}")
    print(f"{'='*60}\n")

    return train_loader, val_loader, test_loader, meta


