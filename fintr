def load_mapping(mapping_path: str):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names = final_classes + ["background"]
    label2idx = {name: i for i, name in enumerate(class_names)}
    print(f"Mapping: {len(extrude2final)} labels -> {len(final_classes)} classes + background")
    return extrude2final, class_names, label2idx

def _load_envi_real(hdr_path: Path):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wavelengths = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3 and cube.shape[2] == len(wavelengths) and len(wavelengths) > 0:
        cube = cube.transpose(2, 0, 1)
    if cube.ndim != 3:
        raise ValueError(f"Invalid cube format: shape {cube.shape}")
    return cube, wavelengths

def _load_envi_augmented(hdr_path: Path):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wavelengths = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3:
        if len(wavelengths) > 0 and cube.shape[1] == len(wavelengths):
            cube = cube.transpose(1, 0, 2)
        elif cube.shape[0] == len(wavelengths):
            pass
        else:
            print(f"  Warning: Unexpected format for {hdr_path.name}: shape {cube.shape}, expected bands {len(wavelengths)}")
    if cube.ndim != 3:
        raise ValueError(f"Invalid cube format after transform: shape {cube.shape}")
    return cube, wavelengths

def _load_envi_auto(hdr_path: Path, source: str = "real"):
    if source == "real":
        return _load_envi_real(hdr_path)
    else:
        return _load_envi_augmented(hdr_path)

def _load_shapes(json_path: Path):
    with open(json_path) as f:
        ann = json.load(f)
    return ann.get("shapes", [])

def _iter_real_dir(real_dir: Path):
    for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
        m = re.match(r"plot_(\d+)_cube", hdr.stem)
        if not m:
            continue
        jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
        if jsn.exists():
            yield "real", hdr.stem, hdr, jsn
        else:
            print(f"Warning: No JSON for {hdr.name} -> ignored")

def _iter_aug_dir(aug_dir: Path):
    for hdr in sorted(aug_dir.glob("*.hdr")):
        if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")):
            continue
        jsn = aug_dir / f"{hdr.stem}.json"
        if not jsn.exists():
            print(f"Warning: No JSON for {hdr.name} -> ignored")
            continue
        source = "circle" if "circle" in hdr.stem.lower() else "aug"
        yield source, hdr.stem, hdr, jsn

def collect_plots_meta(real_dir=None, aug_dir=None):
    meta_list = []
    if real_dir is not None:
        real_dir = Path(real_dir)
        if real_dir.exists():
            for source, name, hdr, jsn in _iter_real_dir(real_dir):
                meta_list.append({"source": source, "name": name, "hdr": hdr, "jsn": jsn})
            n_real = sum(1 for m in meta_list if m["source"] == "real")
            print(f"Info: real_dir -> {n_real} real plots")
        else:
            print(f"Warning: real_dir='{real_dir}' not found")
    if aug_dir is not None:
        aug_dir = Path(aug_dir)
        if aug_dir.exists():
            before = len(meta_list)
            for source, name, hdr, jsn in _iter_aug_dir(aug_dir):
                meta_list.append({"source": source, "name": name, "hdr": hdr, "jsn": jsn})
            print(f"Info: aug_dir -> {len(meta_list) - before} augmented")
        else:
            print(f"Warning: aug_dir='{aug_dir}' not found")
    if not meta_list:
        raise RuntimeError("No plots found. Check --real_dir and --aug_dir.")
    n_real = sum(1 for m in meta_list if m["source"] == "real")
    n_aug = len(meta_list) - n_real
    print(f"Info: Total {len(meta_list)} plots ({n_real} real | {n_aug} augmented)\n")
    return meta_list

def _rasterize_polygon_gpu(points, H, W, device):
    pts = torch.tensor(points, dtype=torch.float32, device=device)
    n = len(pts)
    rows = torch.arange(H, device=device, dtype=torch.float32) + 0.5
    cols = torch.arange(W, device=device, dtype=torch.float32) + 0.5
    grid_c, grid_r = torch.meshgrid(cols, rows, indexing="xy")
    px = grid_c.reshape(-1)
    py = grid_r.reshape(-1)
    x1 = pts[:, 0]
    y1 = pts[:, 1]
    idx_next = (torch.arange(n, device=device) + 1) % n
    x2 = pts[idx_next, 0]
    y2 = pts[idx_next, 1]
    px_ = px.unsqueeze(1)
    py_ = py.unsqueeze(1)
    cond1 = (y1 < py_) != (y2 < py_)
    denom = (y2 - y1).clone()
    safe_denom = torch.where(denom == 0, torch.ones_like(denom) * 1e-10, denom)
    x_intersect = x1 + (py_ - y1) * (x2 - x1) / safe_denom
    cond2 = px_ < x_intersect
    inside = (cond1 & cond2).sum(dim=1) % 2 == 1
    return inside.reshape(H, W)

def build_label_map_gpu(cube_BHW, shapes, extrude2final, label2idx, device):
    B, H, W = cube_BHW.shape
    bg_idx = label2idx["background"]
    label_map_gpu = torch.full((H, W), bg_idx, dtype=torch.int64, device=device)
    for shape in shapes:
        raw_label = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw_label.lower() == "trou" or stype not in ("polygon", "rectangle"):
            continue
        final = extrude2final.get(raw_label)
        if final is None:
            print(f"  Warning: label '{raw_label}' missing from mapping -> ignored")
            continue
        points = shape["points"]
        if len(points) < 3:
            continue
        try:
            mask = _rasterize_polygon_gpu(points, H, W, device)
            label_map_gpu[mask] = label2idx[final]
        except Exception as e:
            print(f"  Warning: rasterization '{raw_label}' failed: {e}")
    n_bg = int((label_map_gpu == bg_idx).sum().item())
    n_total = H * W
    print(f"    Label map: {n_total} pixels | {n_total - n_bg} annotated | {n_bg} raw background")
    label_map = label_map_gpu.cpu().numpy()
    del label_map_gpu
    if device.type == "cuda":
        torch.cuda.empty_cache()
    return label_map

def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15, test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        val = aug[:n_val]
        train = aug[n_val:]
        test = real
        print(f"Split aug_real: train={len(train)} | val={len(val)} | test={len(test)}")
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test = max(1, int(n * test_ratio))
        n_val = max(1, int(n * val_ratio))
        test = all_p[:n_test]
        val = all_p[n_test:n_test + n_val]
        train = all_p[n_test + n_val:]
        print(f"Split shuffle: train={len(train)} | val={len(val)} | test={len(test)}")
    else:
        raise ValueError(f"Unknown split_mode: '{split_mode}'")
    return train, val, test

def balance_background(labels: np.ndarray, bg_idx: int, rng: np.random.Generator, bg_ratio: float = 1.5) -> np.ndarray:
    bg_mask = labels == bg_idx
    fg_mask = ~bg_mask
    n_fg = int(fg_mask.sum())
    n_bg = int(bg_mask.sum())
    keep_mask = fg_mask.copy()
    if n_fg == 0:
        return keep_mask
    n_bg_keep = min(int(n_fg * bg_ratio), n_bg)
    if n_bg_keep > 0:
        bg_indices = np.where(bg_mask)[0]
        chosen = rng.choice(bg_indices, size=n_bg_keep, replace=False)
        keep_mask[chosen] = True
    return keep_mask

def extract_patches_gpu(cube_BHW: np.ndarray, coords: np.ndarray, patch_size: int, device: torch.device) -> torch.Tensor:
    B, H, W = cube_BHW.shape
    margin = patch_size // 2
    cube_t = torch.from_numpy(cube_BHW).unsqueeze(0).to(device=device, dtype=torch.float32)
    cube_padded = F.pad(cube_t, (margin, margin, margin, margin), mode="constant", value=0)
    unfolded = F.unfold(cube_padded, kernel_size=patch_size, stride=1)
    rows = coords[:, 0]
    cols = coords[:, 1]
    lin_idx = torch.from_numpy((rows * W + cols).astype(np.int64)).to(device)
    selected = unfolded[0, :, lin_idx].T
    patches = selected.reshape(-1, B, patch_size, patch_size)
    del cube_t, cube_padded, unfolded, selected
    if device.type == "cuda":
        torch.cuda.empty_cache()
    return patches

def fit_pca_on_real_cubes(real_meta_list, pca_components, fit_max_pixels=500000):
    print(f"\nFitting PCA on {len(real_meta_list)} real cubes only...")
    all_pixels = []
    for meta in real_meta_list:
        try:
            cube, _ = _load_envi_auto(meta["hdr"], meta["source"])
            B, H, W = cube.shape
            n_samples = min(20000, H * W)
            indices = np.random.choice(H * W, n_samples, replace=False)
            pixels = cube.reshape(B, -1)[:, indices].T
            all_pixels.append(pixels)
            print(f"  Sampled {n_samples:,} pixels from {meta['name']}")
            del cube
            gc.collect()
        except Exception as e:
            print(f"  Warning: {meta['name']} failed: {e}")
            continue
    all_pixels = np.concatenate(all_pixels, axis=0)
    print(f"  Total pixels for PCA: {len(all_pixels):,}")
    if len(all_pixels) > fit_max_pixels:
        idx = np.random.choice(len(all_pixels), fit_max_pixels, replace=False)
        all_pixels = all_pixels[idx]
        print(f"  Reduced to {fit_max_pixels:,} pixels for fitting")
    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(all_pixels)
    print(f"  PCA explained variance: {pca.explained_variance_ratio_.sum():.3f}")
    return pca

def transform_cube_pca(cube, pca, chunk_size=20000):
    B, H, W = cube.shape
    cube_flat = cube.reshape(B, -1).T
    transformed = []
    for start in range(0, len(cube_flat), chunk_size):
        end = min(start + chunk_size, len(cube_flat))
        chunk = cube_flat[start:end]
        transformed.append(pca.transform(chunk))
    cube_pca = np.concatenate(transformed, axis=0).T.reshape(pca.n_components_, H, W)
    return cube_pca.astype(np.float32)

def collect_indices_for_plot(meta, extrude2final, label2idx, random_state, bg_ratio, device_id, pca=None):
    device = torch.device(f"cuda:{device_id}")
    name = meta["name"]
    source = meta["source"]
    rng = np.random.default_rng(seed=random_state + hash(name) % 10000)
    bg_idx = label2idx["background"]
    try:
        cube, _ = _load_envi_auto(meta["hdr"], source)
        shapes = _load_shapes(meta["jsn"])
    except Exception as e:
        print(f"  Warning: {name} ignored: {e}")
        return None
    if pca is not None:
        cube = transform_cube_pca(cube, pca)
    B, H, W = cube.shape
    label_map = build_label_map_gpu(cube, shapes, extrude2final, label2idx, device)
    rows, cols = np.where(label_map >= 0)
    labels_all = label_map[rows, cols]
    del label_map
    gc.collect()
    if len(rows) == 0:
        print(f"  Skip: {name} — no pixels")
        del cube
        gc.collect()
        return None
    keep_mask = balance_background(labels_all, bg_idx, rng, bg_ratio)
    rows_k = rows[keep_mask]
    cols_k = cols[keep_mask]
    labels_k = labels_all[keep_mask]
    n_fg = int((labels_all != bg_idx).sum())
    n_bg_raw = int((labels_all == bg_idx).sum())
    n_bg_kept = int((labels_k == bg_idx).sum())
    del labels_all, rows, cols, keep_mask, cube
    if device.type == "cuda":
        torch.cuda.empty_cache()
    gc.collect()
    if len(rows_k) == 0:
        print(f"  Skip: {name} — 0 pixels after balancing")
        return None
    indices_list = []
    for r, c, lbl in zip(rows_k, cols_k, labels_k):
        indices_list.append({
            'cube_name': name,
            'source': source,
            'row': int(r),
            'col': int(c),
            'label': int(lbl)
        })
    print(f"  GPU {device_id} | {source:6} | {name:30} | annotated={n_fg:6} | raw bg={n_bg_raw:7} -> kept bg={n_bg_kept:6} | indices={len(indices_list):7}")
    return indices_list

def collect_indices_parallel(plot_meta_list, extrude2final, label2idx, random_state, bg_ratio, num_gpus=NUM_GPUS, pca=None):
    print(f"\nCollecting indices from {len(plot_meta_list)} plots using {num_gpus} GPUs")
    all_indices = []
    class_counts = defaultdict(int)
    idx2name = {v: k for k, v in label2idx.items()}
    plot_index = 0
    while plot_index < len(plot_meta_list):
        batch_plots = []
        for gpu_id in range(num_gpus):
            if plot_index + gpu_id < len(plot_meta_list):
                batch_plots.append((plot_index + gpu_id, plot_meta_list[plot_index + gpu_id], gpu_id))
        if not batch_plots:
            break
        with ThreadPoolExecutor(max_workers=num_gpus) as executor:
            futures = {}
            for idx, meta, gpu_id in batch_plots:
                future = executor.submit(collect_indices_for_plot, meta, extrude2final, label2idx, random_state, bg_ratio, gpu_id, pca)
                futures[future] = (idx, meta)
            for future in as_completed(futures):
                idx, meta = futures[future]
                try:
                    indices = future.result()
                    if indices is not None:
                        all_indices.extend(indices)
                        for item in indices:
                            class_counts[idx2name[item['label']]] += 1
                except Exception as e:
                    print(f"  Error processing {meta['name']}: {e}")
        plot_index += num_gpus
        torch.cuda.empty_cache()
        gc.collect()
    return all_indices, class_counts

def balance_train_indices(train_indices, label2idx, random_state=345):
    print("\nBalancing TRAIN indices per class...")
    indices_by_label = defaultdict(list)
    for item in train_indices:
        label = item['label']
        indices_by_label[label].append(item)
    min_count = min(len(v) for v in indices_by_label.values())
    print(f"  Minimum patches per class: {min_count}")
    rng = random.Random(random_state)
    balanced_indices = []
    for label, indices in indices_by_label.items():
        rng.shuffle(indices)
        balanced_indices.extend(indices[:min_count])
        print(f"  Class {label}: {len(indices)} -> {min_count}")
    rng.shuffle(balanced_indices)
    print(f"  Total balanced train indices: {len(balanced_indices):,}")
    return balanced_indices

def extract_and_save_patches_for_split(indices_list, split_name, patch_size, real_dir, aug_dir, output_h5, random_state, num_gpus=NUM_GPUS, pca=None, balance_train=False, label2idx=None):
    print(f"\nExtracting and saving {split_name} patches directly to HDF5...")
    if len(indices_list) == 0:
        print(f"  No {split_name} indices, skipping")
        return 0
    if balance_train and split_name == "train":
        indices_list = balance_train_indices(indices_list, label2idx, random_state)
    random.seed(random_state)
    random.shuffle(indices_list)
    with h5py.File(output_h5, 'a') as f:
        if split_name in f:
            del f[split_name]
        f.create_dataset(f"{split_name}/X", shape=(0, 1, 1, 1), maxshape=(None, None, None, None), dtype=np.float32, chunks=True, compression='gzip', compression_opts=9)
        f.create_dataset(f"{split_name}/y", shape=(0,), maxshape=(None,), dtype=np.int64, chunks=True, compression='gzip', compression_opts=9)
    total_samples = 0
    lock = threading.Lock()
    def process_batch(batch_indices, device_id):
        nonlocal total_samples
        device = torch.device(f"cuda:{device_id}")
        all_patches = []
        all_labels = []
        for item in batch_indices:
            cube_name = item['cube_name']
            source = item['source']
            r, c, lbl = item['row'], item['col'], item['label']
            if source == "real":
                hdr_path = Path(real_dir) / f"{cube_name}.hdr"
            else:
                hdr_path = Path(aug_dir) / f"{cube_name}.hdr"
            cube, _ = _load_envi_auto(hdr_path, source)
            if pca is not None:
                cube = transform_cube_pca(cube, pca)
            B, H, W = cube.shape
            margin = patch_size // 2
            r_start = max(0, r - margin)
            r_end = min(H, r + margin + 1)
            c_start = max(0, c - margin)
            c_end = min(W, c + margin + 1)
            patch = cube[:, r_start:r_end, c_start:c_end]
            if patch.shape[1] != patch_size or patch.shape[2] != patch_size:
                patch_padded = np.zeros((B, patch_size, patch_size), dtype=np.float32)
                r_offset = max(0, margin - r)
                c_offset = max(0, margin - c)
                patch_padded[:, r_offset:r_offset+patch.shape[1], c_offset:c_offset+patch.shape[2]] = patch
                patch = patch_padded
            all_patches.append(patch)
            all_labels.append(lbl)
            del cube
            if device.type == "cuda":
                torch.cuda.empty_cache()
        if all_patches:
            X_batch = np.stack(all_patches)
            y_batch = np.array(all_labels)
            with lock:
                with h5py.File(output_h5, 'a') as f:
                    dset_x = f[f"{split_name}/X"]
                    dset_y = f[f"{split_name}/y"]
                    if total_samples == 0:
                        dset_x.resize((len(y_batch), X_batch.shape[1], X_batch.shape[2], X_batch.shape[3]))
                        dset_y.resize((len(y_batch),))
                    else:
                        dset_x.resize((total_samples + len(y_batch), X_batch.shape[1], X_batch.shape[2], X_batch.shape[3]))
                        dset_y.resize((total_samples + len(y_batch),))
                    dset_x[total_samples:total_samples + len(y_batch)] = X_batch
                    dset_y[total_samples:total_samples + len(y_batch)] = y_batch
                    total_samples += len(y_batch)
        return len(y_batch) if all_patches else 0
    batch_size = 1000
    all_batches = [indices_list[i:i+batch_size] for i in range(0, len(indices_list), batch_size)]
    with ThreadPoolExecutor(max_workers=num_gpus) as executor:
        futures = []
        for i, batch in enumerate(all_batches):
            gpu_id = i % num_gpus
            futures.append(executor.submit(process_batch, batch, gpu_id))
        for future in as_completed(futures):
            try:
                count = future.result()
                print(f"  {split_name}: processed batch, total so far: {total_samples}")
            except Exception as e:
                print(f"  Error in batch: {e}")
    print(f"  Total {split_name} patches saved: {total_samples:,}")
    return total_samples

def save_indices(indices_data: dict, cache_dir: str = "indices_cache"):
    cache_dir = Path(cache_dir)
    cache_dir.mkdir(exist_ok=True, parents=True)
    config = indices_data['config']
    config_str = f"{config['real_dir']}_{config['aug_dir']}_{config['split_mode']}_{config['patch_size']}_{config['random_state']}_{config.get('bg_ratio', 1.5)}_{config.get('pca_components', 0)}_{config.get('balance_train', False)}"
    config_hash = hashlib.md5(config_str.encode()).hexdigest()[:12]
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    cache_file = cache_dir / f"indices_{config_hash}_{timestamp}.pkl"
    existing_files = sorted(cache_dir.glob(f"indices_{config_hash}_*.pkl"))
    for old_file in existing_files[:-5]:
        old_file.unlink()
        print(f"  Cache: removed old cache {old_file.name}")
    with open(cache_file, 'wb') as f:
        pickle.dump(indices_data, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = cache_file.stat().st_size / 1e6
    print(f"\nCache saved: {cache_file.name} ({size_mb:.1f} MB)")
    print(f"  Train: {len(indices_data['train']):,} indices")
    print(f"  Val: {len(indices_data['val']):,} indices")
    print(f"  Test: {len(indices_data['test']):,} indices")
    return cache_file

def load_indices(cache_dir: str = "indices_cache", config_hash: str = None):
    cache_dir = Path(cache_dir)
    if not cache_dir.exists():
        return None
    if config_hash:
        cache_files = list(cache_dir.glob(f"indices_{config_hash}_*.pkl"))
    else:
        cache_files = list(cache_dir.glob("indices_*.pkl"))
    if not cache_files:
        return None
    latest = max(cache_files, key=lambda x: x.stem)
    print(f"\nCache loaded: {latest.name}")
    with open(latest, 'rb') as f:
        indices_data = pickle.load(f)
    size_mb = latest.stat().st_size / 1e6
    print(f"  Size: {size_mb:.1f} MB")
    print(f"  Train: {len(indices_data['train']):,} indices")
    print(f"  Val: {len(indices_data['val']):,} indices")
    print(f"  Test: {len(indices_data['test']):,} indices")
    return indices_data

class HDF5Dataset(Dataset):
    def __init__(self, h5_file, split_name):
        self.h5_file = h5_file
        self.split_name = split_name
        with h5py.File(h5_file, 'r') as f:
            self.len = f[f"{split_name}/y"].shape[0]
    def __len__(self):
        return self.len
    def __getitem__(self, idx):
        with h5py.File(self.h5_file, 'r') as f:
            X = torch.from_numpy(f[f"{self.split_name}/X"][idx]).float()
            y = torch.from_numpy(f[f"{self.split_name}/y"][idx]).long()
        return X, y

def build_loaders(real_dir=None, aug_dir=None, mapping_path="mapping.json", split_mode="aug_real", use_pca=True, pca_components=30, patch_size=13, test_ratio=0.15, val_ratio=0.15, batch_size=64, random_state=345, fit_max_pixels=500000, num_workers=4, bg_ratio=1.5, cache_dir="indices_cache", force_recompute=False, balance_train=False):
