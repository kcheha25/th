def load_mapping(mapping_path):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names = final_classes + ["background"]
    label2idx = {name: i for i, name in enumerate(class_names)}
    return extrude2final, class_names, label2idx
def _load_envi_cube(hdr_path, source):
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wl = [float(w) for w in img.metadata.get("wavelength", [])]
    if cube.ndim == 3:
        if source == "real" and wl and cube.shape[2] == len(wl):
            cube = cube.transpose(2, 0, 1)
        elif source != "real" and wl and cube.shape[1] == len(wl):
            cube = cube.transpose(1, 0, 2)
    if cube.ndim != 3:
        raise ValueError(f"Cube invalide : {cube.shape}")
    return cube, wl
def _load_shapes(json_path):
    with open(json_path) as f:
        return json.load(f).get("shapes", [])
def collect_plots_meta(real_dir=None, aug_dir=None):
    meta_list = []
    if real_dir:
        real_dir = Path(real_dir)
        for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
            m = re.match(r"plot_(\d+)_cube", hdr.stem)
            if not m:
                continue
            jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
            if jsn.exists():
                meta_list.append({"source": "real", "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if aug_dir:
        aug_dir = Path(aug_dir)
        for hdr in sorted(aug_dir.glob("*.hdr")):
            if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")):
                continue
            jsn = aug_dir / f"{hdr.stem}.json"
            if not jsn.exists():
                continue
            source = "circle" if "circle" in hdr.stem.lower() else "aug"
            meta_list.append({"source": source, "name": hdr.stem, "hdr": hdr, "jsn": jsn})
    if not meta_list:
        raise RuntimeError("Aucun plot trouvé.")
    return meta_list
def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15, test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        train, val, test = aug[n_val:], aug[:n_val], real
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test, n_val = max(1, int(n * test_ratio)), max(1, int(n * val_ratio))
        test = all_p[:n_test]
        val = all_p[n_test:n_test + n_val]
        train = all_p[n_test + n_val:]
    else:
        raise ValueError(f"split_mode inconnu : {split_mode}")
    return train, val, test
def _rasterize_cpu(points, H, W):
    pts = np.array(points, dtype=np.float32)
    n = len(pts)
    cols = np.arange(W, dtype=np.float32) + 0.5
    rows = np.arange(H, dtype=np.float32) + 0.5
    gc_, gr_ = np.meshgrid(cols, rows)
    px, py = gc_.ravel(), gr_.ravel()
    inside = np.zeros(len(px), dtype=bool)
    x1, y1 = pts[:, 0], pts[:, 1]
    x2, y2 = np.roll(x1, -1), np.roll(y1, -1)
    for i in range(n):
        dy = y2[i] - y1[i]
        if abs(dy) < 1e-10:
            continue
        cond = (y1[i] < py) != (y2[i] < py)
        xi = x1[i] + (py - y1[i]) * (x2[i] - x1[i]) / dy
        inside ^= cond & (px < xi)
    return inside.reshape(H, W)
def build_label_map(H, W, shapes, extrude2final, label2idx):
    bg = label2idx["background"]
    lm = np.full((H, W), bg, dtype=np.int32)
    for shape in shapes:
        raw = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw.lower() == "trou" or stype not in ("polygon", "rectangle"):
            continue
        final = extrude2final.get(raw)
        if final is None:
            continue
        pts = shape["points"]
        if len(pts) < 3:
            continue
        try:
            lm[_rasterize_cpu(pts, H, W)] = label2idx[final]
        except Exception as e:
            print(f"Warning rasterisation '{raw}': {e}")
    return lm
def fit_or_load_pca(real_meta_list, pca_components, cache_dir, config_hash, fit_max_pixels=500_000):
    path = Path(cache_dir) / f"pca_{config_hash}.pkl"
    if path.exists():
        with open(path, "rb") as f:
            return pickle.load(f)
    pixels = []
    for meta in real_meta_list:
        try:
            cube, _ = _load_envi_cube(meta["hdr"], meta["source"])
            B, H, W = cube.shape
            n = min(20_000, H * W)
            idx = np.random.choice(H * W, n, replace=False)
            pixels.append(cube.reshape(B, -1)[:, idx].T)
            del cube
            gc.collect()
        except Exception as e:
            print(f"Warning {meta['name']}: {e}")
    pixels = np.concatenate(pixels)
    if len(pixels) > fit_max_pixels:
        pixels = pixels[np.random.choice(len(pixels), fit_max_pixels, replace=False)]
    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(pixels)
    del pixels
    gc.collect()
    with open(path, "wb") as f:
        pickle.dump(pca, f, protocol=pickle.HIGHEST_PROTOCOL)
    return pca
def apply_pca_chunked(cube, pca, chunk=30_000):
    B, H, W = cube.shape
    flat = cube.reshape(B, -1).T
    out = np.empty((H * W, pca.n_components_), dtype=np.float32)
    for s in range(0, len(flat), chunk):
        out[s:s + chunk] = pca.transform(flat[s:s + chunk])
    del flat
    return out.T.reshape(pca.n_components_, H, W).astype(np.float32)
def balance_background(labels, bg_idx, rng, bg_ratio=1.5):
    fg = labels != bg_idx
    keep = fg.copy()
    n_fg = int(fg.sum())
    if n_fg > 0:
        bg_pool = np.where(~fg)[0]
        n_keep = min(int(n_fg * bg_ratio), len(bg_pool))
        if n_keep > 0:
            keep[rng.choice(bg_pool, n_keep, replace=False)] = True
    return keep
def _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device):
    B, H, W = cube_pca.shape
    m = patch_size // 2
    cube_t = torch.from_numpy(cube_pca).to(device, non_blocking=True).unsqueeze(0)
    padded = F.pad(cube_t, (m, m, m, m), mode="constant", value=0)
    del cube_t
    n_patches = len(rows_k)
    all_patches = np.empty((n_patches, B, patch_size, patch_size), dtype=np.float32)
    for start in range(0, n_patches, PATCH_EXTRACT_BATCH):
        end = min(start + PATCH_EXTRACT_BATCH, n_patches)
        rs = rows_k[start:end]
        cs = cols_k[start:end]
        batch = torch.stack([
            padded[0, :, r:r + patch_size, c:c + patch_size]
            for r, c in zip(rs, cs)
        ])
        all_patches[start:end] = batch.cpu().numpy()
        del batch
    del padded
    torch.cuda.empty_cache()
    return all_patches
def _gpu_worker(gpu_id, task_queue, h5_path, split_name, patch_size,
                extrude2final, label2idx, bg_ratio, random_state,
                pca, write_lock, counters):
    device = torch.device(f"cuda:{gpu_id}")
    bg_idx = label2idx["background"]
    while True:
        try:
            meta = task_queue.get(timeout=30)
        except queue.Empty:
            break
        if meta is None:
            task_queue.task_done()
            break
        name = meta["name"]
        source = meta["source"]
        rng = np.random.default_rng(random_state + hash(name) % 10_000)
        try:
            cube_raw, _ = _load_envi_cube(meta["hdr"], source)
            if pca is not None:
                cube_pca = apply_pca_chunked(cube_raw, pca)
                del cube_raw
                gc.collect()
            else:
                cube_pca = cube_raw
            B, H, W = cube_pca.shape
            shapes = _load_shapes(meta["jsn"])
            label_map = build_label_map(H, W, shapes, extrude2final, label2idx)
            r_all, c_all = np.where(label_map >= 0)
            labels_all = label_map[r_all, c_all]
            del label_map
            keep = balance_background(labels_all, bg_idx, rng, bg_ratio)
            rows_k = r_all[keep].astype(np.int32)
            cols_k = c_all[keep].astype(np.int32)
            labels_k = labels_all[keep].astype(np.int32)
            del r_all, c_all, labels_all, keep
            gc.collect()
            if len(rows_k) == 0:
                del cube_pca
                gc.collect()
                task_queue.task_done()
                continue
            all_patches = _extract_patches_on_gpu(cube_pca, rows_k, cols_k, patch_size, device)
            del cube_pca
            gc.collect()
            n_extracted = len(all_patches)
            with write_lock:
                with h5py.File(h5_path, 'a') as f:
                    dset_x = f[f"{split_name}/X"]
                    dset_y = f[f"{split_name}/y"]
                    cur = dset_x.shape[0]
                    new_n = cur + n_extracted
                    dset_x.resize((new_n, B, patch_size, patch_size))
                    dset_y.resize((new_n,))
                    dset_x[cur:new_n] = all_patches
                    dset_y[cur:new_n] = labels_k
            del all_patches, labels_k, rows_k, cols_k
            gc.collect()
            with counters["lock"]:
                counters["patches"] += n_extracted
                counters["cubes"] += 1
                done = counters["cubes"]
                total = counters["total"]
                ptch = counters["patches"]
                if done % 10 == 0 or done == total:
                    print(f"  GPU{gpu_id} | [{split_name}] {done}/{total} cubes "
                          f"| {ptch:,} patches "
                          f"| VRAM {torch.cuda.memory_allocated(device)/1e9:.2f} GB")
        except Exception as e:
            print(f"  GPU{gpu_id} | {name} : {e}")
        finally:
            task_queue.task_done()
            torch.cuda.empty_cache()
def extract_split_to_hdf5(meta_list, split_name, patch_size, extrude2final,
                           label2idx, bg_ratio, random_state, pca, h5_path,
                           balance_train=False):
    if not meta_list:
        return 0
    shuffled = meta_list[:]
    random.shuffle(shuffled)
    if pca is not None:
        num_bands = pca.n_components_
    else:
        tmp, _ = _load_envi_cube(shuffled[0]["hdr"], shuffled[0]["source"])
        num_bands = tmp.shape[0]
        del tmp
        gc.collect()
    with h5py.File(h5_path, 'a') as f:
        if split_name in f:
            del f[split_name]
        f.create_dataset(
            f"{split_name}/X",
            shape=(0, num_bands, patch_size, patch_size),
            maxshape=(None, num_bands, patch_size, patch_size),
            dtype=np.float32,
            chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size),
            compression='lzf')
        f.create_dataset(
            f"{split_name}/y",
            shape=(0,), maxshape=(None,),
            dtype=np.int64,
            chunks=(4096,),
            compression='lzf')
    task_q = queue.Queue(maxsize=PREFETCH_QUEUE_SIZE)
    counters = {"cubes": 0, "patches": 0, "total": len(shuffled), "lock": threading.Lock()}
    write_lock = threading.Lock()
    workers = []
    for gpu_id in range(NUM_GPUS):
        t = threading.Thread(
            target=_gpu_worker,
            args=(gpu_id, task_q, h5_path, split_name, patch_size,
                  extrude2final, label2idx, bg_ratio, random_state,
                  pca, write_lock, counters),
            daemon=True)
        t.start()
        workers.append(t)
    for meta in shuffled:
        task_q.put(meta)
    for _ in range(NUM_GPUS):
        task_q.put(None)
    for t in workers:
        t.join()
    total_patches = counters["patches"]
    if balance_train and split_name == "train" and total_patches > 0:
        total_patches = _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state)
    return total_patches
def _balance_hdf5_streaming(h5_path, split_name, patch_size, num_bands, random_state, read_chunk=50_000):
    with h5py.File(h5_path, 'r') as f:
        y_all = f[f"{split_name}/y"][:]
        n_tot = len(y_all)
    by_label = defaultdict(list)
    for i, lbl in enumerate(y_all):
        by_label[int(lbl)].append(i)
    del y_all
    min_count = min(len(v) for v in by_label.values())
    rng = random.Random(random_state)
    kept_idx = []
    for lbl, idxs in sorted(by_label.items()):
        rng.shuffle(idxs)
        kept_idx.extend(idxs[:min_count])
    rng.shuffle(kept_idx)
    kept_idx = np.array(kept_idx, dtype=np.int64)
    sort_order = np.argsort(kept_idx)
    sorted_kept = kept_idx[sort_order]
    n_new = len(kept_idx)
    tmp_split = f"{split_name}_tmp"
    with h5py.File(h5_path, 'a') as f:
        if tmp_split in f:
            del f[tmp_split]
        f.create_dataset(
            f"{tmp_split}/X",
            shape=(n_new, num_bands, patch_size, patch_size),
            dtype=np.float32,
            chunks=(HDF5_CHUNK_PATCHES, num_bands, patch_size, patch_size),
            compression='lzf')
        f.create_dataset(
            f"{tmp_split}/y",
            shape=(n_new,), dtype=np.int64,
            chunks=(4096,), compression='lzf')
    written = 0
    for chunk_start in range(0, n_new, read_chunk):
        chunk_end = min(chunk_start + read_chunk, n_new)
        chunk_idx = sorted_kept[chunk_start:chunk_end]
        with h5py.File(h5_path, 'r') as f:
            X_chunk = f[f"{split_name}/X"][chunk_idx]
            y_chunk = f[f"{split_name}/y"][chunk_idx]
        with h5py.File(h5_path, 'a') as f:
            f[f"{tmp_split}/X"][chunk_start:chunk_end] = X_chunk
            f[f"{tmp_split}/y"][chunk_start:chunk_end] = y_chunk
        written += len(chunk_idx)
        del X_chunk, y_chunk
        gc.collect()
    with h5py.File(h5_path, 'a') as f:
        del f[split_name]
        f.move(tmp_split, split_name)
    return n_new
class HDF5Dataset(Dataset):
    def __init__(self, h5_path, split_name):
        self.h5_path = h5_path
        self.split_name = split_name
        self._h5 = None
        with h5py.File(h5_path, 'r') as f:
            self.length = f[f"{split_name}/y"].shape[0]
    def _open(self):
        if self._h5 is None or not self._h5.id.valid:
            self._h5 = h5py.File(self.h5_path, 'r', swmr=True)
    def __len__(self):
        return self.length
    def __getitem__(self, idx):
        self._open()
        X = torch.from_numpy(self._h5[f"{self.split_name}/X"][idx]).float()
        y = int(self._h5[f"{self.split_name}/y"][idx])
        return X, torch.tensor(y, dtype=torch.long)
    def __del__(self):
        if self._h5 is not None:
            try:
                self._h5.close()
            except Exception:
                pass
def worker_init_fn(worker_id):
    seed = (torch.initial_seed() + worker_id) % (2 ** 32)
    np.random.seed(seed)
    random.seed(seed)
def build_loaders(real_dir=None, aug_dir=None, mapping_path="mapping.json",
                  split_mode="aug_real", use_pca=True, pca_components=30,
                  patch_size=13, test_ratio=0.15, val_ratio=0.15,
