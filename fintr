        f.attrs['label2idx'] = json.dumps(label2idx)
        f.attrs['patch_size'] = patch_size
        f.attrs['num_bands'] = pca_components if use_pca else -1
        f.attrs['created_at'] = datetime.now().isoformat()
    return _make_loaders(h5_path, class_names, label2idx, patch_size,
                         pca_components if use_pca else None,
                         balance_train, batch_size, num_workers)
def _make_loaders(h5_path, class_names, label2idx, patch_size,
                  num_bands_override, balance_train, batch_size, num_workers):
    train_ds = HDF5Dataset(str(h5_path), 'train')
