def build_loaders_ddp(rank: int, world_size: int, **kwargs):
    """
    Variante pour DistributedDataParallel.
    Chaque processus (rank) reçoit un sous-ensemble du dataset via DistributedSampler.

    Usage :
        # Dans chaque processus lancé par torchrun :
        train_loader, val_loader, test_loader, meta = build_loaders_ddp(
            rank=rank, world_size=world_size, **cfg
        )
    """
    train_loader, val_loader, test_loader, meta = build_loaders(**kwargs)

    # Remplacer les samplers par des DistributedSampler
    train_sampler = DistributedSampler(
        train_loader.dataset, num_replicas=world_size, rank=rank, shuffle=True)
    val_sampler = DistributedSampler(
        val_loader.dataset, num_replicas=world_size, rank=rank, shuffle=False)

    pin = torch.cuda.is_available()
    nw  = kwargs.get("num_workers", 4)
    bs  = kwargs.get("batch_size", 64)

    train_loader = DataLoader(
        train_loader.dataset, batch_size=bs, sampler=train_sampler,
        num_workers=nw, pin_memory=pin,
        worker_init_fn=worker_init_fn, persistent_workers=(nw > 0)
    )
    val_loader = DataLoader(
        val_loader.dataset, batch_size=bs, sampler=val_sampler,
        num_workers=nw, pin_memory=pin,
        worker_init_fn=worker_init_fn, persistent_workers=(nw > 0)
    )
    return train_loader, val_loader, test_loader, meta


