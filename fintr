def save_indices_npz(indices_data: dict, cache_dir: Path, config_hash: str) -> Path:
    cache_dir.mkdir(parents=True, exist_ok=True)
    out_path = cache_dir / f"indices_{config_hash}.npz"

    # Sérialiser en arrays numpy pour compacité
    def pack(lst):
        if not lst:
            return {}
        hdrs    = np.array([it["hdr"]    for it in lst])
        sources = np.array([it["source"] for it in lst])
        rows    = np.array([it["row"]    for it in lst], dtype=np.int32)
        cols    = np.array([it["col"]    for it in lst], dtype=np.int32)
        labels  = np.array([it["label"]  for it in lst], dtype=np.int32)
        return {"hdrs": hdrs, "sources": sources, "rows": rows,
                "cols": cols, "labels": labels}

    train_p = pack(indices_data["train"])
    val_p   = pack(indices_data["val"])
    test_p  = pack(indices_data["test"])

    np.savez_compressed(
        out_path,
        train_hdrs=train_p["hdrs"],    train_sources=train_p["sources"],
        train_rows=train_p["rows"],    train_cols=train_p["cols"],
        train_labels=train_p["labels"],
        val_hdrs=val_p["hdrs"],        val_sources=val_p["sources"],
        val_rows=val_p["rows"],        val_cols=val_p["cols"],
        val_labels=val_p["labels"],
        test_hdrs=test_p["hdrs"],      test_sources=test_p["sources"],
        test_rows=test_p["rows"],      test_cols=test_p["cols"],
        test_labels=test_p["labels"],
    )
    size_mb = out_path.stat().st_size / 1e6
    print(f"Indices sauvegardés: {out_path.name} ({size_mb:.1f} MB)")
    print(f"  train={len(indices_data['train']):,} | val={len(indices_data['val']):,} | test={len(indices_data['test']):,}")
    return out_path


def load_indices_npz(cache_dir: Path, config_hash: str):
    path = cache_dir / f"indices_{config_hash}.npz"
    if not path.exists():
        return None

    data = np.load(path, allow_pickle=True)

    def unpack(prefix):
        hdrs    = data[f"{prefix}_hdrs"]
        sources = data[f"{prefix}_sources"]
        rows    = data[f"{prefix}_rows"]
        cols    = data[f"{prefix}_cols"]
        labels  = data[f"{prefix}_labels"]
        return [
            {"hdr": str(h), "source": str(s), "row": int(r), "col": int(c), "label": int(l)}
            for h, s, r, c, l in zip(hdrs, sources, rows, cols, labels)
        ]

    print(f"Indices chargés depuis cache: {path.name}")
    return {"train": unpack("train"), "val": unpack("val"), "test": unpack("test")}


