"""
dataset_v2.py — Pipeline HSI → SSFTTnet
Stratégie : LAZY DATASET + LRU CACHE par worker
- Zéro preprocessing : pas de HDF5, pas de 6 jours d'attente
- Les cubes sont chargés une fois par worker et restés chauds en RAM
- La PCA est fittée et sauvegardée une seule fois (pickle)
- Les indices (coordonnées + labels) sont sauvegardés en .npz (~quelques MB)
- 4 GPUs utilisés pendant l'entraînement via DistributedDataParallel
"""

import gc
import json
import random
import re
import pickle
import hashlib
from collections import defaultdict, OrderedDict
from pathlib import Path
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed

import numpy as np
import torch
import torch.nn.functional as F
from sklearn.decomposition import PCA
from spectral import envi
from torch.utils.data import DataLoader, Dataset, DistributedSampler

print(f"PyTorch: {torch.__version__} | CUDA: {torch.cuda.is_available()} | GPUs: {torch.cuda.device_count()}")
NUM_GPUS = torch.cuda.device_count()


# ─────────────────────────────────────────────
#  UTILITAIRES
# ─────────────────────────────────────────────

def load_mapping(mapping_path: str):
    with open(mapping_path) as f:
        raw = json.load(f)
    extrude2final = {}
    for final_class, extrude_list in raw.items():
        for ext in extrude_list:
            extrude2final[ext.strip()] = final_class
    final_classes = sorted(raw.keys())
    class_names = final_classes + ["background"]
    label2idx = {name: i for i, name in enumerate(class_names)}
    print(f"Mapping: {len(extrude2final)} labels -> {len(final_classes)} classes + background")
    return extrude2final, class_names, label2idx


def _load_envi_cube(hdr_path: Path, source: str) -> tuple[np.ndarray, list]:
    img = envi.open(str(hdr_path))
    cube = img.load().astype(np.float32)
    wavelengths = [float(w) for w in img.metadata.get("wavelength", [])]

    if cube.ndim == 3:
        if source == "real":
            # shape (H, W, B) → (B, H, W)
            if cube.shape[2] == len(wavelengths) and len(wavelengths) > 0:
                cube = cube.transpose(2, 0, 1)
        else:
            # shape (B, H, W) ou (H, B, W) selon augmentation
            if len(wavelengths) > 0 and cube.shape[1] == len(wavelengths):
                cube = cube.transpose(1, 0, 2)
            elif cube.shape[0] != len(wavelengths):
                print(f"  Warning: forme inattendue {cube.shape} pour {hdr_path.name}")

    if cube.ndim != 3:
        raise ValueError(f"Cube invalide: {cube.shape}")
    return cube, wavelengths


def _load_shapes(json_path: Path) -> list:
    with open(json_path) as f:
        ann = json.load(f)
    return ann.get("shapes", [])


# ─────────────────────────────────────────────
#  COLLECTE DES MÉTADONNÉES PLOTS
# ─────────────────────────────────────────────

def collect_plots_meta(real_dir=None, aug_dir=None) -> list[dict]:
    meta_list = []

    if real_dir is not None:
        real_dir = Path(real_dir)
        if real_dir.exists():
            for hdr in sorted(real_dir.glob("plot_*_cube.hdr")):
                m = re.match(r"plot_(\d+)_cube", hdr.stem)
                if not m:
                    continue
                jsn = real_dir / f"plot_{m.group(1)}_annotations.json"
                if jsn.exists():
                    meta_list.append({"source": "real", "name": hdr.stem, "hdr": hdr, "jsn": jsn})
        else:
            print(f"Warning: real_dir='{real_dir}' introuvable")

    if aug_dir is not None:
        aug_dir = Path(aug_dir)
        if aug_dir.exists():
            before = len(meta_list)
            for hdr in sorted(aug_dir.glob("*.hdr")):
                if any(hdr.stem.endswith(s) for s in ("_ratio", "_cube")):
                    continue
                jsn = aug_dir / f"{hdr.stem}.json"
                if not jsn.exists():
                    continue
                source = "circle" if "circle" in hdr.stem.lower() else "aug"
                meta_list.append({"source": source, "name": hdr.stem, "hdr": hdr, "jsn": jsn})
            print(f"aug_dir -> {len(meta_list) - before} plots augmentés")
        else:
            print(f"Warning: aug_dir='{aug_dir}' introuvable")

    if not meta_list:
        raise RuntimeError("Aucun plot trouvé. Vérifiez --real_dir et --aug_dir.")

    n_real = sum(1 for m in meta_list if m["source"] == "real")
    print(f"Total: {len(meta_list)} plots ({n_real} réels | {len(meta_list)-n_real} augmentés)")
    return meta_list


def split_plots(plots_meta, split_mode="aug_real", val_ratio=0.15,
                test_ratio=0.15, random_state=345):
    rng = random.Random(random_state)
    if split_mode == "aug_real":
        aug  = [p for p in plots_meta if p["source"] in ("aug", "circle")]
        real = [p for p in plots_meta if p["source"] == "real"]
        rng.shuffle(aug)
        n_val = max(1, int(len(aug) * val_ratio))
        val, train, test = aug[:n_val], aug[n_val:], real
        print(f"Split aug_real: train={len(train)} | val={len(val)} | test={len(test)}")
    elif split_mode == "shuffle":
        all_p = plots_meta[:]
        rng.shuffle(all_p)
        n = len(all_p)
        n_test = max(1, int(n * test_ratio))
        n_val  = max(1, int(n * val_ratio))
        test, val, train = all_p[:n_test], all_p[n_test:n_test+n_val], all_p[n_test+n_val:]
        print(f"Split shuffle: train={len(train)} | val={len(val)} | test={len(test)}")
    else:
        raise ValueError(f"split_mode inconnu: '{split_mode}'")
    return train, val, test


# ─────────────────────────────────────────────
#  RASTERISATION POLYGONE (CPU, rapide)
# ─────────────────────────────────────────────

def _rasterize_polygon_cpu(points, H, W) -> np.ndarray:
    """Ray-casting vectorisé sur CPU. Suffisant pour la collecte d'indices."""
    pts = np.array(points, dtype=np.float32)
    n   = len(pts)
    rows = np.arange(H, dtype=np.float32) + 0.5
    cols = np.arange(W, dtype=np.float32) + 0.5
    grid_c, grid_r = np.meshgrid(cols, rows)  # (H, W)
    px = grid_c.ravel()
    py = grid_r.ravel()

    x1, y1 = pts[:, 0], pts[:, 1]
    x2 = np.roll(x1, -1)
    y2 = np.roll(y1, -1)

    inside = np.zeros(len(px), dtype=bool)
    for i in range(n):
        cond1 = (y1[i] < py) != (y2[i] < py)
        denom = y2[i] - y1[i]
        if abs(denom) < 1e-10:
            continue
        x_int = x1[i] + (py - y1[i]) * (x2[i] - x1[i]) / denom
        inside ^= cond1 & (px < x_int)

    return inside.reshape(H, W)


def build_label_map(H, W, shapes, extrude2final, label2idx) -> np.ndarray:
    bg_idx    = label2idx["background"]
    label_map = np.full((H, W), bg_idx, dtype=np.int32)

    for shape in shapes:
        raw   = shape.get("label", "").strip()
        stype = shape.get("shape_type", "")
        if raw.lower() == "trou" or stype not in ("polygon", "rectangle"):
            continue
        final = extrude2final.get(raw)
        if final is None:
            continue
        pts = shape["points"]
        if len(pts) < 3:
            continue
        try:
            mask = _rasterize_polygon_cpu(pts, H, W)
            label_map[mask] = label2idx[final]
        except Exception as e:
            print(f"  Warning rasterisation '{raw}': {e}")

    return label_map


# ─────────────────────────────────────────────
#  PCA
# ─────────────────────────────────────────────

def fit_or_load_pca(real_meta_list, pca_components, cache_dir,
                    config_hash, fit_max_pixels=500_000) -> PCA:
    pca_path = Path(cache_dir) / f"pca_{config_hash}.pkl"
    if pca_path.exists():
        print(f"PCA chargée depuis cache: {pca_path.name}")
        with open(pca_path, "rb") as f:
            return pickle.load(f)

    print(f"\nFit PCA sur {len(real_meta_list)} cubes réels...")
    all_pixels = []
    for meta in real_meta_list:
        try:
            cube, _ = _load_envi_cube(meta["hdr"], meta["source"])
            B, H, W = cube.shape
            n = min(20_000, H * W)
            idx = np.random.choice(H * W, n, replace=False)
            all_pixels.append(cube.reshape(B, -1)[:, idx].T)
            del cube; gc.collect()
        except Exception as e:
            print(f"  Warning {meta['name']}: {e}")

    all_pixels = np.concatenate(all_pixels, axis=0)
    if len(all_pixels) > fit_max_pixels:
        idx = np.random.choice(len(all_pixels), fit_max_pixels, replace=False)
        all_pixels = all_pixels[idx]

    pca = PCA(n_components=pca_components, whiten=True)
    pca.fit(all_pixels)
    print(f"  Variance expliquée: {pca.explained_variance_ratio_.sum():.3f}")

    with open(pca_path, "wb") as f:
        pickle.dump(pca, f, protocol=pickle.HIGHEST_PROTOCOL)
    print(f"  PCA sauvegardée: {pca_path.name}")
    return pca


def apply_pca(cube: np.ndarray, pca: PCA, chunk=20_000) -> np.ndarray:
    B, H, W = cube.shape
    flat = cube.reshape(B, -1).T          # (H*W, B)
    out  = np.empty((H * W, pca.n_components_), dtype=np.float32)
    for s in range(0, len(flat), chunk):
        out[s:s+chunk] = pca.transform(flat[s:s+chunk])
    return out.T.reshape(pca.n_components_, H, W).astype(np.float32)


# ─────────────────────────────────────────────
#  COLLECTE DES INDICES (coordonnées + labels)
# ─────────────────────────────────────────────

def _collect_one_plot(meta, extrude2final, label2idx, bg_ratio,
                      random_state, pca) -> list[dict]:
    """Charge un cube, construit la label map, retourne les indices filtrés."""
    name   = meta["name"]
    source = meta["source"]
    rng    = np.random.default_rng(seed=random_state + hash(name) % 10_000)
    bg_idx = label2idx["background"]

    try:
        cube, _ = _load_envi_cube(meta["hdr"], source)
    except Exception as e:
        print(f"  Warning {name}: {e}")
        return []

    # PCA optionnelle pour inférer H, W (on n'a besoin que des dims ici)
    B, H, W = cube.shape
    del cube; gc.collect()

    # Label map depuis annotations
    shapes    = _load_shapes(meta["jsn"])
    label_map = build_label_map(H, W, shapes, extrude2final, label2idx)

    rows, cols    = np.where(label_map >= 0)
    labels_all    = label_map[rows, cols]

    # Équilibrage background
    bg_mask  = labels_all == bg_idx
    fg_mask  = ~bg_mask
    n_fg     = int(fg_mask.sum())
    n_bg     = int(bg_mask.sum())
    keep     = fg_mask.copy()

    if n_fg > 0:
        n_bg_keep = min(int(n_fg * bg_ratio), n_bg)
        if n_bg_keep > 0:
            chosen = rng.choice(np.where(bg_mask)[0], size=n_bg_keep, replace=False)
            keep[chosen] = True

    rows_k   = rows[keep].astype(np.int32)
    cols_k   = cols[keep].astype(np.int32)
    labels_k = labels_all[keep].astype(np.int32)

    # On stocke le chemin absolu du cube pour le lazy loading
    hdr_str = str(meta["hdr"])

    return [
        {"hdr": hdr_str, "source": source, "row": int(r), "col": int(c), "label": int(l)}
        for r, c, l in zip(rows_k, cols_k, labels_k)
    ]


def collect_all_indices(plot_meta_list, extrude2final, label2idx,
                        bg_ratio, random_state, pca,
                        num_workers=8) -> tuple[list, dict]:
    """
    Collecte les indices pour tous les plots en parallèle (CPU threads).
    Rapide car on ne charge les cubes que pour lire H, W.
    """
    print(f"\nCollecte des indices ({len(plot_meta_list)} plots, {num_workers} threads)...")
    all_indices   = []
    class_counts  = defaultdict(int)
    idx2name      = {v: k for k, v in label2idx.items()}

    with ThreadPoolExecutor(max_workers=num_workers) as ex:
        futures = {
            ex.submit(_collect_one_plot, meta, extrude2final, label2idx,
                      bg_ratio, random_state, pca): meta
            for meta in plot_meta_list
        }
        done = 0
        for fut in as_completed(futures):
            meta = futures[fut]
            try:
                items = fut.result()
                all_indices.extend(items)
                for it in items:
                    class_counts[idx2name[it["label"]]] += 1
                done += 1
                if done % 100 == 0 or done == len(plot_meta_list):
                    print(f"  {done}/{len(plot_meta_list)} plots traités — {len(all_indices):,} indices")
            except Exception as e:
                print(f"  Erreur {meta['name']}: {e}")

    return all_indices, dict(class_counts)


def balance_indices(indices_list, label2idx, random_state=345) -> list:
    """Undersampling à la classe minoritaire (toutes classes confondues)."""
    by_label = defaultdict(list)
    for it in indices_list:
        by_label[it["label"]].append(it)

    min_count = min(len(v) for v in by_label.values())
    rng = random.Random(random_state)
    balanced = []
    for label, items in by_label.items():
        rng.shuffle(items)
        balanced.extend(items[:min_count])
    rng.shuffle(balanced)
    print(f"  Balancing: {len(indices_list):,} -> {len(balanced):,} indices ({min_count}/classe)")
    return balanced


