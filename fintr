import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
import torch.distributed as dist
from torch.nn.parallel import DataParallel
from torch.cuda.amp import GradScaler, autocast
from sklearn.metrics import confusion_matrix, accuracy_score, classification_report, cohen_kappa_score
from operator import truediv
import time
import sys
import argparse
from pathlib import Path
sys.path.append(str(Path(__file__).parent))
from dataset_v4 import build_loaders
import SSFTTnet

def AA_andEachClassAccuracy(cm):
    diag = np.diag(cm)
    row_sum = np.sum(cm, axis=1)
    each_acc = np.nan_to_num(truediv(diag, row_sum))
    return each_acc, np.mean(each_acc)

def acc_reports(y_test, y_pred, class_names):
    report = classification_report(y_test, y_pred, digits=4, target_names=class_names)
    oa = accuracy_score(y_test, y_pred)
    cm = confusion_matrix(y_test, y_pred)
    each_acc, aa = AA_andEachClassAccuracy(cm)
    kappa = cohen_kappa_score(y_test, y_pred)
    return report, oa * 100, cm, each_acc * 100, aa * 100, kappa * 100

def build_model(meta, device, num_gpus):
    net = SSFTTnet.SSFTTnet(
        n_bands=meta['num_bands'],
        n_classes=meta['num_classes'],
        patch_size=meta['patch_size']
    )
    net = net.to(device)
    if num_gpus > 1:
        net = DataParallel(net, device_ids=list(range(num_gpus)))
        print(f"DataParallel sur {num_gpus} GPUs")
    return net

def train_one_epoch(net, loader, criterion, optimizer, scaler, device, epoch, epochs, accum_steps):
    net.train()
    epoch_loss = 0.0
    correct = 0
    total = 0
    optimizer.zero_grad(set_to_none=True)
    for i, (data, target) in enumerate(loader):
        data = data.to(device, non_blocking=True)
        target = target.to(device, non_blocking=True)
        with autocast(dtype=torch.bfloat16):
            outputs = net(data)
            loss = criterion(outputs, target) / accum_steps
        scaler.scale(loss).backward()
        if (i + 1) % accum_steps == 0 or (i + 1) == len(loader):
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(net.parameters(), max_norm=1.0)
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad(set_to_none=True)
        epoch_loss += loss.item() * accum_steps
        preds = outputs.argmax(dim=1)
        correct += (preds == target).sum().item()
        total += target.size(0)
        if (i + 1) % 500 == 0:
            running_acc = 100 * correct / total
            print(f"  Epoch [{epoch+1}/{epochs}] "
                  f"Batch [{i+1}/{len(loader)}] "
                  f"Loss: {epoch_loss/(i+1):.4f} "
                  f"Acc: {running_acc:.2f}%")
    return epoch_loss / len(loader), 100 * correct / total

@torch.no_grad()
def evaluate(net, loader, criterion, device):
    net.eval()
    total_loss = 0.0
    y_pred, y_true = [], []
    for data, target in loader:
        data = data.to(device, non_blocking=True)
        target = target.to(device, non_blocking=True)
        with autocast(dtype=torch.bfloat16):
            outputs = net(data)
            loss = criterion(outputs, target)
        total_loss += loss.item()
        y_pred.extend(outputs.argmax(dim=1).cpu().numpy())
        y_true.extend(target.cpu().numpy())
    y_pred = np.array(y_pred)
    y_true = np.array(y_true)
    oa = accuracy_score(y_true, y_pred) * 100
    cm = confusion_matrix(y_true, y_pred)
    _, aa = AA_andEachClassAccuracy(cm)
    kappa = cohen_kappa_score(y_true, y_pred) * 100
    return total_loss / len(loader), oa, aa * 100, kappa, y_pred, y_true

def train(train_loader, val_loader, meta, epochs, lr, device, num_gpus, accum_steps, save_dir):
    save_dir = Path(save_dir)
    save_dir.mkdir(parents=True, exist_ok=True)
    net = build_model(meta, device, num_gpus)
    criterion = nn.CrossEntropyLoss(label_smoothing=0.1)
    optimizer = optim.AdamW(net.parameters(), lr=lr, weight_decay=1e-4)
    scheduler = optim.lr_scheduler.OneCycleLR(
        optimizer,
        max_lr=lr,
        epochs=epochs,
        steps_per_epoch=len(train_loader) // accum_steps,
        pct_start=0.1,
        anneal_strategy='cos'
    )
    scaler = GradScaler()
    best_oa = 0.0
    history = []
    print(f"\nBatch effectif : {train_loader.batch_size * num_gpus * accum_steps:,} samples")
    print(f"Steps/epoch    : {len(train_loader) // accum_steps:,}")
    print(f"Mixed precision: bfloat16")
    print("=" * 60)
    for epoch in range(epochs):
        t0 = time.perf_counter()
        train_loss, train_acc = train_one_epoch(
            net, train_loader, criterion, optimizer, scaler,
            device, epoch, epochs, accum_steps)
        val_loss, val_oa, val_aa, val_kappa, _, _ = evaluate(
            net, val_loader, criterion, device)
        scheduler.step()
        elapsed = time.perf_counter() - t0
        history.append({
            'epoch': epoch + 1,
            'train_loss': train_loss, 'train_acc': train_acc,
            'val_loss': val_loss, 'val_oa': val_oa,
            'val_aa': val_aa, 'val_kappa': val_kappa,
        })
        print(f"[Epoch {epoch+1:3d}/{epochs}] "
              f"Train loss={train_loss:.4f} acc={train_acc:.2f}% | "
              f"Val loss={val_loss:.4f} OA={val_oa:.2f}% "
              f"AA={val_aa:.2f}% K={val_kappa:.2f}% | "
              f"LR={scheduler.get_last_lr()[0]:.2e} | "
              f"{elapsed:.0f}s")
        if val_oa > best_oa:
            best_oa = val_oa
            state = net.module.state_dict() if isinstance(net, DataParallel) else net.state_dict()
            torch.save(state, save_dir / "best.pth")
            print(f"  → Nouveau meilleur modèle sauvegardé (OA={best_oa:.2f}%)")
    state = net.module.state_dict() if isinstance(net, DataParallel) else net.state_dict()
    torch.save(state, save_dir / "final.pth")
    _save_history(history, save_dir)
    return net

def _save_history(history, save_dir):
    path = save_dir / "history.csv"
    with open(path, 'w') as f:
        keys = list(history[0].keys())
        f.write(','.join(keys) + '\n')
        for row in history:
            f.write(','.join(str(row[k]) for k in keys) + '\n')
    print(f"Historique sauvegardé : {path}")

@torch.no_grad()
def test(net, test_loader, criterion, device, meta, save_dir):
    save_dir = Path(save_dir)
    print("\nChargement du meilleur modèle pour le test...")
    state = torch.load(save_dir / "best.pth", map_location=device)
    core = net.module if isinstance(net, DataParallel) else net
    core.load_state_dict(state)
    loss, oa, aa, kappa, y_pred, y_true = evaluate(net, test_loader, criterion, device)
    report, oa, cm, each_acc, aa, kappa = acc_reports(y_true, y_pred, meta['class_names'])
    print(f"\nTest OA    : {oa:.2f}%")
    print(f"Test AA    : {aa:.2f}%")
    print(f"Test Kappa : {kappa:.2f}%")
    print("\nPar classe :")
    for name, acc in zip(meta['class_names'], each_acc):
        print(f"  {name:25}: {acc:.2f}%")
    print(f"\nRapport :\n{report}")
    out = save_dir / "classification_report.txt"
    with open(out, 'w') as f:
        f.write(f"OA: {oa}\nAA: {aa}\nKappa: {kappa}\n\n")
        f.write(f"Par classe: {each_acc}\n\n")
        f.write(f"{report}\n\nMatrice de confusion:\n{cm}\n")
    print(f"Résultats sauvegardés : {out}")
    return oa, aa, kappa, each_acc, cm

